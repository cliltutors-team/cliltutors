---
/**
 * PricingTier Component
 * Premium pricing card with feature list
 * Features: Feature list, CTA button, featured tier highlight, i18n labels
 */

interface PricingFeature {
  text: string;
  included?: boolean;
  highlighted?: boolean;
}

interface Props {
  name: string;
  price: string | number;
  priceUnit?: string;
  pricePeriod?: string;
  description?: string;
  features: PricingFeature[];
  cta?: {
    text: string;
    href: string;
  };
  featured?: boolean;
  variant?: 'default' | 'minimal' | 'card';
  badge?: string;
  analytics?: {
    tierId?: string;
    clickAction?: string;
  };
}

const {
  name,
  price,
  priceUnit = '$',
  pricePeriod = '/month',
  description,
  features,
  cta,
  featured = false,
  variant = 'default',
  badge,
  analytics
} = Astro.props;
---

<div
  class:list={[
    'pricing-tier',
    `variant-${variant}`,
    featured && 'tier-featured'
  ]}
  {...analytics?.tierId && { 'data-tier': analytics.tierId }}
>
  {/* Featured Badge */}
  <div class="reveal" style="--stagger: 0">
  {featured && badge && (
    <div class="featured-badge">
      <svg class="badge-icon" viewBox="0 0 20 20" fill="currentColor">
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      </svg>
      <span>{badge}</span>
    </div>
  )}
  </div>

  {/* Header */}
  <div class="tier-header reveal" style="--stagger: 1">
    <h3 class="tier-name">{name}</h3>

    <div class="tier-price">
      {typeof price === 'number' && (
        <>
          <span class="price-unit">{priceUnit}</span>
          <span class="price-value">{price.toLocaleString()}</span>
          <span class="price-period">{pricePeriod}</span>
        </>
      )}
      {typeof price === 'string' && (
        <span class="price-custom">{price}</span>
      )}
    </div>

    {description && (
      <p class="tier-description">{description}</p>
    )}
  </div>

  {/* Features */}
  <ul class="tier-features reveal" style="--stagger: 2">
    {features.map((feature) => (
      <li class:list={['feature-item', feature.highlighted && 'feature-highlighted']}>
        {feature.included !== false ? (
          <svg class="feature-icon icon-check" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        ) : (
          <svg class="feature-icon icon-x" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        )}
        <span class="feature-text">{feature.text}</span>
      </li>
    ))}
  </ul>

  {/* CTA */}
  {cta && (
    <a
      href={cta.href}
      class:list={['tier-cta', 'reveal', featured && 'cta-primary']}
      style="--stagger: 3"
      {...analytics?.clickAction && { 'data-action': analytics.clickAction }}
    >
      <span>{cta.text}</span>
      <svg class="cta-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </a>
  )}
</div>

<style>
.pricing-tier {
  position: relative;
  background: white;
  border-radius: 1.5rem;
  padding: 2rem;
  border: 2px solid var(--color-brand-blue-200);
  display: flex;
  flex-direction: column;
  transition: all 400ms var(--ease-out-expo);
}

.pricing-tier:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
  border-color: var(--color-brand-blue-200);
}

/* Featured Tier */
.tier-featured {
  border-color: var(--color-brand-gold);
  box-shadow: 0 0 0 1px var(--color-brand-gold);
  background: linear-gradient(135deg, white 0%, var(--color-brand-gold-50) 100%);
}

.tier-featured:hover {
  transform: translateY(-8px) scale(1.02);
  box-shadow: 
    0 24px 60px rgba(254, 187, 55, 0.15),
    0 12px 30px rgba(0, 0, 0, 0.1);
}

/* Featured Badge */
.featured-badge {
  position: absolute;
  top: -0.75rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.5rem 1rem;
  background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-orange));
  color: white;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  border-radius: 100px;
  box-shadow: 0 4px 12px rgba(254, 187, 55, 0.4);
}

.badge-icon {
  width: 1rem;
  height: 1rem;
}

/* Header */
.tier-header {
  margin-bottom: 1.5rem;
  text-align: center;
}

.tier-name {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-brand-navy);
  margin: 0 0 1rem 0;
}

.tier-price {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.125rem;
}

.price-unit {
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-slate-light);
}

.price-value {
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  color: var(--color-brand-navy);
  line-height: 1;
}

.price-period {
  font-size: 0.875rem;
  color: var(--color-slate-light);
}

.price-custom {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-brand-navy);
}

.tier-description {
  font-size: 0.875rem;
  color: var(--color-slate-light);
  margin: 0.75rem 0 0 0;
  line-height: 1.5;
}

/* Features */
.tier-features {
  list-style: none;
  padding: 0;
  margin: 0 0 2rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}

.feature-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
}

.feature-icon {
  width: 1.25rem;
  height: 1.25rem;
  flex-shrink: 0;
  margin-top: 0.125rem;
}

.icon-check {
  color: var(--color-brand-blue);
}

.icon-x {
  color: var(--color-brand-blue-400);
}

.feature-highlighted {
  padding: 0.5rem 0.75rem;
  margin: 0 -0.75rem;
  background: var(--color-brand-blue-50);
  border-radius: 0.5rem;
}

.feature-highlighted .feature-text {
  font-weight: 600;
  color: var(--color-brand-navy);
}

.feature-text {
  font-size: 0.9375rem;
  color: var(--color-brand-navy-700);
  line-height: 1.5;
}

/* CTA */
.tier-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 1rem;
  background: var(--color-brand-navy);
  color: white;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  border-radius: 100px;
  transition: all 300ms var(--ease-out-expo);
}

.tier-cta:hover {
  background: var(--color-brand-indigo);
  transform: translateY(-2px);
  gap: 0.75rem;
}

.cta-primary {
  background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-orange));
  box-shadow: 0 4px 14px rgba(254, 187, 55, 0.4);
}

.cta-primary:hover {
  background: linear-gradient(135deg, var(--color-brand-orange), var(--color-brand-gold));
  box-shadow: 0 6px 20px rgba(254, 187, 55, 0.5);
}

.cta-icon {
  width: 1.125rem;
  height: 1.125rem;
  transition: transform 250ms var(--ease-out-expo);
}

.tier-cta:hover .cta-icon {
  transform: translateX(4px);
}

  .pricing-tier .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.7s var(--ease-out-expo), transform 0.7s var(--ease-out-expo);
    transition-delay: calc(var(--stagger, 0) * 80ms);
  }
.pricing-tier .reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

  /* Variant: Minimal */
.variant-minimal {
  border: none;
  background: transparent;
  padding: 0;
}

.variant-minimal:hover {
  transform: none;
  box-shadow: none;
}

.variant-minimal .tier-features {
  gap: 0.5rem;
}

/* Variant: Card */
.variant-card {
  border: none;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

@media (prefers-reduced-motion: reduce) {
  .pricing-tier:hover {
    transform: none;
  }

  .tier-featured:hover {
    transform: none;
  }
}

/* Responsive */
@media (max-width: 768px) {
  .pricing-tier {
    padding: 1.5rem;
  }
  
  .price-value {
    font-size: 2.5rem;
  }
  }
</style>


