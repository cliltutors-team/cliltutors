---
import SectionHeader from './SectionHeader.astro';

interface Instructor {
  id: string;
  name: string;
  title: string;
  bio: string;
  image: string;
  courses: number;
  students: number;
  rating: number;
  specialties: string[];
  social?: {
    linkedin?: string;
    twitter?: string;
    website?: string;
  };
}

interface Props {
  instructors: Instructor[];
  title: string;
  subtitle: string;
  eyebrow: string;
  viewAllText: string;
  coursesText: string;
  studentsText: string;
  ratingText: string;
}

const {
  instructors,
  title,
  subtitle,
  eyebrow,
  viewAllText,
  coursesText,
  studentsText,
  ratingText,
} = Astro.props;
---

<section class="section-padding gradient-section-alt instructor-spotlight-section">
  <div class="container-narrow">
    <SectionHeader eyebrow={eyebrow} title={title} description={subtitle} />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        instructors.map((instructor, index) => (
		<article
			class="instructor-card group reveal"
			style={`--stagger: ${1 + index}`}
		>
            <div class="relative overflow-hidden rounded-t-2xl">
              <div class="aspect-[4/5] bg-gradient-to-br from-brand-blue-50 to-brand-purple-50">
                <img
                  src={instructor.image}
                  alt={instructor.name}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>

              <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/80 via-brand-navy/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-400">
                <div class="absolute bottom-4 left-4 right-4 flex justify-center gap-3">
                  {instructor.social?.linkedin && (
                    <a
                      href={instructor.social.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-10 h-10 rounded-lg bg-white/20 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white/30 transition-colors"
                      aria-label={`${instructor.name}'s LinkedIn`}
                    >
                      <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" />
                      </svg>
                    </a>
                  )}
                  {instructor.social?.twitter && (
                    <a
                      href={instructor.social.twitter}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-10 h-10 rounded-lg bg-white/20 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white/30 transition-colors"
                      aria-label={`${instructor.name}'s Twitter`}
                    >
                      <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                      </svg>
                    </a>
                  )}
                </div>
              </div>

              <div class="absolute top-4 right-4 px-3 py-1.5 bg-white/95 backdrop-blur-sm rounded-lg flex items-center gap-1.5 shadow-sm">
                <svg
                  class="w-4 h-4 text-brand-gold"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="text-sm font-bold text-brand-navy">
                  {instructor.rating.toFixed(1)}
                </span>
              </div>
            </div>

            <div class="bg-white rounded-b-2xl p-5">
              <h3 class="font-heading font-bold text-xl text-brand-navy mb-1 group-hover:text-brand-indigo transition-colors">
                {instructor.name}
              </h3>
              <p class="text-sm text-brand-blue font-medium mb-3">
                {instructor.title}
              </p>

              <div class="flex items-center gap-4 mb-4 text-xs text-brand-navy-700">
                <div class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 6.253v13m0-13C10.832 6.477 9.246 7.073 8 7.75c-1.246.677-2.667 1.075-4 1.25v11c1.333-.175 2.754-.573 4-1.25 1.246-.677 2.832-1.273 4-1.75m0-13c1.168.477 2.754 1.073 4 1.25v11c-1.333-.175-2.754-.573-4-1.25m0-13V3m0 13v3m0-3c-1.246.677-2.667 1.075-4 1.25m4-1.25c1.246.677 2.832 1.073 4 1.25"
                    />
                  </svg>
                  <span>
                    {instructor.courses} {coursesText}
                  </span>
                </div>
                <div class="flex items-center gap-1">
                  <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                    />
                  </svg>
                  <span>
                    {instructor.students.toLocaleString()} {studentsText}
                  </span>
                </div>
              </div>

              <div class="flex flex-wrap gap-2">
                {instructor.specialties.slice(0, 3).map((specialty) => (
                  <span class="px-2.5 py-1 bg-brand-blue-50 text-brand-blue text-xs font-medium rounded-md">
                    {specialty}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>

	<div class="mt-12 text-center reveal" style="--stagger: 20">
      <a
        href=`${Astro.currentLocale}/instructors`
        class="btn-secondary inline-flex items-center gap-2"
      >
        {viewAllText}
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .instructor-card {
    border-radius: 20px;
    overflow: hidden;
    background: var(--color-white);
    border: 1px solid var(--color-brand-blue-200);
    transition: all 400ms cubic-bezier(0.25, 1, 0.5, 1);
    position: relative;
  }

  .instructor-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 2px;
    background: linear-gradient(
      135deg,
      var(--color-brand-blue-200),
      var(--color-brand-purple-100),
      var(--color-brand-gold-100)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
  }

  .instructor-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(52, 53, 79, 0.15);
  }

.instructor-card:hover::before {
  opacity: 1;
}

.instructor-spotlight-section .reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  transition-delay: calc(var(--stagger, 0) * 80ms);
}

.instructor-spotlight-section .reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
