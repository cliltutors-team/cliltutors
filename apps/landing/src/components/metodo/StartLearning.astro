---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;

const features = [
  {
    titleKey: 'features.f1.title',
    descKey: 'features.f1.desc',
    image: '/images/canva/person_green.png',
    langs: ['start.spanish', 'start.english', 'start.portuguese'],
    langColors: ['bg-red-400', 'bg-yellow-400', 'bg-green-400'],
    bg: 'bg-gradient-to-br from-green-50 to-emerald-50',
  },
  {
    titleKey: 'features.f2.title',
    descKey: 'features.f2.desc',
    image: '/images/canva/person_pink.png',
    bg: 'bg-gradient-to-br from-pink-50 to-rose-50',
  },
  {
    titleKey: 'features.f3.title',
    descKey: 'features.f3.desc',
    image: '/images/canva/person_yellow.png',
    bg: 'bg-gradient-to-br from-amber-50 to-yellow-50',
  },
];
---

<section id="features" class="py-20 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <span class="inline-block bg-[#2563eb] text-white text-xs font-heading font-medium px-3 py-1 rounded-full uppercase tracking-wider mb-4">
        {t('start.badge')}
      </span>
      <h2 class="font-heading text-4xl md:text-5xl font-semibold text-[#2d3559] mb-4">
        {t('about.title')}
      </h2>
      <p class="text-gray-600 text-lg leading-relaxed" set:html={t('about.desc')} />
    </div>

    <!-- Feature Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {features.map((f) => (
        <div class={`${f.bg} rounded-3xl p-6 shadow-sm hover:shadow-md transition-shadow group overflow-hidden`}>
          <!-- Image -->
          <div class="relative h-56 mb-4 rounded-2xl overflow-hidden">
            <img
              src={f.image}
              alt=""
              class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
            />
          </div>

          <!-- Language pills (only for first card) -->
          {f.langs && (
            <div class="flex gap-2 mb-3">
              {f.langs.map((lk: string, i: number) => (
                <span class={`${f.langColors?.[i] || 'bg-gray-300'} text-white text-[11px] font-inter font-semibold px-3 py-1 rounded-full`}>
                  {t(lk)}
                </span>
              ))}
            </div>
          )}

          <!-- Title & Description -->
          <h3
            class="font-heading text-xl font-semibold text-[#2d3559] mb-2"
            set:html={t(f.titleKey)}
          />
          <p class="text-gray-600 text-sm leading-relaxed" set:html={t(f.descKey)} />
        </div>
      ))}
    </div>
  </div>
</section>
