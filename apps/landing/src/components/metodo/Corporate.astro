---
interface Props {
    t: (key: string) => string;
}
const { t } = Astro.props;
---

<section id="corporate" class="relative py-24 bg-[#2d3559] overflow-hidden">
    <!-- Decorative Blob Shapes -->
    <div
        class="absolute top-20 right-20 w-64 h-64 bg-purple-400/20 rounded-full blur-xl"
    >
    </div>
    <div
        class="absolute bottom-20 right-40 w-48 h-48 bg-rose-400/15 rounded-full blur-lg"
    >
    </div>
    <div
        class="absolute top-40 right-60 w-32 h-32 bg-white/5 rounded-full blur-md"
    >
    </div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Left: Content -->
            <div class="space-y-6">
                <p
                    class="text-sm font-bold uppercase tracking-[0.3em] text-white/60"
                >
                    CORPORATE
                </p>
                <p
                    class="text-xs font-bold uppercase tracking-[0.15em] text-white/50 max-w-sm"
                >
                    {t("corp.label")}
                </p>
                <h2
                    class="font-heading text-4xl md:text-5xl font-semibold text-white leading-tight"
                >
                    {t("corp.title").split(" ").slice(0, 4).join(" ")}
                </h2>
                <p
                    class="font-heading text-4xl md:text-5xl font-semibold text-white/60 italic leading-tight"
                >
                    {t("corp.title").split(" ").slice(4).join(" ")}
                </p>
                <a
                    href="#pricing"
                    class="inline-block mt-4 bg-white/10 hover:bg-white/20 text-white border border-white/20 px-8 py-3 rounded-full text-lg font-medium transition-all backdrop-blur-sm"
                >
                    {t("footer.cta")}
                </a>
            </div>

            <!-- Right: Image -->
            <div class="relative flex justify-center">
                <img
                    src="/images/web/Corporate_Hero.webp"
                    alt="Corporate team"
                    class="w-full max-w-md rounded-3xl object-cover shadow-2xl"
                />
                <!-- Rotating Badge -->
                <div class="absolute -top-4 -right-4 w-24 h-24">
                    <div
                        class="animate-[spin_20s_linear_infinite] w-full h-full"
                    >
                        <svg viewBox="0 0 100 100" class="w-full h-full">
                            <defs>
                                <path
                                    id="corpCircle"
                                    d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0"
                                ></path>
                            </defs>
                            <text
                                class="text-[8px] fill-white/70 font-heading font-medium uppercase tracking-widest"
                            >
                                <textPath href="#corpCircle">
                                    {t("corp.badge")}
                                </textPath>
                            </text>
                        </svg>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
