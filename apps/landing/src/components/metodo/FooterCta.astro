---
interface Props {
    t: (key: string) => string;
}
const { t } = Astro.props;
---

<!-- CTA Section -->
<section
    class="py-24 bg-gradient-to-br from-[#4ade80] via-[#22c55e] to-[#16a34a]"
>
    <div class="max-w-4xl mx-auto px-6 text-center">
        <h2
            class="font-heading text-4xl md:text-5xl font-semibold text-[#2d3559] mb-6 leading-tight"
            set:html={t("footer.title")}
        />
        <p class="text-[#2d3559]/80 text-lg mb-8 max-w-xl mx-auto">
            {t("footer.desc")}
        </p>
        <a
            href="#pricing"
            class="inline-block bg-[#2d3559] hover:bg-[#1e2a4a] text-white px-10 py-4 rounded-full text-lg font-medium transition-all shadow-lg hover:shadow-xl hover:scale-105"
        >
            {t("footer.cta")}
        </a>
    </div>
</section>

<!-- Footer -->
<footer class="bg-gradient-to-br from-[#4ade80] to-[#22c55e] pt-8 pb-6">
    <div class="max-w-7xl mx-auto px-6">
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-6"
        >
            <!-- Logo -->
            <a href="/" class="flex-shrink-0">
                <img
                    src="/images/logo-cliltutors.svg"
                    alt="Cliltutors"
                    class="h-10 w-auto opacity-80"
                />
            </a>

            <!-- Social Links -->
            <div class="flex items-center gap-4">
                <a
                    href="#"
                    class="text-[#2d3559] hover:text-[#2d3559]/70 transition-colors"
                    aria-label="YouTube"
                >
                    <img
                        src="/images/canva/youtube_icon.svg"
                        alt="YouTube"
                        class="w-8 h-8"
                    />
                </a>
                <a
                    href="#"
                    class="text-[#2d3559] hover:text-[#2d3559]/70 transition-colors"
                    aria-label="WhatsApp"
                >
                    <img
                        src="/images/canva/whatsapp_icon.svg"
                        alt="WhatsApp"
                        class="w-8 h-8"
                    />
                </a>
                <a
                    href="#"
                    class="text-[#2d3559] hover:text-[#2d3559]/70 transition-colors"
                    aria-label="LinkedIn"
                >
                    <img
                        src="/images/canva/linkedin_icon.svg"
                        alt="LinkedIn"
                        class="w-8 h-8"
                    />
                </a>
                <a
                    href="#"
                    class="text-[#2d3559] hover:text-[#2d3559]/70 transition-colors"
                    aria-label="Instagram"
                >
                    <img
                        src="/images/canva/instagram_icon.svg"
                        alt="Instagram"
                        class="w-8 h-8"
                    />
                </a>
            </div>
        </div>

        <p class="text-center text-[#2d3559]/60 text-sm mt-6">
            Copyright &copy; 2025 Cliltutors
        </p>
    </div>
</footer>
