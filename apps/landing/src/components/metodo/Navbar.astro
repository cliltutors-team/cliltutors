---
interface Props {
    t: (key: string) => string;
    lang: string;
}
const { t, lang } = Astro.props;

const langs = [
    { code: "pt", flag: "🇧🇷", label: "Português" },
    { code: "en", flag: "🇺🇸", label: "English" },
    { code: "es", flag: "🇪🇸", label: "Español" },
];
---

<nav
    class="sticky top-0 z-50 w-full backdrop-blur-md bg-white/80 border-b border-gray-100"
>
    <div class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
        <!-- Logo -->
        <a href={`/${lang}/metodo`} class="flex-shrink-0">
            <img
                src="/images/logo-cliltutors.svg"
                alt="Cliltutors"
                class="h-10 w-auto"
            />
        </a>

        <!-- Nav Links -->
        <div class="hidden md:flex items-center gap-8">
            <a
                href="#about"
                class="text-sm font-medium text-gray-700 hover:text-[#2563eb] transition-colors"
                set:html={t("nav.about")}
            />
            <a
                href="#features"
                class="text-sm font-medium text-gray-700 hover:text-[#2563eb] transition-colors"
                set:html={t("nav.course")}
            />
            <a
                href="#corporate"
                class="text-sm font-medium text-gray-700 hover:text-[#2563eb] transition-colors"
                set:html={t("nav.business")}
            />
            <a
                href="#coaching"
                class="text-sm font-medium text-gray-700 hover:text-[#2563eb] transition-colors"
                set:html={t("nav.coaching")}
            />
        </div>

        <!-- Language Switcher -->
        <div class="flex items-center gap-2">
            {
                langs.map((l) => (
                    <a
                        href={`/${l.code}/metodo`}
                        class:list={[
                            "text-lg transition-transform hover:scale-110",
                            lang === l.code
                                ? "scale-110 ring-2 ring-[#2563eb] rounded-full"
                                : "opacity-70",
                        ]}
                        title={l.label}
                    >
                        {l.flag}
                    </a>
                ))
            }
        </div>
    </div>
</nav>
