---
interface Props {
  t: (key: string) => string;
}
const { t } = Astro.props;

const plans = [
  {
    nameKey: 'pricing.p1.name',
    freqKey: 'pricing.p1.freq',
    priceMonthKey: 'pricing.p1.price_month',
    priceSemKey: 'pricing.p1.price_sem',
    descKey: 'pricing.p1.desc',
    labelColor: 'bg-rose-400',
  },
  {
    nameKey: 'pricing.p2.name',
    freqKey: 'pricing.p2.freq',
    priceMonthKey: 'pricing.p2.price_month',
    priceSemKey: 'pricing.p2.price_sem',
    descKey: 'pricing.p2.desc',
    labelColor: 'bg-yellow-400',
  },
  {
    nameKey: 'pricing.p3.name',
    freqKey: 'pricing.p3.freq',
    priceMonthKey: 'pricing.p3.price_month',
    priceSemKey: 'pricing.p3.price_sem',
    descKey: 'pricing.p3.desc',
    labelColor: 'bg-green-400',
  },
];
---

<section id="pricing" class="py-20 bg-gradient-to-b from-blue-50/50 to-white">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Header -->
    <div class="text-center mb-16">
      <p class="text-sm font-inter font-semibold uppercase tracking-[0.2em] text-rose-500 mb-3">
        PLANOS ALUNOS INDIVIDUAIS
      </p>
      <h2 class="font-heading text-4xl md:text-5xl font-semibold text-[#2d3559] mb-4">
        {t('pricing.title')}
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto leading-relaxed">
        {t('pricing.subtitle')}
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
      {plans.map((plan) => (
        <div class="relative bg-white/80 backdrop-blur-sm rounded-3xl p-8 shadow-sm hover:shadow-lg transition-all group border border-gray-100">
          <!-- Color Label -->
          <div class={`${plan.labelColor} text-white font-heading font-medium px-5 py-2 rounded-full text-sm inline-block mb-6`}>
            {t(plan.nameKey)}
          </div>

          <!-- Features List -->
          <ul class="space-y-3 mb-6">
            <li class="flex items-center gap-2 text-[#2d3559] text-lg">
              <span class="text-gray-400">•</span>
              <span class="font-medium">{t(plan.freqKey)}</span>
            </li>
            <li class="flex items-center gap-2 text-[#2d3559] text-lg">
              <span class="text-gray-400">•</span>
              <span class="font-medium">{t(plan.priceMonthKey)}</span>
            </li>
            <li class="flex items-center gap-2 text-[#2d3559] text-lg">
              <span class="text-gray-400">•</span>
              <span class="font-medium">{t(plan.priceSemKey)}</span>
            </li>
          </ul>

          <hr class="border-gray-200 mb-4" />

          <!-- Description -->
          <p class="text-gray-500 text-sm italic">
            {t(plan.descKey)}
          </p>
        </div>
      ))}
    </div>

    <!-- Benefits Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
      <div class="space-y-2">
        <div class="text-2xl">👥</div>
        <p class="text-[#2d3559] font-medium text-sm">{t('benefits.b1')}</p>
      </div>
      <div class="space-y-2">
        <div class="text-2xl">💻</div>
        <p class="text-[#2d3559] font-medium text-sm">{t('benefits.b2')}</p>
      </div>
      <div class="space-y-2">
        <div class="text-2xl">💰</div>
        <p class="text-[#2d3559] font-medium text-sm">{t('benefits.b3')}</p>
      </div>
    </div>
  </div>
</section>
