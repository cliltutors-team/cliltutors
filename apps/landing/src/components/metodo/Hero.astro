---
interface Props {
    t: (key: string) => string;
}
const { t } = Astro.props;
---

<section
    class="relative overflow-hidden bg-[#FAFBFF] min-h-[90vh] flex items-center"
>
    <!-- Background glowing orbs / blobs for premium EdTech/SaaS feel -->
    <div
        class="absolute pointer-events-none inset-0 flex items-center justify-center overflow-hidden z-0"
    >
        <img
            src="/images/web/bg_difuminado.webp"
            alt=""
            class="w-full h-full object-cover opacity-80"
        />
    </div>

    <div
        class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center relative z-10"
    >
        <!-- Left column -->
        <div class="space-y-8">
            <h1
                class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold text-[#2d3559] leading-[1.1]"
                set:html={t("hero.title")}
            />

            <p
                class="text-lg md:text-xl text-gray-700 max-w-md leading-relaxed"
                set:html={t("hero.subtitle")}
            />

            <div class="flex items-center gap-5">
                <!-- CTA Button -->
                <a
                    href="#pricing"
                    class="group inline-flex items-center gap-3 bg-[#4ade80] hover:bg-[#22c55e] text-white px-8 py-4 rounded-full text-lg font-medium transition-all shadow-lg shadow-green-200 hover:shadow-green-300 hover:scale-105"
                >
                    <svg
                        class="w-6 h-6 transition-transform group-hover:translate-x-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 8l4 4-4 4M8 12h8"></path>
                    </svg>
                    <span set:html={t("hero.cta.book")} />
                </a>

                <!-- 100% Live Badge -->
                <div class="relative w-20 h-20 flex-shrink-0">
                    <div
                        class="absolute inset-0 animate-[spin_12s_linear_infinite]"
                    >
                        <svg viewBox="0 0 100 100" class="w-full h-full">
                            <defs>
                                <path
                                    id="circlePath"
                                    d="M 50,50 m -37,0 a 37,37 0 1,1 74,0 a 37,37 0 1,1 -74,0"
                                ></path>
                            </defs>
                            <text
                                class="text-[11px] fill-gray-500 font-heading font-medium uppercase tracking-[0.2em]"
                            >
                                <textPath
                                    href="#circlePath"
                                    set:html={t("hero.live").replace(
                                        "<br/>",
                                        " · ",
                                    ) +
                                        " · " +
                                        t("hero.live").replace("<br/>", " · ")}
                                />
                            </text>
                        </svg>
                    </div>
                    <div
                        class="absolute inset-0 flex items-center justify-center"
                    >
                        <img
                            src="/images/canva/video_call_icon.svg"
                            alt=""
                            class="w-8 h-8"
                        />
                    </div>
                </div>
            </div>
        </div>

        <!-- Right column: Hero Image -->
        <div class="relative flex justify-center lg:justify-end">
            <img
                src="/images/web/girl-tablet.png"
                alt="Student learning online"
                class="w-full max-w-lg lg:max-w-xl object-contain drop-shadow-xl"
                loading="eager"
            />
        </div>
    </div>
</section>
