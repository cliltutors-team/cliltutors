---
interface Props {
  step: number;
  eyebrow: string;
  title: string;
  description: string;
  items?: string[];
  isLast?: boolean;
  stagger?: number;
}

const { step, eyebrow, title, description, items, isLast = false, stagger = 0 } = Astro.props;

const stepColors = [
  { bg: 'bg-brand-blue', glow: 'shadow-brand-blue' },
  { bg: 'bg-brand-indigo', glow: 'shadow-brand-indigo' },
  { bg: 'bg-brand-purple', glow: 'shadow-brand-purple' },
  { bg: 'bg-brand-gold', glow: 'shadow-brand-gold' },
  { bg: 'bg-brand-orange', glow: 'shadow-brand-orange' },
];
const color = stepColors[(step - 1) % stepColors.length];
---

<div class="method-step group reveal" style={`--stagger: ${stagger}`}>
  <div class="flex flex-col items-center shrink-0">
    <div class={`step-badge ${color.bg}`}>
      {step}
    </div>
    {!isLast && (
      <div class="step-line"></div>
    )}
  </div>
  <div class={`pb-10 ${isLast ? 'pb-0' : ''}`}>
    <span class="text-xs font-bold tracking-[0.12em] uppercase text-brand-blue">{eyebrow}</span>
    <h3 class="font-heading font-semibold text-xl text-brand-navy mt-1 group-hover:text-brand-indigo transition-colors">{title}</h3>
    <p class="text-brand-navy-700 mt-2 leading-relaxed">{description}</p>
    {items && items.length > 0 && (
      <ul class="mt-4 space-y-2">
        {items.map(item => (
          <li class="flex items-start gap-2.5 text-sm text-brand-navy-700">
            <div class="w-5 h-5 rounded-full bg-brand-blue-50 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-3 h-3 text-brand-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
            </div>
            {item}
          </li>
        ))}
      </ul>
    )}
  </div>
</div>

<style>
.method-step {
  display: flex;
  gap: 1.5rem;
}

.method-step .reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  transition-delay: calc(var(--stagger, 0) * 80ms);
}

.method-step .reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.step-badge {
  width: 48px;
  height: 48px;
  border-radius: 14px;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.125rem;
  box-shadow: 0 4px 16px rgba(82, 138, 237, 0.2);
  transition: transform 300ms cubic-bezier(0.25, 1, 0.5, 1),
    box-shadow 300ms;
  position: relative;
  z-index: 1;
}

.method-step:hover .step-badge {
  transform: scale(1.1);
  box-shadow: 0 6px 24px rgba(82, 138, 237, 0.3);
}

.step-line {
  width: 2px;
  flex: 1;
  margin-top: 0.5rem;
  background: linear-gradient(to bottom, var(--color-brand-blue-200), transparent);
  border-radius: 1px;
  transform-origin: top;
  transform: scaleY(0);
  transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.method-step.active .step-line {
  transform: scaleY(1);
}

@media (prefers-reduced-motion: reduce) {
  .step-line {
    transform: scaleY(1);
    transition: none;
  }
}
</style>


