---
import SectionHeader from './SectionHeader.astro';

interface Course {
  id: string;
  title: string;
  subtitle: string;
  category: string;
  level: "beginner" | "intermediate" | "advanced";
  duration: string;
  students: number;
  rating: number;
  price: number;
  originalPrice?: number;
  image: string;
  instructor: string;
  featured?: boolean;
  bestseller?: boolean;
}

interface Props {
  courses: Course[];
  title: string;
  subtitle: string;
  eyebrow: string;
  filterAllText: string;
  bestsellerText: string;
  featuredText: string;
  studentsText: string;
  enrollText: string;
  viewAllText: string;
  viewAllHref?: string;
}

const {
  courses,
  title,
  subtitle,
  eyebrow,
  filterAllText,
  bestsellerText,
  featuredText,
  studentsText,
  enrollText,
  viewAllText,
  viewAllHref = `${Astro.currentLocale}/courses`,
} = Astro.props;

const categories = [...new Set(courses.map((c) => c.category))];
const levels = ["beginner", "intermediate", "advanced"];
---

<section class="section-padding bg-white course-catalog-section">
  <div class="section-decor">
    <div class="decor-dots"></div>
    <div class="decor-orb"></div>
  </div>
  <div class="container-narrow">
    <SectionHeader eyebrow={eyebrow} title={title} description={subtitle} />

    <div class="mb-10 reveal" style="--stagger: 1">
      <div class="flex flex-wrap gap-3 justify-center">
        <button class="filter-btn active" data-filter="all"
          >{filterAllText}</button
        >
        {
          categories.map((cat) => (
            <button class="filter-btn" data-filter={cat}>
              {cat}
            </button>
          ))
        }
      </div>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6" id="courses-grid">
      {
        courses.map((course, index) => (
		<article
			class="course-card group reveal"
			data-category={course.category}
			data-level={course.level}
			style={`--stagger: ${2 + index}`}
		>
            <div class="course-image-wrap relative overflow-hidden rounded-xl mb-4">
              <img
                src={course.image}
                alt={course.title}
                class="w-full h-48 object-cover transition-transform duration-500 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-brand-navy/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300" />

              {course.bestseller && (
                <span class="absolute top-3 left-3 px-2.5 py-1 bg-brand-gold text-white text-xs font-bold rounded-md uppercase tracking-wide">
                  {bestsellerText}
                </span>
              )}

              {course.featured && !course.bestseller && (
                <span class="absolute top-3 left-3 px-2.5 py-1 bg-brand-purple text-white text-xs font-bold rounded-md uppercase tracking-wide">
                  {featuredText}
                </span>
              )}

              <div class="absolute bottom-3 right-3 flex items-center gap-1.5 px-2 py-1 bg-white/95 backdrop-blur-sm rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
                <svg
                  class="w-4 h-4 text-brand-gold"
                  fill="currentColor"
                  viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="text-sm font-semibold text-brand-navy">
                  {course.rating.toFixed(1)}
                </span>
              </div>
            </div>

            <div class="flex items-start justify-between gap-3 mb-2">
              <span class="text-xs font-semibold text-brand-blue uppercase tracking-wide">
                {course.category}
              </span>
              <span
                class={`text-xs font-medium px-2 py-0.5 rounded ${
                  course.level === "beginner"
                    ? "bg-brand-blue-50 text-brand-blue"
                    : course.level === "intermediate"
                      ? "bg-brand-purple-50 text-brand-purple"
                      : "bg-brand-gold-50 text-brand-gold"
                }`}
              >
                {course.level}
              </span>
            </div>

            <h3 class="font-heading font-semibold text-lg text-brand-navy mb-1 group-hover:text-brand-indigo transition-colors line-clamp-2">
              {course.title}
            </h3>
            <p class="text-sm text-slate-light mb-3 line-clamp-2">
              {course.subtitle}
            </p>

            <div class="flex items-center gap-3 text-xs text-brand-blue-500 mb-4">
              <div class="flex items-center gap-1">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                  />
                </svg>
                <span>{course.duration}</span>
              </div>
              <div class="flex items-center gap-1">
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  />
                </svg>
                <span>
                  {course.students.toLocaleString()} {studentsText}
                </span>
              </div>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-brand-blue-100">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-blue to-brand-purple flex items-center justify-center text-white text-xs font-bold">
                  {course.instructor
                    .split(" ")
                    .map((n) => n[0])
                    .join("")
                    .slice(0, 2)}
                </div>
                <span class="text-sm text-brand-navy-700">{course.instructor}</span>
              </div>

              <div class="text-right">
                {course.originalPrice && (
                  <span class="text-sm text-brand-blue-400 line-through mr-1">
                    ${course.originalPrice}
                  </span>
                )}
                <span class="text-lg font-bold text-brand-navy">
                  ${course.price}
                </span>
              </div>
            </div>

            <button class="mt-4 w-full py-2.5 px-4 bg-gradient-to-r from-brand-blue to-brand-indigo text-white font-semibold text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 hover:shadow-lg hover:shadow-brand-blue/30">
              {enrollText}
            </button>
          </article>
        ))
      }
    </div>

	<div class="mt-12 text-center reveal" style="--stagger: 20">
      <a
        href={viewAllHref}
        class="btn-secondary inline-flex items-center gap-2"
      >
        {viewAllText}
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .course-catalog-section {
  position: relative;
  overflow: hidden;
}

.section-decor {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.decor-dots {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, var(--color-brand-blue-200) 1px, transparent 1px);
  background-size: 32px 32px;
  opacity: 0.35;
}

.decor-orb {
  position: absolute;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(82, 138, 237, 0.08), transparent 70%);
  top: -100px;
  right: -150px;
  filter: blur(60px);
}

.course-catalog-section .container-narrow {
  position: relative;
  z-index: 1;
}

.course-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(14px);
  border: 1px solid rgba(82, 138, 237, 0.15);
  border-radius: 16px;
  padding: 1.25rem;
  transition: all 300ms cubic-bezier(0.25, 1, 0.5, 1);
  position: relative;
}

  .course-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 16px;
    padding: 1.5px;
    background: linear-gradient(
      135deg,
      var(--color-brand-blue-200),
      var(--color-brand-purple-100),
      var(--color-brand-gold-100)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 300ms ease;
  }

.course-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 40px rgba(52, 53, 79, 0.12);
  border-color: transparent;
}

  .course-card:hover::before {
    opacity: 1;
  }

.filter-btn {
  padding: 0.5rem 1.25rem;
  border-radius: 100px;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-brand-navy-700);
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(82, 138, 237, 0.15);
  cursor: pointer;
  transition: all 250ms cubic-bezier(0.25, 1, 0.5, 1);
  position: relative;
  overflow: hidden;
}

.filter-btn::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 100px;
  padding: 1.5px;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo), var(--color-brand-purple));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 250ms ease;
  pointer-events: none;
}

.filter-btn:hover {
  background: rgba(255, 255, 255, 0.85);
  color: var(--color-brand-blue);
  border-color: transparent;
}

.filter-btn:hover::after {
  opacity: 1;
}

  .filter-btn.active {
    background: linear-gradient(
      135deg,
      var(--color-brand-blue),
      var(--color-brand-indigo)
    );
    color: white;
    border-color: transparent;
    box-shadow: 0 4px 12px rgba(82, 138, 237, 0.25);
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

.course-card[hidden] {
  display: none;
}

.course-catalog-section .reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  transition-delay: calc(var(--stagger, 0) * 80ms);
}

.course-catalog-section .reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const courseCards = document.querySelectorAll(".course-card");

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        filterBtns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");

        const filter = btn.getAttribute("data-filter");

        courseCards.forEach((card) => {
          if (
            filter === "all" ||
            card.getAttribute("data-category") === filter
          ) {
            card.removeAttribute("hidden");
            card.style.animation = "none";
            card.offsetHeight;
            card.style.animation = null;
          } else {
            card.setAttribute("hidden", "");
          }
        });
      });
    });
  });
</script>
