---
interface Props {
  quote: string;
  name: string;
  role: string;
  stars?: number;
  avatar?: string;
}

const { quote, name, role, stars = 5, avatar } = Astro.props;

const initials = name ? name.charAt(0) : '?';
---

<div class="testimonial-card">
  <div class="testimonial-header">
    <div class="quote-mark">
      <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
      </svg>
    </div>
    <div class="star-rating" aria-label={`${stars} out of 5 stars`}>
      {Array.from({ length: 5 }).map((_, i) => (
        <svg class="star-icon" viewBox="0 0 20 20" fill={i < stars ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="1.5">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  </div>

  <p class="testimonial-quote">"{quote}"</p>

  <div class="testimonial-footer">
    {avatar ? (
      <img src={avatar} alt={name} class="testimonial-avatar" loading="lazy" />
    ) : (
      <div class="testimonial-avatar-fallback">{initials}</div>
    )}
    <div class="testimonial-author">
      <p class="testimonial-name">{name}</p>
      <p class="testimonial-role">{role}</p>
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(82, 138, 237, 0.15);
    border-radius: 20px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(82, 138, 237, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    transition: all 400ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .testimonial-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 20px;
    padding: 1.5px;
    background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo), var(--color-brand-purple));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
  }

  .testimonial-card:hover {
    background: rgba(255, 255, 255, 0.85);
    border-color: transparent;
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(82, 138, 237, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .testimonial-card:hover::before {
    opacity: 1;
  }

  .testimonial-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .quote-mark {
    color: var(--color-brand-blue);
    opacity: 0.2;
    transition: opacity 300ms;
  }

  .testimonial-card:hover .quote-mark {
    opacity: 0.4;
  }

  .star-rating {
    display: flex;
    gap: 2px;
  }

  .star-icon {
    width: 16px;
    height: 16px;
    color: var(--color-brand-gold);
  }

  .star-icon[fill="none"] {
    color: rgba(82, 138, 237, 0.2);
  }

  .testimonial-quote {
    color: var(--color-brand-navy);
    line-height: 1.7;
    flex: 1;
    font-size: 15px;
  }

  .testimonial-footer {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(82, 138, 237, 0.1);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testimonial-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(82, 138, 237, 0.15);
    flex-shrink: 0;
    transition: border-color 300ms ease;
  }

  .testimonial-card:hover .testimonial-avatar {
    border-color: rgba(82, 138, 237, 0.35);
  }

  .testimonial-avatar-fallback {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }

  .testimonial-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 14px;
    color: var(--color-brand-navy);
  }

  .testimonial-role {
    font-size: 12px;
    color: rgba(52, 53, 79, 0.85);
    margin-top: 2px;
  }
</style>
