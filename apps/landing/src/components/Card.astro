---
interface Props {
  icon?: string;
  title: string;
  description: string;
  href?: string;
  linkText?: string;
  variant?: 'blue' | 'purple' | 'gold' | 'orange';
}

const { icon, title, description, href, linkText, variant = 'blue' } = Astro.props;

const iconColors = {
  blue: 'icon-box-blue',
  purple: 'icon-box-purple',
  gold: 'icon-box-gold',
  orange: 'icon-box-orange',
};
---

<div class="card-gradient group flex flex-col h-full reveal">
  {icon && (
    <div class={`icon-box ${iconColors[variant]} mb-5`}>
      <span class="text-xl">{icon}</span>
    </div>
  )}
  <h3 class="font-heading font-semibold text-lg text-brand-navy mb-2 group-hover:text-brand-indigo transition-colors">
    {title}
  </h3>
  <p class="text-sm text-slate-light leading-relaxed flex-1">
    {description}
  </p>
  {href && linkText && (
    <a href={href} class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-blue group-hover:text-brand-indigo transition-all">
      {linkText}
      <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
    </a>
  )}
</div>
