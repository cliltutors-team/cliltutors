---
import LucideIcon from './LucideIcon';
import MotionReveal from './MotionReveal';
import MotionCard from './MotionCard';

interface TrustIndicator {
  value: string;
  label: string;
  icon?: string;
  iconType?: 'emoji' | 'lucide';
}

interface Partner {
  name: string;
  logo: string;
}

interface Props {
  trustIndicators: TrustIndicator[];
  partners?: Partner[];
  studentCount: string;
  courseCount: string;
  countryCount: string;
  ratingValue: string;
  studentLabel: string;
  courseLabel: string;
  countryLabel: string;
  ratingLabel: string;
  verifiedLabel: string;
  lifetimeLabel: string;
  expertsLabel: string;
  partnersLabel: string;
}

const {
  trustIndicators,
  partners = [],
  studentCount,
  courseCount,
  countryCount,
  ratingValue,
  studentLabel,
  courseLabel,
  countryLabel,
  ratingLabel,
  verifiedLabel,
  lifetimeLabel,
  expertsLabel,
  partnersLabel
} = Astro.props;
---

<section class="section-padding gradient-subtle border-y border-brand-blue-100 trust-signals">
  <div class="container-narrow">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
      <MotionReveal client:visible direction="up" delay={0.05} className="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-blue-50 to-brand-purple-50 mb-3">
          <svg class="w-8 h-8 text-brand-indigo" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
          </svg>
        </div>
        <div class="font-heading font-bold text-3xl text-brand-navy mb-1">{studentCount}</div>
        <div class="text-sm text-brand-navy-700">{studentLabel}</div>
      </MotionReveal>

      <MotionReveal client:visible direction="up" delay={0.12} className="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-purple-50 to-brand-gold-50 mb-3">
          <svg class="w-8 h-8 text-brand-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 6.477 9.246 7.073 8 7.75c-1.246.677-2.667 1.075-4 1.25v11c1.333-.175 2.754-.573 4-1.25 1.246-.677 2.832-1.273 4-1.75m0-13c1.168.477 2.754 1.073 4 1.25v11c-1.333-.175-2.754-.573-4-1.25m0-13V3m0 13v3m0-3c-1.246.677-2.667 1.075-4 1.25m4-1.25c1.246.677 2.832 1.073 4 1.25"/>
          </svg>
        </div>
        <div class="font-heading font-bold text-3xl text-brand-navy mb-1">{courseCount}</div>
        <div class="text-sm text-brand-navy-700">{courseLabel}</div>
      </MotionReveal>

      <MotionReveal client:visible direction="up" delay={0.19} className="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-gold-100 to-brand-orange-50 mb-3">
          <svg class="w-8 h-8 text-brand-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div class="font-heading font-bold text-3xl text-brand-navy mb-1">{countryCount}</div>
        <div class="text-sm text-brand-navy-700">{countryLabel}</div>
      </MotionReveal>

      <MotionReveal client:visible direction="up" delay={0.26} className="text-center">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-orange-50 to-brand-coral-50 mb-3">
          <svg class="w-8 h-8 text-brand-navy-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
        </div>
        <div class="font-heading font-bold text-3xl text-brand-navy mb-1">{ratingValue}</div>
        <div class="text-sm text-brand-navy-700">{ratingLabel}</div>
      </MotionReveal>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
      {trustIndicators.map((indicator) => (
        <MotionCard client:visible hoverScale={1.03} hoverY={-3} className="trust-badge flex items-center gap-3 p-4 rounded-xl bg-gradient-to-br from-brand-blue-50 to-white border border-brand-blue-100">
          {indicator.icon && (
            indicator.iconType === 'lucide' ? (
              <div class="w-10 h-10 rounded-lg bg-brand-blue-50 flex items-center justify-center flex-shrink-0">
                <LucideIcon client:idle name={indicator.icon} size={20} color="currentColor" className="text-brand-blue" />
              </div>
            ) : (
              <div class="w-10 h-10 rounded-lg bg-brand-blue-50 flex items-center justify-center text-xl flex-shrink-0">
                {indicator.icon}
              </div>
            )
          )}
          <div>
            <div class="font-heading font-bold text-xl text-brand-navy">{indicator.value}</div>
            <div class="text-xs text-brand-navy-700">{indicator.label}</div>
          </div>
        </MotionCard>
      ))}
    </div>

    {partners.length > 0 && (
      <MotionReveal client:visible direction="up" delay={0.4}>
        <p class="text-center text-sm text-brand-blue-500 mb-6 uppercase tracking-wide font-semibold">{partnersLabel}</p>
        <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 opacity-60">
          {partners.map(partner => (
            <div class="partner-logo grayscale hover:grayscale-0 transition-all duration-500">
              <img src={partner.logo} alt={partner.name} class="h-8 md:h-10 object-contain" loading="lazy" />
            </div>
          ))}
        </div>
      </MotionReveal>
    )}

    <div class="mt-12 grid sm:grid-cols-3 gap-6">
      <MotionReveal client:visible direction="up" delay={0.5}>
        <div class="flex items-center justify-center gap-2 px-4 py-2 bg-brand-blue-50 rounded-lg">
          <svg class="w-5 h-5 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <span class="text-sm font-semibold text-brand-navy">{verifiedLabel}</span>
        </div>
      </MotionReveal>
      <MotionReveal client:visible direction="up" delay={0.55}>
        <div class="flex items-center justify-center gap-2 px-4 py-2 bg-brand-purple-50 rounded-lg">
          <svg class="w-5 h-5 text-brand-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span class="text-sm font-semibold text-brand-navy">{lifetimeLabel}</span>
        </div>
      </MotionReveal>
      <MotionReveal client:visible direction="up" delay={0.6}>
        <div class="flex items-center justify-center gap-2 px-4 py-2 bg-brand-gold-50 rounded-lg">
          <svg class="w-5 h-5 text-brand-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span class="text-sm font-semibold text-brand-navy">{expertsLabel}</span>
        </div>
      </MotionReveal>
    </div>
  </div>
</section>

<style>
  .trust-badge {
    transition: all 300ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .trust-badge:hover {
    border-color: var(--color-brand-blue-200);
    box-shadow: 0 4px 16px rgba(82, 138, 237, 0.1);
  }

  .partner-logo {
    transition: all 400ms ease;
  }

  .partner-logo:hover {
    transform: scale(1.05);
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-badge:hover {
      transform: none;
    }
  }
</style>
