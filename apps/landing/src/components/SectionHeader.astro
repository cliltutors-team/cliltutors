---
import MotionReveal from './MotionReveal';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  center?: boolean;
  light?: boolean;
}

const { eyebrow, title, description, center = true, light = false } = Astro.props;
---

<div class:list={['mb-12 lg:mb-16 section-header', { 'text-center': center }]}>
  {eyebrow && (
    <MotionReveal
      client:visible
      direction="up"
      delay={0}
      duration={0.5}
      className={`eyebrow mb-4 ${light ? 'eyebrow-light' : ''}`}
    >
      <span class="eyebrow-dot" />
      {eyebrow}
    </MotionReveal>
  )}
  <MotionReveal
    client:visible
    direction="up"
    delay={0.08}
    duration={0.6}
  >
    <h2
      class:list={[
        'font-heading font-bold text-3xl sm:text-4xl lg:text-[2.75rem] leading-[1.1] tracking-[-0.025em] text-balance',
        { 'max-w-3xl mx-auto': center },
        { 'text-white': light, 'text-brand-navy': !light },
      ]}
    >
      {title}
    </h2>
  </MotionReveal>
  {description && (
    <MotionReveal
      client:visible
      direction="up"
      delay={0.16}
      duration={0.6}
    >
      <p
        class:list={[
          'mt-5 text-lg leading-relaxed',
          { 'max-w-2xl mx-auto': center, 'max-w-3xl': !center },
          { 'text-white/70': light, 'text-slate-light': !light },
        ]}
      >
        {description}
      </p>
    </MotionReveal>
  )}
</div>

<style>
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-blue);
    display: inline-block;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .eyebrow-light {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .eyebrow-light .eyebrow-dot {
    background: rgba(255, 255, 255, 0.8);
  }
</style>
