---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  center?: boolean;
  light?: boolean;
}

const { eyebrow, title, description, center = true, light = false } = Astro.props;
---

<div class={`mb-12 lg:mb-16 ${center ? 'text-center' : ''} reveal`}>
  {eyebrow && (
    <span class={`eyebrow mb-4 ${light ? 'eyebrow-light' : ''}`}>
      <span class="eyebrow-dot"></span>
      {eyebrow}
    </span>
  )}
  <h2 class={`font-heading font-bold text-3xl sm:text-4xl lg:text-[2.75rem] leading-[1.1] tracking-[-0.025em] text-balance ${center ? 'max-w-3xl mx-auto' : ''} ${light ? 'text-white' : 'text-brand-navy'}`}>
    {title}
  </h2>
  {description && (
    <p class={`mt-5 text-lg leading-relaxed ${center ? 'max-w-2xl mx-auto' : 'max-w-3xl'} ${light ? 'text-white/70' : 'text-slate-light'}`}>
      {description}
    </p>
  )}
</div>

<style>
  .eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand-blue);
    display: inline-block;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .eyebrow-light {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .eyebrow-light .eyebrow-dot {
    background: rgba(255, 255, 255, 0.8);
  }
</style>
