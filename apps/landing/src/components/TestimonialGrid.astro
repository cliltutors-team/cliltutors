---
/**
 * TestimonialGrid Component
 * Premium testimonial display grid
 * Features: Featured testimonial, avatar + quote + metrics, full i18n
 */

interface Testimonial {
  quote: string;
  name: string;
  role: string;
  company?: string;
  avatarUrl?: string;
  rating?: number;
  metrics?: Array<{
    label: string;
    value: string;
  }>;
  featured?: boolean;
}

interface Props {
  testimonials: Testimonial[];
  layout?: 'grid' | 'carousel';
  columns?: 2 | 3 | 4;
  showMetrics?: boolean;
  showRating?: boolean;
  analytics?: {
    sectionId?: string;
    clickAction?: string;
  };
}

const {
  testimonials,
  layout = 'grid',
  columns = 3,
  showMetrics = true,
  showRating = false,
  analytics
} = Astro.props;

const featuredTestimonial = testimonials.find(t => t.featured);
const regularTestimonials = testimonials.filter(t => !t.featured);

const columnClasses = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4'
};
---

<div 
  class:list={['testimonial-grid-wrapper']}
  {...analytics?.sectionId && { 'data-section': analytics.sectionId }}
>
  {/* Featured Testimonial */}
  {featuredTestimonial && (
    <div class="featured-testimonial reveal" style="--stagger: 0">
      <div class="featured-card">
        <div class="quote-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
          </svg>
        </div>

        <div class="featured-content">
          <p class="featured-quote">"{featuredTestimonial.quote}"</p>
          
          {showRating && featuredTestimonial.rating && (
            <div class="rating">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg 
                  class:list={['star', i < featuredTestimonial.rating! && 'star-filled']} 
                  viewBox="0 0 20 20" 
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          )}

          <div class="author-info">
            {featuredTestimonial.avatarUrl ? (
              <img 
                src={featuredTestimonial.avatarUrl} 
                alt={featuredTestimonial.name}
                class="avatar"
              />
            ) : (
              <div class="avatar avatar-placeholder">
                {featuredTestimonial.name.charAt(0)}
              </div>
            )}
            
            <div class="author-details">
              <p class="author-name">{featuredTestimonial.name}</p>
              <p class="author-role">
                {featuredTestimonial.role}
                {featuredTestimonial.company && `, ${featuredTestimonial.company}`}
              </p>
            </div>
          </div>

          {showMetrics && featuredTestimonial.metrics && featuredTestimonial.metrics.length > 0 && (
            <div class="testimonial-metrics">
              {featuredTestimonial.metrics.map((metric) => (
                <div class="metric">
                  <span class="metric-value">{metric.value}</span>
                  <span class="metric-label">{metric.label}</span>
                </div>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  {/* Regular Testimonials Grid */}
  <div class:list={['testimonials-grid', columnClasses[columns]]}>
    {regularTestimonials.map((testimonial, index) => (
      <div 
          class="testimonial-card reveal"
          style={`--stagger: ${index + 1}`}
      >
        <div class="card-header">
          <div class="quote-mark">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
            </svg>
          </div>
          
          {showRating && testimonial.rating && (
            <div class="rating rating-sm">
              {Array.from({ length: 5 }).map((_, i) => (
                <svg 
                  class:list={['star', i < testimonial.rating! && 'star-filled']} 
                  viewBox="0 0 20 20" 
                  fill="currentColor"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          )}
        </div>

        <p class="card-quote">"{testimonial.quote}"</p>

        <div class="card-footer">
          {testimonial.avatarUrl ? (
            <img 
              src={testimonial.avatarUrl} 
              alt={testimonial.name}
              class="avatar avatar-sm"
            />
          ) : (
            <div class="avatar avatar-sm avatar-placeholder">
              {testimonial.name.charAt(0)}
            </div>
          )}
          
          <div class="author-info-sm">
            <p class="author-name">{testimonial.name}</p>
            <p class="author-role-sm">{testimonial.role}</p>
          </div>
        </div>

        {showMetrics && testimonial.metrics && testimonial.metrics.length > 0 && (
          <div class="card-metrics">
            {testimonial.metrics.map((metric) => (
              <div class="metric-sm">
                <span class="metric-value-sm">{metric.value}</span>
                <span class="metric-label-sm">{metric.label}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>
</div>

<style>
.testimonial-grid-wrapper {
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

/* Featured Testimonial */
.featured-testimonial {
  width: 100%;
}

.featured-card {
  position: relative;
  background: linear-gradient(135deg, var(--color-brand-blue-50) 0%, var(--color-brand-purple-50) 100%);
  border: 2px solid var(--color-brand-blue-200);
  border-radius: 1.5rem;
  padding: 2.5rem;
  overflow: hidden;
}

.featured-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at top right, rgba(82, 138, 237, 0.08), transparent);
  pointer-events: none;
}

.quote-icon {
  position: absolute;
  top: 1.5rem;
  right: 1.5rem;
  width: 4rem;
  height: 4rem;
  color: var(--color-brand-blue);
  opacity: 0.15;
}

.featured-content {
  position: relative;
  z-index: 1;
}

.featured-quote {
  font-size: 1.25rem;
  line-height: 1.7;
  color: var(--color-brand-navy);
  font-style: italic;
  margin: 0 0 1.5rem 0;
}

@media (min-width: 768px) {
  .featured-quote {
    font-size: 1.5rem;
  }
}

/* Rating */
.rating {
  display: flex;
  gap: 0.25rem;
  margin-bottom: 1.5rem;
}

.star {
  width: 1.25rem;
  height: 1.25rem;
  color: var(--color-brand-blue-200);
}

.star-filled {
  color: var(--color-brand-gold);
}

.rating-sm .star {
  width: 1rem;
  height: 1rem;
}

/* Author Info */
.author-info {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 1.5rem;
}

.avatar {
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo));
  color: white;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1.25rem;
}

.author-details {
  flex: 1;
}

.author-name {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-brand-navy);
  margin: 0;
}

.author-role {
  font-size: 0.875rem;
  color: var(--color-slate-light);
  margin: 0.25rem 0 0 0;
}

/* Metrics */
.testimonial-metrics {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: 1rem;
  padding-top: 1.5rem;
  border-top: 1px solid rgba(82, 138, 237, 0.2);
}

.metric {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.metric-value {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-brand-navy);
}

.metric-label {
  font-size: 0.75rem;
  color: var(--color-slate-light);
}

/* Grid */
.testimonials-grid {
  display: grid;
  gap: 1.5rem;
}

.testimonial-grid-wrapper .reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.7s var(--ease-out-expo), transform 0.7s var(--ease-out-expo);
  transition-delay: calc(var(--stagger, 0) * 80ms);
}
.testimonial-grid-wrapper .reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Regular Cards */
.testimonial-card {
  background: white;
  border: 1px solid var(--color-brand-blue-200);
  border-radius: 1.25rem;
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  transition: all 300ms var(--ease-out-expo);
}

.testimonial-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 30px rgba(82, 138, 237, 0.1);
  border-color: var(--color-brand-blue-200);
}

.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.quote-mark {
  width: 1.5rem;
  height: 1.5rem;
  color: var(--color-brand-blue);
  opacity: 0.3;
}

.card-quote {
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--color-brand-navy-700);
  font-style: italic;
  margin: 0;
  flex: 1;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 1px solid var(--color-brand-blue-100);
}

.avatar-sm {
  width: 2.5rem;
  height: 2.5rem;
}

.author-info-sm {
  flex: 1;
}

.author-name {
  font-size: 0.9375rem;
  font-weight: 600;
  margin: 0;
}

.author-role-sm {
  font-size: 0.75rem;
  color: var(--color-brand-blue-500);
  margin: 0.125rem 0 0 0;
}

.card-metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
  padding-top: 1rem;
  border-top: 1px solid var(--color-brand-blue-100);
}

.metric-sm {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}

.metric-value-sm {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--color-brand-navy);
}

.metric-label-sm {
  font-size: 0.6875rem;
  color: var(--color-brand-blue-500);
}

@media (prefers-reduced-motion: reduce) {
  .testimonial-card:hover {
    transform: none;
  }
}

/* Responsive */
@media (max-width: 768px) {
  .featured-card {
    padding: 1.5rem;
  }
  
  .testimonial-metrics {
    grid-template-columns: 1fr;
  }
}
</style>


