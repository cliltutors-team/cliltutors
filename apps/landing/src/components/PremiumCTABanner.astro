---
import LucideIcon from './LucideIcon';
import MotionReveal from './MotionReveal';

/**
* PremiumCTABanner Component
* Conversion-optimized CTA section with multiple variants
* Features: Dark/light/gradient themes, trust badges, countdown timer, full i18n
*/

interface Props {
  title: string;
  description?: string;
  primaryCTA?: {
    text: string;
    href: string;
  };
  secondaryCTA?: {
    text: string;
    href: string;
  };
  variant?: 'dark' | 'light' | 'gradient' | 'gradient-purple' | 'gradient-gold';
  trustBadges?: Array<{
    icon?: string;
    iconType?: 'emoji' | 'lucide';
    label: string;
    value?: string;
  }>;
  countdown?: {
    targetDate: string;
    labels: {
      days: string;
      hours: string;
      minutes: string;
      seconds: string;
    };
  };
  analytics?: {
    sectionId?: string;
    primaryAction?: string;
    secondaryAction?: string;
  };
}

const {
  title,
  description,
  primaryCTA,
  secondaryCTA,
  variant = 'gradient',
  trustBadges = [],
  countdown,
  analytics
} = Astro.props;
---

<section 
  class:list={['premium-cta-banner', `variant-${variant}`]}
  {...analytics?.sectionId && { 'data-section': analytics.sectionId }}
>
  {/* Background Effects */}
  <div class="banner-bg">
    <div class="gradient-orb orb-1"></div>
    <div class="gradient-orb orb-2"></div>
    <div class="pattern-overlay"></div>
  </div>

  <div class="banner-content">
    {countdown && (
      <MotionReveal client:visible direction="up" delay={0.05}>
        <div class="countdown-timer" id="countdown-timer" data-target-date={countdown.targetDate}>
          <div class="countdown-item">
            <span class="countdown-value" data-unit="days">00</span>
            <span class="countdown-label">{countdown.labels.days}</span>
          </div>
          <div class="countdown-separator">:</div>
          <div class="countdown-item">
            <span class="countdown-value" data-unit="hours">00</span>
            <span class="countdown-label">{countdown.labels.hours}</span>
          </div>
          <div class="countdown-separator">:</div>
          <div class="countdown-item">
            <span class="countdown-value" data-unit="minutes">00</span>
            <span class="countdown-label">{countdown.labels.minutes}</span>
          </div>
          <div class="countdown-separator">:</div>
          <div class="countdown-item">
            <span class="countdown-value" data-unit="seconds">00</span>
            <span class="countdown-label">{countdown.labels.seconds}</span>
          </div>
        </div>
      </MotionReveal>
    )}

    <MotionReveal client:visible direction="up" delay={0.1}>
      <h2 class="banner-title">{title}</h2>
    </MotionReveal>

    {description && (
      <MotionReveal client:visible direction="up" delay={0.15}>
        <p class="banner-description">{description}</p>
      </MotionReveal>
    )}

    {(primaryCTA || secondaryCTA) && (
      <MotionReveal client:visible direction="up" delay={0.2}>
        <div class="cta-buttons">
          {primaryCTA && (
            <a
              href={primaryCTA.href}
              class="btn-primary"
              {...analytics?.primaryAction && { 'data-action': analytics.primaryAction }}
            >
              <span>{primaryCTA.text}</span>
              <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          )}
          {secondaryCTA && (
            <a
              href={secondaryCTA.href}
              class="btn-secondary"
              {...analytics?.secondaryAction && { 'data-action': analytics.secondaryAction }}
            >
              {secondaryCTA.text}
            </a>
          )}
        </div>
      </MotionReveal>
    )}

    {trustBadges.length > 0 && (
      <MotionReveal client:visible direction="up" delay={0.3}>
        <div class="trust-badges">
          {trustBadges.map((badge) => (
            <div class="trust-badge">
              {badge.icon && (
                badge.iconType === 'lucide' ? (
                  <div class="badge-icon-lucide">
                    <LucideIcon client:idle name={badge.icon} size={20} color="currentColor" className={variant === 'light' ? 'text-brand-blue' : 'text-white/90'} />
                  </div>
                ) : (
                  <span class="badge-icon">{badge.icon}</span>
                )
              )}
              <div class="badge-content">
                {badge.value && <span class="badge-value">{badge.value}</span>}
                <span class="badge-label">{badge.label}</span>
              </div>
            </div>
          ))}
        </div>
      </MotionReveal>
    )}
  </div>
</section>

<style>
.premium-cta-banner {
  position: relative;
  overflow: hidden;
  border-radius: 1.5rem;
}

/* Variants */
.variant-dark {
  background: linear-gradient(135deg, var(--color-brand-navy) 0%, var(--color-brand-indigo) 100%);
  color: white;
}

.variant-light {
  background: linear-gradient(135deg, white 0%, var(--color-brand-blue-50) 100%);
  color: var(--color-brand-navy);
}

.variant-gradient {
  background: linear-gradient(135deg, var(--color-brand-blue) 0%, var(--color-brand-indigo) 100%);
  color: white;
}

.variant-gradient-purple {
  background: linear-gradient(135deg, var(--color-brand-purple) 0%, var(--color-brand-indigo) 100%);
  color: white;
}

.variant-gradient-gold {
  background: linear-gradient(135deg, var(--color-brand-gold) 0%, var(--color-brand-orange) 100%);
  color: white;
}

/* Background Effects */
.banner-bg {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.gradient-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  animation: float 8s ease-in-out infinite;
}

.orb-1 {
  top: -20%;
  right: -10%;
  width: 400px;
  height: 400px;
  background: rgba(255, 255, 255, 0.5);
}

.orb-2 {
  bottom: -20%;
  left: -10%;
  width: 350px;
  height: 350px;
  background: rgba(255, 255, 255, 0.3);
  animation-delay: 2s;
}

.pattern-overlay {
  position: absolute;
  inset: 0;
  opacity: 0.04;
  background-image: radial-gradient(circle, white 1px, transparent 1px);
  background-size: 32px 32px;
}

  /* Content */
.banner-content {
  position: relative;
  z-index: 1;
  max-width: 4xl;
  margin: 0 auto;
  padding: 3rem 1.5rem;
  text-align: center;
}

@media (min-width: 768px) {
  .banner-content {
    padding: 4rem 2rem;
  }
}

@media (min-width: 1024px) {
  .banner-content {
    padding: 5rem 2rem;
  }
}

/* Countdown Timer */
.countdown-timer {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(12px);
  border-radius: 100px;
  margin-bottom: 2rem;
}

.countdown-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}

.countdown-value {
  font-family: var(--font-heading);
  font-size: 1.5rem;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
}

.countdown-label {
  font-size: 0.6875rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  opacity: 0.75;
}

.countdown-separator {
  font-size: 1.5rem;
  font-weight: 700;
  opacity: 0.5;
}

/* Title */
.banner-title {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 1rem 0;
}

@media (min-width: 768px) {
  .banner-title {
    font-size: 2.5rem;
  }
}

@media (min-width: 1024px) {
  .banner-title {
    font-size: 3rem;
  }
}

.variant-light .banner-title {
  color: var(--color-brand-navy);
}

/* Description */
.banner-description {
  font-size: 1.125rem;
  line-height: 1.6;
  opacity: 0.9;
  max-width: 2xl;
  margin: 0 auto 2rem;
}

.variant-light .banner-description {
  color: var(--color-slate-light);
}

/* CTA Buttons */
.cta-buttons {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  align-items: center;
  justify-content: center;
}

@media (min-width: 640px) {
  .cta-buttons {
    flex-direction: row;
    gap: 1.25rem;
  }
}

.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  padding: 1rem 2rem;
  background: white;
  color: var(--color-brand-navy);
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  border-radius: 100px;
  box-shadow: 0 4px 14px rgba(0, 0, 0, 0.15);
  transition: all 300ms var(--ease-out-expo);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
  gap: 0.75rem;
}

.btn-icon {
  width: 1.25rem;
  height: 1.25rem;
  transition: transform 250ms var(--ease-out-expo);
}

.btn-primary:hover .btn-icon {
  transform: translateX(4px);
}

.variant-light .btn-primary {
  background: var(--color-brand-blue);
  color: white;
}

.btn-secondary {
  display: inline-flex;
  align-items: center;
  padding: 1rem 2rem;
  background: transparent;
  color: currentColor;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  text-decoration: none;
  border: 2px solid currentColor;
  border-radius: 100px;
  transition: all 300ms var(--ease-out-expo);
}

.btn-secondary:hover {
  background: rgba(255, 255, 255, 0.1);
  transform: translateY(-2px);
}

.variant-light .btn-secondary {
  border-color: var(--color-brand-blue);
  color: var(--color-brand-blue);
}

.variant-light .btn-secondary:hover {
  background: var(--color-brand-blue-50);
}

/* Trust Badges */
.trust-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.5rem;
  margin-top: 2.5rem;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.2);
}

.variant-light .trust-badges {
  border-top-color: var(--color-brand-blue-200);
}

.trust-badge {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

  .badge-icon {
    font-size: 1.5rem;
  }

  .badge-icon-lucide {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
  }

  .variant-light .badge-icon-lucide {
    color: var(--color-brand-blue);
  }

.badge-content {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
  text-align: left;
}

.badge-value {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: 700;
}

.badge-label {
  font-size: 0.75rem;
  opacity: 0.75;
}
</style>

{countdown && (
<script>
  const timer = document.getElementById('countdown-timer');
  if (timer) {
    const targetDateStr = timer.getAttribute('data-target-date');
    if (targetDateStr) {
      const targetDate = new Date(targetDateStr);
      function updateCountdown() {
        const now = new Date();
        const diff = targetDate - now;
        if (diff <= 0) {
          timer.classList.add('countdown-complete');
          return;
        }
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);
        const daysEl = timer.querySelector('[data-unit="days"]');
        const hoursEl = timer.querySelector('[data-unit="hours"]');
        const minutesEl = timer.querySelector('[data-unit="minutes"]');
        const secondsEl = timer.querySelector('[data-unit="seconds"]');
        if (daysEl) daysEl.textContent = String(days).padStart(2, '0');
        if (hoursEl) hoursEl.textContent = String(hours).padStart(2, '0');
        if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
        if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');
      }
      updateCountdown();
      setInterval(updateCountdown, 1000);
    }
  }
</script>
)}
