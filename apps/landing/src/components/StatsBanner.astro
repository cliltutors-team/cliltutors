---
/**
 * StatsBanner — Premium bento-grid statistics showcase
 * Dark theme with animated gradient accents, glassmorphism cards,
 * asymmetric layout, and decorative line art
 */

import StatsCounter from './StatsCounter';
import MotionReveal from './MotionReveal';
import StaggerContainer, { StaggerItem } from './StaggerContainer';

interface Stat {
  value: string;
  label: string;
  sublabel?: string;
  trend?: 'up' | 'down' | 'neutral';
  trendValue?: string;
  icon?: string;
}

interface Props {
  stats: Stat[];
  layout?: 'bento' | 'grid' | 'carousel' | 'inline';
  theme?: 'dark' | 'light' | 'gradient';
  title?: string;
  subtitle?: string;
  eyebrow?: string;
}

const {
  stats,
  layout = 'bento',
  theme = 'dark',
  title,
  subtitle,
  eyebrow,
} = Astro.props;

const [featured, ...rest] = stats;
---

<section class:list={['stats-banner section-padding', `theme-${theme}`, `layout-${layout}`]}>
  {/* Mesh background */}
  <div class="sb-mesh" aria-hidden="true">
    <div class="sb-orb sb-orb-1"></div>
    <div class="sb-orb sb-orb-2"></div>
    <div class="sb-orb sb-orb-3"></div>
    <div class="sb-grid-lines"></div>
  </div>

  <div class="sb-container">

    {/* Optional header */}
    {(eyebrow || title || subtitle) && (
      <MotionReveal client:visible direction="up" delay={0} duration={0.6} className="sb-header">
        {eyebrow && <span class="sb-eyebrow">{eyebrow}</span>}
        {title && <h2 class="sb-title">{title}</h2>}
        {subtitle && <p class="sb-subtitle">{subtitle}</p>}
      </MotionReveal>
    )}

    {/* Bento layout */}
    {layout === 'bento' && featured && (
      <div class="bento-grid">

        {/* Featured stat — large left card */}
        <MotionReveal client:visible direction="up" delay={0.1} duration={0.7} className="bento-featured">
          <div class="sb-card sb-card-featured">
            <div class="sb-card-glow"></div>
            <div class="sb-card-inner">
              <div class="sb-featured-badge">
                <svg class="sb-badge-icon" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                Resultado destacado
              </div>
              <div class="sb-featured-value">
                <StatsCounter client:visible value={featured.value} className="sb-counter-xl" />
              </div>
              <p class="sb-featured-label">{featured.label}</p>
              {featured.sublabel && <p class="sb-featured-sublabel">{featured.sublabel}</p>}
              {featured.trend && (
                <div class:list={['sb-trend', `trend-${featured.trend}`]}>
                  {featured.trend === 'up' && (
                    <svg class="sb-trend-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 15l7-7 7 7" />
                    </svg>
                  )}
                  {featured.trendValue && <span>{featured.trendValue}</span>}
                </div>
              )}
              {/* Decorative ring */}
              <div class="sb-deco-ring"></div>
            </div>
          </div>
        </MotionReveal>

        {/* Secondary stats — right column */}
        <StaggerContainer client:visible staggerDelay={0.1} className="bento-secondary">
          {rest.map((stat, i) => (
            <StaggerItem client:visible className="bento-secondary-item">
              <div class="sb-card sb-card-secondary">
                <div class="sb-card-inner-secondary">
                  <div class="sb-secondary-content">
                    <div class="sb-secondary-value">
                      <StatsCounter client:visible value={stat.value} className="sb-counter-md" />
                    </div>
                    <div class="sb-secondary-text">
                      <p class="sb-secondary-label">{stat.label}</p>
                      {stat.sublabel && <p class="sb-secondary-sublabel">{stat.sublabel}</p>}
                    </div>
                  </div>
                  {i < rest.length - 1 && <div class="sb-divider"></div>}
                </div>
              </div>
            </StaggerItem>
          ))}
        </StaggerContainer>

      </div>
    )}

    {/* Fallback: all equal stats grid */}
    {layout !== 'bento' && (
      <StaggerContainer client:visible staggerDelay={0.08} className="sb-grid">
        {stats.map((stat) => (
          <StaggerItem client:visible className="sb-grid-item">
            <div class="sb-card sb-card-grid">
              <div class="sb-card-inner">
                <StatsCounter client:visible value={stat.value} className="sb-counter-lg" />
                <p class="sb-grid-label">{stat.label}</p>
              </div>
            </div>
          </StaggerItem>
        ))}
      </StaggerContainer>
    )}

  </div>
</section>

<style>
  /* ── Base ── */
  .stats-banner {
    position: relative;
    overflow: hidden;
  }

  .theme-dark {
    background: var(--color-brand-navy-900, #0b1628);
    color: white;
  }

  .theme-gradient {
    background: linear-gradient(135deg, #0b1628 0%, #1a1040 50%, #0d1a35 100%);
    color: white;
  }

  .theme-light {
    background: #f8faff;
    color: var(--color-brand-navy);
  }

  /* ── Theme-light text overrides ── */
  .theme-light :global(.sb-counter-xl),
  .theme-light :global(.sb-counter-md),
  .theme-light :global(.sb-counter-lg) {
    background: linear-gradient(135deg, var(--color-brand-navy), var(--color-brand-navy-700));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .theme-light .sb-featured-label,
  .theme-light .sb-featured-sublabel,
  .theme-light .sb-secondary-label,
  .theme-light .sb-secondary-sublabel,
  .theme-light .sb-grid-label {
    color: var(--color-brand-navy);
  }
  .theme-light .sb-featured-card,
  .theme-light .sb-card-secondary {
    background: rgba(52, 53, 79, 0.04);
    border-color: rgba(52, 53, 79, 0.1);
  }
  .theme-light .sb-featured-sublabel,
  .theme-light .sb-secondary-sublabel {
    color: var(--color-slate-light);
  }

  /* ── Mesh background ── */
  .sb-mesh {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .sb-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.18;
  }

  .sb-orb-1 {
    width: 600px;
    height: 600px;
    top: -200px;
    right: -100px;
    background: radial-gradient(circle, var(--color-brand-blue, #2563eb), transparent 70%);
    animation: sb-drift-1 20s ease-in-out infinite alternate;
  }

  .sb-orb-2 {
    width: 400px;
    height: 400px;
    bottom: -150px;
    left: -50px;
    background: radial-gradient(circle, var(--color-brand-purple, #7c3aed), transparent 70%);
    animation: sb-drift-2 16s ease-in-out infinite alternate;
  }

  .sb-orb-3 {
    width: 300px;
    height: 300px;
    top: 40%;
    left: 40%;
    background: radial-gradient(circle, var(--color-brand-indigo, #4f46e5), transparent 70%);
    opacity: 0.1;
  }

  @keyframes sb-drift-1 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(-60px, 40px) scale(1.15); }
  }
  @keyframes sb-drift-2 {
    from { transform: translate(0, 0) scale(1); }
    to   { transform: translate(40px, -30px) scale(1.1); }
  }

  .sb-grid-lines {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* ── Container ── */
  .sb-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .sb-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .sb-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-brand-blue, #2563eb);
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.2);
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .sb-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin: 0 0 1rem;
    color: white;
  }

  .sb-subtitle {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.65);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── Bento grid ── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    align-items: stretch;
  }

  /* ── Cards ── */
  .sb-card {
    border-radius: 1.5rem;
    transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 350ms cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  /* Featured card */
  .sb-card-featured {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    height: 100%;
  }

  .sb-card-featured::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(37,99,235,0.12) 0%, rgba(124,58,237,0.08) 100%);
    border-radius: 1.5rem;
    pointer-events: none;
  }

  .sb-card-featured::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1.5rem;
    padding: 1.5px;
    background: linear-gradient(135deg, rgba(37,99,235,0.5), rgba(124,58,237,0.4), rgba(255,255,255,0.05));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    opacity: 0.6;
  }

  .sb-card-featured:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 64px rgba(0,0,0,0.3), 0 0 0 1px rgba(37,99,235,0.2);
  }

  .sb-card-glow {
    position: absolute;
    width: 240px;
    height: 240px;
    top: -80px;
    right: -60px;
    background: radial-gradient(circle, rgba(37,99,235,0.25), transparent 70%);
    pointer-events: none;
    border-radius: 50%;
  }

  .sb-card-inner {
    padding: 2.5rem;
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 280px;
  }

  /* Featured badge */
  .sb-featured-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-brand-gold, #f59e0b);
    background: rgba(245,158,11,0.1);
    border: 1px solid rgba(245,158,11,0.2);
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .sb-badge-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  /* Featured value */
  .sb-featured-value {
    flex: 1;
    display: flex;
    align-items: center;
  }

  :global(.sb-counter-xl) {
    font-family: var(--font-heading);
    font-size: clamp(4rem, 8vw, 6rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    background: linear-gradient(135deg, #ffffff 30%, rgba(255,255,255,0.75) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .sb-featured-label {
    font-size: 1.0625rem;
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    margin: 0.75rem 0 0.25rem;
    line-height: 1.4;
  }

  .sb-featured-sublabel {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.65);
    margin: 0;
    line-height: 1.5;
  }

  /* Decorative ring */
  .sb-deco-ring {
    position: absolute;
    bottom: -60px;
    right: -60px;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    border: 40px solid rgba(255,255,255,0.025);
    pointer-events: none;
  }

  /* Trend badge */
  .sb-trend {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.3rem 0.625rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    margin-top: 0.75rem;
    width: fit-content;
  }

  .trend-up   { background: rgba(16,185,129,0.15); color: #34d399; }
  .trend-down { background: rgba(239,68,68,0.15); color: #f87171; }

  .sb-trend-icon { width: 12px; height: 12px; }

  /* ── Secondary column ── */
  .bento-secondary {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .bento-secondary-item {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .sb-card-secondary {
    flex: 1;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 1.25rem;
    margin-bottom: 1rem;
    transition: all 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .sb-card-secondary:last-child {
    margin-bottom: 0;
  }

  .sb-card-secondary::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 1.25rem;
    padding: 1px;
    background: linear-gradient(135deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .sb-card-secondary:hover {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    transform: translateX(4px);
  }

  .sb-card-inner-secondary {
    padding: 1.5rem 1.75rem;
  }

  .sb-secondary-content {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  :global(.sb-counter-md) {
    font-family: var(--font-heading);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #ffffff, rgba(255,255,255,0.8));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    flex-shrink: 0;
    min-width: 80px;
  }

  .sb-secondary-text {
    flex: 1;
    border-left: 1px solid rgba(255,255,255,0.08);
    padding-left: 1.25rem;
  }

  .sb-secondary-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    margin: 0 0 0.2rem;
    line-height: 1.3;
  }

  .sb-secondary-sublabel {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.65);
    margin: 0;
  }

  .sb-divider {
    height: 1px;
    background: linear-gradient(90deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
    margin-top: 1rem;
    display: none; /* divider handled by gap */
  }

  /* ── Fallback grid ── */
  .sb-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }

  .sb-card-grid {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }

  :global(.sb-counter-lg) {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, #ffffff, rgba(255,255,255,0.8));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .sb-grid-label {
    font-size: 0.9375rem;
    font-weight: 500;
    color: rgba(255,255,255,0.65);
    margin: 0.625rem 0 0;
    line-height: 1.4;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .sb-card-inner {
      min-height: auto;
    }

    :global(.sb-counter-xl) {
      font-size: clamp(3rem, 10vw, 4.5rem);
    }
  }

  @media (max-width: 640px) {
    .stats-banner {
      padding-block: 4rem;
    }

    .sb-card-inner {
      padding: 1.75rem;
    }

    .sb-card-inner-secondary {
      padding: 1.25rem 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sb-orb-1, .sb-orb-2 { animation: none; }
  }
</style>
