---
/**
* StatsBanner Component
* Premium statistics showcase for enterprise platform
* Full i18n support
* Animated counter via StatsCounter React island
*/

import StatsCounter from './StatsCounter';
import MotionReveal from './MotionReveal';
import StaggerContainer, { StaggerItem } from './StaggerContainer';

interface Stat {
  value: string;
  label: string;
  trend?: 'up' | 'down' | 'neutral';
  trendValue?: string;
}

interface Props {
  stats: Stat[];
  layout?: 'grid' | 'carousel' | 'inline';
  theme?: 'dark' | 'light' | 'gradient';
  title?: string;
  subtitle?: string;
}

const {
  stats,
  layout = 'grid',
  theme = 'dark',
  title,
  subtitle
} = Astro.props;

const isDark = theme === 'dark' || theme === 'gradient';
---

<section class:list={['stats-banner', `theme-${theme}`, `layout-${layout}`]}>
  {/* Background Elements */}
  {theme === 'gradient' && (
    <Fragment>
      <div class="gradient-orb orb-1"></div>
      <div class="gradient-orb orb-2"></div>
    </Fragment>
  )}

  <div class="stats-container">
    {/* Header */}
    {(title || subtitle) && (
      <div class="stats-header">
        {title && <h2 class="stats-title">{title}</h2>}
        {subtitle && <p class="stats-subtitle">{subtitle}</p>}
      </div>
    )}

    {/* Stats Grid */}
    <div class="stats-grid">
      {stats.map((stat, index) => (
        <div class="stat-card animate-fade-up" style={`animation-delay: ${index * 100}ms`}>
          <div class="stat-value-wrapper">
            <StatsCounter client:visible value={stat.value} />
            {stat.trend && (
              <span class:list={['stat-trend', `trend-${stat.trend}`]}>
                {stat.trend === 'up' && (
                  <svg class="trend-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                  </svg>
                )}
                {stat.trend === 'down' && (
                  <svg class="trend-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                )}
                {stat.trendValue && <span class="trend-value">{stat.trendValue}</span>}
              </span>
            )}
          </div>
          <p class="stat-label">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats-banner {
    position: relative;
    padding: 5rem 0;
    overflow: hidden;
  }

  .theme-dark {
    background: linear-gradient(145deg, var(--color-brand-navy-900), var(--color-brand-navy));
    color: white;
  }

  .theme-gradient {
    background: linear-gradient(135deg, var(--color-brand-blue-dark), var(--color-brand-indigo), var(--color-brand-purple));
    color: white;
  }

  .theme-light {
    background: var(--color-off-white);
    color: var(--color-brand-navy);
  }

  .gradient-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.2;
    pointer-events: none;
  }

  .orb-1 {
    width: 500px;
    height: 500px;
    top: -200px;
    right: -100px;
    background: white;
  }

  .orb-2 {
    width: 400px;
    height: 400px;
    bottom: -150px;
    left: -100px;
    background: white;
  }

  .stats-container {
    position: relative;
    z-index: 2;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .stats-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .stats-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  .stats-subtitle {
    font-size: 1.125rem;
    opacity: 0.8;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }

  .layout-inline .stats-grid {
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 3rem;
  }

  .stat-card {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: 1.25rem;
    transition: all 300ms var(--ease-out-expo);
  }

  .theme-dark .stat-card,
  .theme-gradient .stat-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
  }

  .theme-dark .stat-card:hover,
  .theme-gradient .stat-card:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-4px);
  }

  .theme-light .stat-card {
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.06);
    box-shadow: var(--shadow-sm);
  }

  .theme-light .stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .stat-value-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(135deg, currentColor, currentColor);
    -webkit-background-clip: text;
    background-clip: text;
  }

  .theme-gradient .stat-value {
    background: linear-gradient(135deg, white, rgba(255, 255, 255, 0.8));
    -webkit-background-clip: text;
    background-clip: text;
  }

  .stat-trend {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.25rem 0.5rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .trend-up {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }

  .trend-down {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }

  .trend-neutral {
    background: rgba(156, 163, 175, 0.15);
    color: #9ca3af;
  }

  .trend-icon {
    width: 14px;
    height: 14px;
  }

  .trend-value {
    font-size: 0.6875rem;
  }

  .stat-label {
    font-size: 0.9375rem;
    font-weight: 500;
    opacity: 0.8;
    line-height: 1.4;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
  .stat-card {
    animation: none;
  }
}

@media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .layout-inline .stats-grid {
      grid-template-columns: 1fr;
    }

    .stat-card {
      padding: 1.5rem 1rem;
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
