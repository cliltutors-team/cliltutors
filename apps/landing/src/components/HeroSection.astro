---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  cta1Text?: string;
  cta1Href?: string;
  cta2Text?: string;
  cta2Href?: string;
  imageSrc?: string;
  imageAlt?: string;
  dark?: boolean;
}

const { eyebrow, title, subtitle, cta1Text, cta1Href = '#', cta2Text, cta2Href = '#', imageSrc, imageAlt = '', dark = true } = Astro.props;
---

<section class={`relative overflow-hidden ${dark ? 'gradient-hero-glow' : 'bg-off-white'}`}>
  <!-- Decorative grid pattern (dark mode) -->
  {dark && (
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
  )}

  <div class="relative max-w-7xl mx-auto px-5 sm:px-6 lg:px-8 py-20 lg:py-32">
    <div class={`grid ${imageSrc ? 'lg:grid-cols-2 gap-12 lg:gap-16 items-center' : 'grid-cols-1 text-center'}`}>
      <!-- Content -->
      <div class={`${!imageSrc ? 'max-w-3xl mx-auto' : ''}`}>
        {eyebrow && (
          <span class={`hero-eyebrow animate-fade-up ${dark ? 'dark' : ''}`}>
            {eyebrow}
          </span>
        )}
        <h1 class={`font-heading font-bold text-4xl sm:text-5xl lg:text-[3.5rem] xl:text-6xl leading-[1.08] tracking-[-0.03em] text-balance animate-fade-up delay-100 ${dark ? 'text-white' : 'text-brand-navy'}`}>
          {title}
        </h1>
        <p class={`mt-6 text-lg sm:text-xl leading-relaxed max-w-xl animate-fade-up delay-200 ${dark ? 'text-white/75' : 'text-slate-light'} ${!imageSrc ? 'mx-auto max-w-2xl' : ''}`}>
          {subtitle}
        </p>
        {(cta1Text || cta2Text) && (
          <div class={`mt-10 flex flex-wrap gap-4 animate-fade-up delay-300 ${!imageSrc ? 'justify-center' : ''}`}>
            {cta1Text && (
              <a href={cta1Href} class={dark ? 'btn-white group' : 'btn-primary group'}>
                {cta1Text}
                <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </a>
            )}
            {cta2Text && (
              <a href={cta2Href} class={dark ? 'hero-ghost-btn' : 'btn-secondary'}>
                {cta2Text}
              </a>
            )}
          </div>
        )}
      </div>

      <!-- Image -->
      {imageSrc && (
        <div class="hidden lg:block animate-fade-up delay-400">
          <div class="hero-image-wrapper">
            <img src={imageSrc} alt={imageAlt} class="w-full max-w-lg mx-auto rounded-2xl" loading="eager" />
          </div>
        </div>
      )}
    </div>
  </div>

  <!-- Radial glow orbs (dark mode) -->
  {dark && (
    <Fragment>
      <div class="absolute top-1/4 -right-20 w-[400px] h-[400px] rounded-full opacity-20 blur-[100px] animate-float" style="background: radial-gradient(circle, rgba(82,138,237,0.6) 0%, transparent 70%);"></div>
      <div class="absolute -bottom-20 -left-20 w-[350px] h-[350px] rounded-full opacity-15 blur-[80px]" style="background: radial-gradient(circle, rgba(166,123,244,0.5) 0%, transparent 70%); animation: float 5s ease-in-out infinite 1s;"></div>
      <div class="absolute top-1/2 left-1/3 w-[200px] h-[200px] rounded-full opacity-10 blur-[60px]" style="background: radial-gradient(circle, rgba(254,187,55,0.5) 0%, transparent 70%); animation: float 6s ease-in-out infinite 2s;"></div>
    </Fragment>
  )}
</section>

<style>
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    background: rgba(82, 138, 237, 0.08);
    color: var(--color-brand-blue);
    border: 1px solid rgba(82, 138, 237, 0.15);
  }

  .hero-eyebrow.dark {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .hero-ghost-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.75rem;
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 12px;
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    cursor: pointer;
    text-decoration: none;
    backdrop-filter: blur(8px);
    transition: all 250ms cubic-bezier(0.25, 1, 0.5, 1);
  }

  .hero-ghost-btn:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
    transform: translateY(-1px);
  }

  .hero-image-wrapper {
    position: relative;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow:
      0 25px 60px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(255, 255, 255, 0.08) inset;
  }

  .hero-image-wrapper::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 1.25rem;
    padding: 1.5px;
    background: linear-gradient(145deg, rgba(255,255,255,0.15), rgba(255,255,255,0.02));
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }
</style>
