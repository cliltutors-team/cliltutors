---
import MotionReveal from './MotionReveal';
import StaggerContainer, { StaggerItem } from './StaggerContainer';
import StatsCounter from './StatsCounter';
import HeroVisual from './HeroVisual';

/** 
 * PremiumHero Component
 * Enterprise-grade hero section for $10M+ language learning platform
 * Features: Dynamic gradients, animated backgrounds, premium typography,
 * MotionReveal scroll entrances, glassmorphism trust bar, micro-interactions
 * i18n: Full translation support via props
 */

interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  ctaPrimary?: { text: string; href: string };
  ctaSecondary?: { text: string; href: string };
  visualType?: "image" | "illustration" | "gradient" | "video" | "animated";
  visualAsset?: string;
  visualVariant?: "dashboard" | "growth" | "network";
  visualStats?: Array<{ value: string; label: string }>;
  alignment?: "left" | "center" | "split";
  theme?: "dark" | "light" | "gradient";
  trustIndicators?: Array<{ value: string; label: string; animated?: boolean }>;
}

const {
  eyebrow,
  title,
  subtitle,
  ctaPrimary,
  ctaSecondary,
  visualType = "gradient",
  visualAsset,
  visualVariant = "dashboard",
  visualStats = [],
  alignment = "split",
  theme = "gradient",
  trustIndicators = [],
} = Astro.props;

const isDark = theme === "dark" || theme === "gradient";
---

<section
  class:list={[
    "premium-hero relative overflow-hidden",
    `hero-theme-${theme}`,
    `hero-align-${alignment}`,
  ]}
>
  {/* Desert Grain Mesh Background */}
  {
    isDark && (
      <Fragment>
        <div class="desert-mesh">
        <svg style="display:none" aria-hidden="true">
        <filter id="grainy">
        <feTurbulence
        type="fractalNoise"
        baseFrequency="0.65"
        numOctaves="3"
        stitchTiles="stitch"
        />
        <feColorMatrix type="saturate" values="0" />
        <feComponentTransfer>
        <feFuncA type="linear" slope="0.1" />
        </feComponentTransfer>
        <feBlend mode="overlay" in2="SourceGraphic" />
        </filter>
        </svg>
        </div>
        <div class="hero-dot-grid"></div>
        <div class="hero-float hero-float-1"></div>
        <div class="hero-float hero-float-2"></div>
        <div class="hero-float hero-float-3"></div>
      </Fragment>
    )
  }

  <div class="hero-container">
    <div
      class:list={[
        "hero-content",
        { "hero-content-center": alignment === "center" },
      ]}
    >
      {/* Eyebrow Badge */}
      {
        eyebrow && (
          <MotionReveal
            client:visible
            direction="up"
            delay={0}
            duration={0.6}
            className={`hero-eyebrow ${isDark ? "dark" : "light"}`}
          >
            <span class="eyebrow-dot" />
            {eyebrow}
          </MotionReveal>
        )
      }

      {/* Title with Premium Typography */}
      <MotionReveal
        client:visible
        direction="up"
        delay={0.1}
        duration={0.7}
      >
      <h1
        class={`hero-title ${isDark ? "gradient-text-hero" : "text-brand-navy"}`}
        set:html={title}
      />
      </MotionReveal>

      {/* Subtitle */}
      <MotionReveal
        client:visible
        direction="up"
        delay={0.2}
        duration={0.7}
      >
        <p
          class={`hero-subtitle ${isDark ? "text-white/80" : "text-slate-light"}`}
          set:html={subtitle}
        />
      </MotionReveal>

      {/* CTAs */}
      {
        (ctaPrimary || ctaSecondary) && (
          <MotionReveal
            client:visible
            direction="up"
            delay={0.3}
            duration={0.6}
            className="hero-cta-group"
          >
      {ctaPrimary && (
        <a
          href={ctaPrimary.href}
          class={`hero-btn-primary hero-btn-magnetic ${isDark ? "btn-white" : "btn-primary"}`}
        >
                <span>{ctaPrimary.text}</span>
                <svg
                  class="btn-arrow"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </a>
            )}
      {ctaSecondary && (
        <a
          href={ctaSecondary.href}
          class={`hero-btn-secondary hero-btn-magnetic ${isDark ? "btn-ghost-hero" : "btn-secondary"}`}
        >
                {ctaSecondary.text}
              </a>
            )}
          </MotionReveal>
        )
      }

      {/* Trust Indicators — glassmorphism bar */}
      {
        trustIndicators.length > 0 && (
          <MotionReveal
            client:visible
            direction="up"
            delay={0.45}
            duration={0.6}
            className="hero-trust-bar"
          >
            <StaggerContainer
              client:visible
              staggerDelay={0.08}
              className="trust-indicators-grid"
            >
        {trustIndicators.map((indicator) => (
          <StaggerItem client:visible className="trust-indicator">
            <span class="trust-value">
              {indicator.animated !== false
                ? <StatsCounter client:visible value={indicator.value} className="trust-counter" />
                : indicator.value}
            </span>
            <span class="trust-label">{indicator.label}</span>
          </StaggerItem>
        ))}
            </StaggerContainer>
          </MotionReveal>
        )
      }
    </div>

  {/* Visual Panel */}
  {
    visualType === "animated" && (
      <MotionReveal
        client:visible
        direction="left"
        delay={0.3}
        duration={0.8}
        className="hero-visual h-full"
      >
        <HeroVisual
          client:visible
          variant={visualVariant}
          stats={visualStats.length > 0 ? visualStats : trustIndicators.map(i => ({ value: i.value, label: i.label }))}
        />
      </MotionReveal>
    )
  }
  {
    visualType !== "gradient" && visualType !== "animated" && visualAsset && (
      <MotionReveal
        client:visible
        direction="left"
        delay={0.3}
        duration={0.8}
        className="hero-visual h-full"
      >
        <div class="visual-wrapper h-full">
          {visualType === "image" && (
            <img
              src={visualAsset}
              alt=""
              class="visual-image"
              loading="eager"
            />
          )}
          {visualType === "illustration" && (
            <div class="visual-illustration" set:html={visualAsset} />
          )}
        </div>
      </MotionReveal>
    )
  }
  </div>

  {/* Scroll Indicator */}
  <MotionReveal
    client:visible
    direction="up"
    delay={0.6}
    duration={0.5}
    className="hero-scroll-indicator"
  >
    <div class="scroll-mouse">
      <div class="scroll-wheel"></div>
    </div>
  </MotionReveal>
</section>

<style>
  /* ── Container & Layout ── */
  .premium-hero {
    min-height: 90vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: 72px;
  }

  .hero-container {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  .hero-align-split .hero-container {
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .hero-align-center .hero-container {
    grid-template-columns: 1fr;
    text-align: center;
  }

  /* ── Desert Grain Mesh Background ── */
  .desert-mesh {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background-color: var(--color-brand-navy-900);
    z-index: 0;
  }

  .desert-mesh::before {
    content: "";
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background-image:
      radial-gradient(
        circle at 10% 20%,
        var(--color-brand-blue) 0%,
        transparent 40%
      ),
      radial-gradient(
        circle at 80% 10%,
        var(--color-brand-purple) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 50% 50%,
        var(--color-brand-gold) 0%,
        transparent 40%
      ),
      radial-gradient(
        circle at 90% 80%,
        var(--color-brand-coral) 0%,
        transparent 45%
      ),
      radial-gradient(
        circle at 20% 80%,
        var(--color-brand-indigo) 0%,
        transparent 50%
      );
    background-size: 100% 100%;
    filter: blur(80px) saturate(1.5);
    animation: drift 25s infinite alternate ease-in-out;
    opacity: 0.8;
  }

  .desert-mesh::after {
    content: "";
    position: absolute;
    inset: 0;
    filter: url(#grainy);
    opacity: 0.4;
    pointer-events: none;
  }

  @keyframes drift {
    0% {
      transform: rotate(0deg) scale(1);
    }
    50% {
      transform: rotate(3deg) scale(1.1) translateX(2%);
    }
    100% {
      transform: rotate(-2deg) scale(1.05) translateY(1%);
    }
  }

  /* ── Content ── */
  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-content-center {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(12px);
  }

  .hero-eyebrow.light {
    background: rgba(82, 138, 237, 0.08);
    color: var(--color-brand-blue);
    border: 1px solid rgba(82, 138, 237, 0.2);
  }

  .hero-eyebrow.dark {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

.hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    max-width: 800px;
  }

  .hero-align-center .hero-title {
    max-width: 1000px;
  }

  .hero-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 600px;
  }

  .hero-align-center .hero-subtitle {
    max-width: 750px;
  }

  /* ── Buttons ── */
  .hero-cta-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }

.hero-btn-primary,
.hero-btn-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  padding: 1rem 2rem;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  border-radius: 14px;
  text-decoration: none;
  transition: all 350ms cubic-bezier(0.16, 1, 0.3, 1);
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.hero-btn-primary::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.15) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  transform: translateX(-100%);
  transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-btn-primary:hover::before {
  transform: translateX(100%);
}

.hero-btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(82, 138, 237, 0.35), 0 0 40px rgba(82, 138, 237, 0.12);
}

.hero-btn-primary:active {
  transform: translateY(0px);
  box-shadow: 0 2px 10px rgba(82, 138, 237, 0.2);
}

.hero-btn-secondary:hover {
  transform: translateY(-3px);
}

.hero-btn-secondary:active {
  transform: translateY(0px);
}

.btn-ghost-hero {
  background: rgba(255, 255, 255, 0.08);
  color: white;
  border: 1.5px solid rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.btn-ghost-hero:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.4);
  box-shadow: 0 8px 30px rgba(255, 255, 255, 0.1), 0 0 40px rgba(255, 255, 255, 0.04);
}

.btn-arrow {
  width: 18px;
  height: 18px;
  transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-btn-primary:hover .btn-arrow {
  transform: translateX(4px);
}

  /* ── Trust Bar — glassmorphism ── */
  .hero-trust-bar {
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: 0.5rem;
  }

  .trust-indicators-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

.trust-indicator {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding: 0.75rem 1.25rem;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.06);
  transition: all 300ms var(--ease-out-expo);
  position: relative;
  overflow: hidden;
}

.trust-indicator::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 12px;
  padding: 1px;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-purple));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 300ms var(--ease-out-expo);
  pointer-events: none;
}

.trust-indicator:hover {
  background: rgba(255, 255, 255, 0.08);
  border-color: transparent;
  transform: translateY(-2px);
}

.trust-indicator:hover::after {
  opacity: 1;
}

  .trust-value {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: inherit;
  }

  .trust-label {
    font-size: 0.875rem;
    opacity: 0.7;
  }

  /* ── Visual Panel ── */
  .hero-visual {
    position: relative;
    z-index: 2;
  }

  .visual-wrapper {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    box-shadow:
      0 30px 70px rgba(0, 0, 0, 0.15),
      0 0 0 1px rgba(255, 255, 255, 0.1) inset;
  }

  .visual-wrapper::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: 1.5rem;
    padding: 2px;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.2),
      rgba(255, 255, 255, 0.02)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
  }

  .visual-image {
    width: 100%;
    height: auto;
    display: block;
  }

/* ── Gradient Text Hero ── */
.gradient-text-hero {
  background: linear-gradient(135deg, white 0%, white 40%, var(--color-brand-gold) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Dot Grid Overlay ── */
.hero-dot-grid {
  position: absolute;
  inset: 0;
  z-index: 1;
  background-image: radial-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
}

/* ── Floating Elements ── */
.hero-float {
  position: absolute;
  border-radius: 1rem;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  pointer-events: none;
  z-index: 1;
}

.hero-float-1 {
  width: 120px;
  height: 80px;
  top: 18%;
  right: 8%;
  background: rgba(82, 138, 237, 0.1);
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.12);
  animation: float-1 12s ease-in-out infinite;
}

.hero-float-2 {
  width: 90px;
  height: 90px;
  bottom: 25%;
  right: 15%;
  background: rgba(166, 123, 244, 0.1);
  border-radius: 50%;
  box-shadow: 0 8px 32px rgba(166, 123, 244, 0.1);
  animation: float-2 10s ease-in-out infinite;
}

.hero-float-3 {
  width: 100px;
  height: 60px;
  top: 55%;
  right: 5%;
  background: rgba(254, 187, 55, 0.08);
  box-shadow: 0 8px 32px rgba(254, 187, 55, 0.1);
  animation: float-3 14s ease-in-out infinite;
}

@keyframes float-1 {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-20px) rotate(2deg); }
}

@keyframes float-2 {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(15px) scale(1.05); }
}

@keyframes float-3 {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  33% { transform: translateY(-12px) rotate(-1deg); }
  66% { transform: translateY(8px) rotate(1deg); }
}

/* ── Magnetic Button ── */
.hero-btn-magnetic {
  transition: transform 350ms cubic-bezier(0.16, 1, 0.3, 1), box-shadow 350ms cubic-bezier(0.16, 1, 0.3, 1);
}

/* ── Trust Counter ── */
.trust-value .trust-counter {
  font-family: inherit;
  font-size: inherit;
  font-weight: inherit;
  color: inherit;
  display: inline;
}

/* ── Scroll Indicator ── */
.hero-scroll-indicator {
  position: absolute;
  bottom: 3rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  opacity: 0.7;
  transition: opacity 400ms ease;
}

.hero-scroll-indicator:hover {
  opacity: 1;
}

.scroll-mouse {
  width: 26px;
  height: 42px;
  border: 2px solid rgba(255, 255, 255, 0.25);
  border-radius: 20px;
  display: flex;
  justify-content: center;
  padding-top: 8px;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  background: rgba(255, 255, 255, 0.03);
}

.scroll-wheel {
  width: 3px;
  height: 8px;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 2px;
  animation: scroll-pulse 2.2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

@keyframes scroll-pulse {
  0%, 100% {
    opacity: 0.3;
    transform: translateY(0);
  }
  50% {
    opacity: 1;
    transform: translateY(10px);
  }
}

/* ── Responsive ── */
@media (prefers-reduced-motion: reduce) {
  .desert-mesh::before {
    animation: none;
  }

  .scroll-wheel {
    animation: none;
  }

  .hero-float-1,
  .hero-float-2,
  .hero-float-3 {
    animation: none;
  }

  .hero-dot-grid {
    display: none;
  }
}

@media (max-width: 1024px) {
  .hero-align-split .hero-container {
    grid-template-columns: 1fr;
    text-align: center;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-cta-group {
    justify-content: center;
  }

  .hero-float-1,
  .hero-float-2,
  .hero-float-3 {
    display: none;
  }

  .hero-dot-grid {
    opacity: 0.5;
  }
}

@media (max-width: 640px) {
  .hero-container {
    padding: 2rem 1rem;
  }

  .trust-indicators-grid {
    flex-direction: column;
    gap: 1rem;
  }

  .hero-scroll-indicator {
    bottom: 1.5rem;
  }

  .hero-float {
    display: none;
  }

  .hero-dot-grid {
    display: none;
  }
}


</style>

<script>
const magneticBtns = document.querySelectorAll<HTMLElement>('.hero-btn-magnetic');
const STRENGTH = 0.15;

magneticBtns.forEach((btn) => {
  btn.addEventListener('mousemove', (e) => {
    const rect = btn.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    const deltaX = (e.clientX - centerX) * STRENGTH;
    const deltaY = (e.clientY - centerY) * STRENGTH;
    btn.style.transform = `translate(${deltaX}px, ${deltaY}px)`;
  });

  btn.addEventListener('mouseleave', () => {
    btn.style.transform = '';
  });
});
</script>
