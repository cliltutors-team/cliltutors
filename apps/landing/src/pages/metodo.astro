<script>
(function() {
  var CANVAS_W  = 1366;
  var CANVAS_H_DEFAULT = 668;

  // Returns [scale, containerWidth] for the current viewport
  function computeScale() {
    var vw = window.innerWidth;
    var scale, cw;
    if (vw >= 1024) {
      // Desktop: fit to viewport
      scale = vw / CANVAS_W;
      cw    = vw;
    } else if (vw >= 600) {
      // Tablet: fit but keep at least 0.55
      scale = Math.max(vw / CANVAS_W, 0.55);
      cw    = Math.round(CANVAS_W * scale);
    } else {
      // Mobile: fixed visible width of 660px (readable), allow horizontal scroll
      scale = 660 / CANVAS_W;   // ≈ 0.483
      cw    = 660;
    }
    return [scale, cw];
  }

  function resizeSlides() {
    var result = computeScale();
    var scale  = result[0];
    var cw     = result[1];

    // ── Update every .DPPJ_A slide container ──
    var slides = document.querySelectorAll('.DPPJ_A');
    slides.forEach(function(slide) {
      var inner = slide.querySelector('._14BoqA');
      if (!inner) return;
      var rawH  = parseFloat(inner.style.height) || CANVAS_H_DEFAULT;
      var ch    = rawH * scale;
      slide.style.width  = cw + 'px';
      slide.style.height = ch + 'px';
      inner.style.transform       = 'scale(' + scale + ')';
      inner.style.transformOrigin = '0 0';
    });

    // ── Update the .zEapAQ spacer containers (mirror adjacent .DPPJ_A height) ──
    var spacers = document.querySelectorAll('.zEapAQ');
    spacers.forEach(function(spacer) {
      var sibling = spacer.querySelector('.DPPJ_A');
      if (sibling) {
        spacer.style.width  = cw + 'px';
        spacer.style.height = sibling.style.height;
      } else {
        spacer.style.width = cw + 'px';
      }
    });

    // ── On mobile: allow horizontal scroll on the root wrapper ──
    var wrapper = document.querySelector('.LlCHmw.kMDoBQ');
    if (wrapper) {
      if (window.innerWidth < 600) {
        wrapper.style.overflowX = 'auto';
        wrapper.style.webkitOverflowScrolling = 'touch';
      } else {
        wrapper.style.overflowX = 'hidden';
      }
    }
  }

  // Run on DOMContentLoaded, resize, and immediately if DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', resizeSlides);
  } else {
    resizeSlides();
  }
  window.addEventListener('resize', resizeSlides);
})();
</script>
