---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Welcome to Astro.">
	<main class="flex min-h-screen flex-col items-center justify-between p-24">
		<h1 class="text-4xl font-bold text-deep-blue font-montserrat">
			Welcome to <span class="text-violet">Astro</span>
		</h1>
		<p class="mt-4 text-xl font-poppins text-gray-600">
			This is a landing page inside your Turborepo.
		</p>
		<button
			class="mt-8 px-6 py-3 bg-medium-blue text-white rounded-lg font-quicksand hover:bg-deep-blue transition-colors"
		>
			Get Started
		</button>
	</main>
</Layout>
