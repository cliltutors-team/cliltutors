---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import ContactForm from '../../components/ContactForm';
import LucideIcon from '../../components/LucideIcon';
import StaggerContainer, { StaggerItem } from '../../components/StaggerContainer';
import MotionCard from '../../components/MotionCard';
import MotionReveal from '../../components/MotionReveal';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const trustIndicators = [
  { value: '24h', label: t('contact.trust.response') },
  { value: '4.9', label: t('contact.trust.rating') },
  { value: '100%', label: t('contact.trust.dedicated') },
];

const contactMethods = [
  {
    icon: 'mail', iconType: 'lucide' as const,
    title: t('contact.method.email.title'),
    description: t('contact.method.email.desc'),
    action: 'hello@cliltutors.com',
    href: 'mailto:hello@cliltutors.com',
  },
  {
    icon: 'message-circle', iconType: 'lucide' as const,
    title: t('contact.method.chat.title'),
    description: t('contact.method.chat.desc'),
    action: t('contact.method.chat.action'),
    href: '#',
  },
  {
    icon: 'calendar', iconType: 'lucide' as const,
    title: t('contact.method.meeting.title'),
    description: t('contact.method.meeting.desc'),
    action: t('contact.method.meeting.action'),
    href: `/${lang}/consultation`,
  },
];

const faqs = [
  { question: t('contact.faq1.q'), answer: t('contact.faq1.a') },
  { question: t('contact.faq2.q'), answer: t('contact.faq2.a') },
  { question: t('contact.faq3.q'), answer: t('contact.faq3.a') },
];
---

<Layout title={t('contact.meta.title')} description={t('contact.meta.desc')} lang={lang}>
  <Navbar />

  <div class="contact-page">
    <PremiumHero
      eyebrow={t('contact.hero.eyebrow')}
      title={t('contact.hero.title')}
      subtitle={t('contact.hero.subtitle')}
      alignment="center"
      theme="gradient"
      trustIndicators={trustIndicators}
    />

    <section class="section-padding relative overflow-hidden">
      <div class="bg-dots"></div>
      <div class="container-narrow max-w-6xl relative">
        <MotionReveal client:visible>
          <SectionHeader
            eyebrow={t('contact.methods.eyebrow')}
            title={t('contact.methods.title')}
            description={t('contact.methods.subtitle')}
          />
        </MotionReveal>
      <StaggerContainer client:visible className="contact-methods-grid mb-16">
        {contactMethods.map((method) => (
          <StaggerItem>
            <MotionCard client:visible>
              <a href={method.href} class="contact-method-card">
                <div class="method-icon">
                  {method.iconType === 'lucide' ? (
                    <LucideIcon client:idle name={method.icon} size={32} color="currentColor" className="text-brand-blue" />
                  ) : (
                    method.icon
                  )}
                </div>
                <h3 class="method-title">{method.title}</h3>
                <p class="method-desc">{method.description}</p>
                <span class="method-action">{method.action}</span>
              </a>
            </MotionCard>
          </StaggerItem>
        ))}
      </StaggerContainer>

        <ContactForm
          client:visible
  t={t as (key: string) => string}
  lang={lang}
  contactMethods={contactMethods}
          faqs={faqs}
        />
      </div>
    </section>

    <PremiumCTABanner
      title={t('contact.cta.title')}
      description={t('contact.cta.subtitle')}
      primaryCTA={{ text: t('nav.consultation'), href: `/${lang}/consultation` }}
      secondaryCTA={{ text: t('nav.methodology'), href: `/${lang}/methodology` }}
      variant="gradient-purple"
      trustBadges={[
    { icon: 'mail', iconType: 'lucide' as const, label: t('contact.trust.response') },
    { icon: 'star', iconType: 'lucide' as const, label: t('contact.trust.rating') },
      ]}
    />
  </div>

  <Footer />
</Layout>

<style>
.contact-methods-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
}

.contact-method-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  padding: 2rem;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(82, 138, 237, 0.15);
  border-radius: 1.25rem;
  text-decoration: none;
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  transition: all 400ms var(--ease-out-expo);
  overflow: hidden;
}

.contact-method-card::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 1.25rem;
  padding: 1.5px;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-purple));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 400ms ease;
  pointer-events: none;
}

.contact-method-card:hover {
  background: rgba(255, 255, 255, 0.88);
  border-color: transparent;
  box-shadow: 0 12px 40px rgba(82, 138, 237, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.15);
  transform: translateY(-4px);
}

.contact-method-card:hover::after {
  opacity: 1;
}

.method-icon {
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.12), rgba(166, 123, 244, 0.1));
  border: 1px solid rgba(82, 138, 237, 0.2);
  transition: all 400ms var(--ease-out-expo);
}

.contact-method-card:hover .method-icon {
  transform: scale(1.08) rotate(-3deg);
  border-color: rgba(82, 138, 237, 0.35);
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.18), rgba(166, 123, 244, 0.16));
}

.method-title {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 600;
  color: var(--color-brand-navy);
  margin-bottom: 0.5rem;
}

.method-desc {
  font-size: 0.9375rem;
  color: var(--color-slate-light);
  line-height: 1.6;
  margin-bottom: 1rem;
}

.method-action {
  font-family: var(--font-heading);
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-brand-blue);
}

@media (max-width: 640px) {
  .contact-methods-grid {
    grid-template-columns: 1fr;
  }
}
</style>
