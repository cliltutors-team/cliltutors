---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCard from '../../components/PremiumCard.astro';
import StatsBanner from '../../components/StatsBanner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import MotionReveal from '../../components/MotionReveal.tsx';
import StaggerContainer, { StaggerItem } from '../../components/StaggerContainer.tsx';
import MotionCard from '../../components/MotionCard.tsx';
import LucideIcon from '../../components/LucideIcon.tsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('corporate.meta.title')} description={t('corporate.meta.desc')} lang={lang}>
  <div class="corporate-training">
  <Navbar />

  <PremiumHero
    eyebrow={t('corporate.hero.eyebrow')}
    title={t('corporate.hero.title')}
    subtitle={t('corporate.hero.subtitle')}
    ctaPrimary={{ text: t('corporate.cta.btn'), href: `/${lang}/consultation` }}
    ctaSecondary={{ text: t('corporate.hero.cta2'), href: `/${lang}/methodology` }}
  visualType="animated"
  visualVariant="growth"
  visualStats={[
    { value: '500+', label: t('corporate.trust.companies') },
    { value: '15K+', label: t('corporate.trust.professionals') },
    { value: '94%', label: t('corporate.trust.satisfaction') }
  ]}
  theme="gradient"
  trustIndicators={[
    { value: '500+', label: t('corporate.trust.companies') },
    { value: '15K+', label: t('corporate.trust.professionals') },
    { value: '94%', label: t('corporate.trust.satisfaction') }
  ]}
  />

  <section class="section-padding gradient-subtle ct-challenges">
    <div class="ct-bg-dots" aria-hidden="true"></div>
    <div class="container-narrow">
<MotionReveal client:visible>
      <SectionHeader
        eyebrow={t('corporate.challenges.eyebrow')}
        title={t('corporate.challenges.title')}
      />
    </MotionReveal>

    <StaggerContainer className="grid md:grid-cols-3 gap-8" client:visible>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="globe" iconType="lucide"
            title={t('corporate.ch1.title')}
            description={t('corporate.ch1.desc')}
            variant="navy"
            featured={false}
            metrics={[
              { label: t('corporate.metric.productivity'), value: '25%' }
            ]}
          />
        </MotionCard>
      </StaggerItem>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="users" iconType="lucide"
            title={t('corporate.ch2.title')}
            description={t('corporate.ch2.desc')}
            variant="navy"
            featured={false}
            metrics={[
              { label: t('corporate.metric.expansion'), value: '-40%' }
            ]}
          />
        </MotionCard>
      </StaggerItem>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="users" iconType="lucide"
            title={t('corporate.ch3.title')}
            description={t('corporate.ch3.desc')}
            variant="navy"
            featured={false}
            metrics={[
              { label: t('corporate.metric.performance'), value: '-35%' }
            ]}
          />
        </MotionCard>
      </StaggerItem>
    </StaggerContainer>
    </div>
  </section>

  <section class="section-padding gradient-subtle ct-programs">
    <div class="ct-orb ct-orb--blue" aria-hidden="true"></div>
    <div class="container-narrow">
<MotionReveal client:visible>
      <SectionHeader
        eyebrow={t('corporate.programs.eyebrow')}
        title={t('corporate.programs.title')}
      />
    </MotionReveal>

    <StaggerContainer className="grid md:grid-cols-3 gap-8" client:visible>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="briefcase" iconType="lucide"
            title={t('corporate.prog1.title')}
            description={t('corporate.prog1.desc')}
            href={`/${lang}/consultation`}
            linkText={t('corporate.programs.learn')}
            variant="blue"
            featured={true}
            featuredLabel={t('card.featured')}
            tags={[t('corporate.tag.c-suite'), t('corporate.tag.leadership')]}
          />
        </MotionCard>
      </StaggerItem>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="clipboard-list" iconType="lucide"
            title={t('corporate.prog2.title')}
            description={t('corporate.prog2.desc')}
            href={`/${lang}/consultation`}
            linkText={t('corporate.programs.learn')}
            variant="purple"
            featured={false}
            tags={[t('corporate.tag.departments'), t('corporate.tag.teams')]}
          />
        </MotionCard>
      </StaggerItem>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="globe-2" iconType="lucide"
            title={t('corporate.prog3.title')}
            description={t('corporate.prog3.desc')}
            href={`/${lang}/consultation`}
            linkText={t('corporate.programs.learn')}
            variant="gold"
            featured={false}
            tags={[t('corporate.tag.workshops'), t('corporate.tag.cultural')]}
          />
        </MotionCard>
      </StaggerItem>
    </StaggerContainer>
    </div>
  </section>

  <section class="section-padding gradient-section-alt ct-structure">
    <div class="container-narrow">
<MotionReveal client:visible>
      <SectionHeader
        eyebrow={t('corporate.structure.eyebrow')}
        title={t('corporate.structure.title')}
        description={t('corporate.structure.desc')}
      />
    </MotionReveal>

    <div class="mt-12 grid md:grid-cols-2 gap-8 items-center">
      <StaggerContainer className="structure-visual" client:visible>
        <StaggerItem>
          <div class="structure-step">
            <div class="step-number">01</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step1.title')}</h3>
              <p class="step-desc">{t('corporate.step1.desc')}</p>
            </div>
          </div>
        </StaggerItem>

        <StaggerItem>
          <div class="structure-step">
            <div class="step-number">02</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step2.title')}</h3>
              <p class="step-desc">{t('corporate.step2.desc')}</p>
            </div>
          </div>
        </StaggerItem>

        <StaggerItem>
          <div class="structure-step">
            <div class="step-number">03</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step3.title')}</h3>
              <p class="step-desc">{t('corporate.step3.desc')}</p>
            </div>
          </div>
        </StaggerItem>

        <StaggerItem>
          <div class="structure-step">
            <div class="step-number">04</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step4.title')}</h3>
              <p class="step-desc">{t('corporate.step4.desc')}</p>
            </div>
          </div>
        </StaggerItem>
      </StaggerContainer>

      <StaggerContainer className="structure-benefits" client:visible>
        <StaggerItem>
          <MotionCard client:visible>
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <LucideIcon client:idle name="check-circle" size={24} color="var(--color-brand-blue)" />
          </div>
          <h4>{t('corporate.benefit1.title')}</h4>
          <p>{t('corporate.benefit1.desc')}</p>
        </div>
          </MotionCard>
        </StaggerItem>

        <StaggerItem>
          <MotionCard client:visible>
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <LucideIcon client:idle name="zap" size={24} color="var(--color-brand-blue)" />
          </div>
          <h4>{t('corporate.benefit2.title')}</h4>
          <p>{t('corporate.benefit2.desc')}</p>
        </div>
          </MotionCard>
        </StaggerItem>

        <StaggerItem>
          <MotionCard client:visible>
        <div class="benefit-card">
          <div class="benefit-icon-wrap">
            <LucideIcon client:idle name="bar-chart" size={24} color="var(--color-brand-brand-blue)" />
          </div>
          <h4>{t('corporate.benefit3.title')}</h4>
          <p>{t('corporate.benefit3.desc')}</p>
        </div>
          </MotionCard>
        </StaggerItem>
      </StaggerContainer>
    </div>
    </div>
  </section>

  <section class="section-padding gradient-premium ct-solution">
    <div class="ct-orb ct-orb--purple" aria-hidden="true"></div>
    <div class="container-narrow">
<MotionReveal client:visible>
      <SectionHeader
        eyebrow={t('corporate.solution.eyebrow')}
        title={t('corporate.solution.title')}
      />
    </MotionReveal>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <StaggerContainer className="solution-content" client:visible>
        <StaggerItem>
          <div class="solution-point">
            <div class="point-icon blue">
              <LucideIcon client:idle name="search" size={28} color="currentColor" />
            </div>
            <div class="point-content">
              <h3>{t('corporate.solution1.title')}</h3>
              <p>{t('corporate.solution1.desc')}</p>
            </div>
          </div>
        </StaggerItem>

        <StaggerItem>
          <div class="solution-point">
            <div class="point-icon purple">
              <LucideIcon client:idle name="settings" size={28} color="currentColor" />
            </div>
            <div class="point-content">
              <h3>{t('corporate.solution2.title')}</h3>
              <p>{t('corporate.solution2.desc')}</p>
            </div>
          </div>
        </StaggerItem>

        <StaggerItem>
          <div class="solution-point">
            <div class="point-icon gold">
              <LucideIcon client:idle name="shield-check" size={28} color="currentColor" />
            </div>
            <div class="point-content">
              <h3>{t('corporate.solution3.title')}</h3>
              <p>{t('corporate.solution3.desc')}</p>
            </div>
          </div>
        </StaggerItem>
      </StaggerContainer>

      <MotionReveal client:visible direction="left" delay={0.2}>
        <div class="solution-visual">
          <div class="visual-card card-1">
            <div class="card-header">
              <div class="status-dot"></div>
              <span>{t('corporate.visual.active')}</span>
            </div>
            <div class="card-metric">
              <span class="metric-value">+127%</span>
              <span class="metric-label">{t('corporate.visual.engagement')}</span>
            </div>
          </div>

          <div class="visual-card card-2">
            <div class="card-header">
              <div class="status-dot success"></div>
              <span>{t('corporate.visual.completed')}</span>
            </div>
            <div class="card-metric">
              <span class="metric-value">2,847</span>
              <span class="metric-label">{t('corporate.visual.professionals')}</span>
            </div>
          </div>
        </div>
      </MotionReveal>
    </div>
    </div>
  </section>

  <section class="section-padding gradient-subtle ct-cases">
    <div class="ct-bg-dots ct-bg-dots--right" aria-hidden="true"></div>
    <div class="container-narrow">
<MotionReveal client:visible>
      <SectionHeader
        eyebrow={t('corporate.cases.eyebrow')}
        title={t('corporate.cases.title')}
      />
    </MotionReveal>

    <StaggerContainer className="grid md:grid-cols-3 gap-8" client:visible>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="briefcase" iconType="lucide"
            title={t('corporate.case1.company')}
            description={t('corporate.case1.desc')}
            variant="blue"
            metrics={[
              { label: t('corporate.case.metric1'), value: '+45%' },
              { label: t('corporate.case.metric2'), value: t('corporate.case1.duration') }
            ]}
          />
        </MotionCard>
      </StaggerItem>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="factory" iconType="lucide"
            title={t('corporate.case2.company')}
            description={t('corporate.case2.desc')}
            variant="purple"
            metrics={[
              { label: t('corporate.case.metric1'), value: '+62%' },
              { label: t('corporate.case.metric2'), value: t('corporate.case2.duration') }
            ]}
          />
        </MotionCard>
      </StaggerItem>
      <StaggerItem>
        <MotionCard client:visible>
          <PremiumCard
            icon="landmark" iconType="lucide"
            title={t('corporate.case3.company')}
            description={t('corporate.case3.desc')}
            variant="gold"
            metrics={[
              { label: t('corporate.case.metric1'), value: '+78%' },
              { label: t('corporate.case.metric2'), value: t('corporate.case3.duration') }
            ]}
          />
        </MotionCard>
      </StaggerItem>
    </StaggerContainer>
    </div>
  </section>

  <PremiumCTABanner
    title={t('corporate.cta.title')}
    primaryCTA={{ text: t('corporate.cta.btn'), href: `/${lang}/consultation` }}
    variant="gradient"
    trustBadges={[
      { icon: 'briefcase', iconType: 'lucide' as const, label: t('corporate.trust.companies'), value: '500+' },
      { icon: 'user', iconType: 'lucide' as const, label: t('corporate.trust.professionals'), value: '15K+' },
      { icon: 'star', iconType: 'lucide' as const, label: t('corporate.trust.satisfaction'), value: '94%' }
    ]}
  />

  <Footer />
  </div>
</Layout>

<style>
  .ct-challenges,
  .ct-programs,
  .ct-structure,
  .ct-solution,
  .ct-cases {
    position: relative;
    overflow: hidden;
  }

  .ct-bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(82, 138, 237, 0.06) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  .ct-bg-dots--right {
    background-position: right center;
  }

  .ct-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .ct-orb--blue {
    width: 400px;
    height: 400px;
    top: -100px;
    right: -100px;
    background: radial-gradient(circle, rgba(82, 138, 237, 0.12), transparent 70%);
  }

  .ct-orb--purple {
    width: 350px;
    height: 350px;
    bottom: -80px;
    left: -80px;
    background: radial-gradient(circle, rgba(166, 123, 244, 0.1), transparent 70%);
  }

.structure-visual {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  position: relative;
}

.structure-visual::before {
  content: "";
  position: absolute;
  left: 3.5rem;
  top: 2.5rem;
  bottom: 2.5rem;
  width: 2px;
  background: linear-gradient(to bottom, var(--color-brand-blue), var(--color-brand-indigo), var(--color-brand-purple));
  opacity: 0.2;
  border-radius: 1px;
}

.structure-step {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  position: relative;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 1.25rem;
  border: 1px solid rgba(82, 138, 237, 0.15);
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  transition: all 400ms var(--ease-out-expo);
  overflow: hidden;
}

.structure-step::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 1.25rem;
  padding: 1.5px;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 400ms ease;
  pointer-events: none;
}

.structure-step:hover {
  background: rgba(255, 255, 255, 0.88);
  border-color: transparent;
  box-shadow: 0 12px 40px rgba(82, 138, 237, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.15);
  transform: translateX(8px);
}

.structure-step:hover::after {
  opacity: 1;
}

.step-number {
  font-family: var(--font-heading);
  font-size: 2rem;
  font-weight: 700;
  line-height: 1;
  opacity: 0.25;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo));
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  transition: all 400ms ease;
}

.structure-step:hover .step-number {
  opacity: 0.6;
}

  .step-content {
    flex: 1;
  }

  .step-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-brand-navy);
    margin: 0 0 0.5rem;
  }

  .step-desc {
    font-size: 0.9375rem;
    color: var(--color-slate-light);
    line-height: 1.6;
    margin: 0;
  }

  .structure-benefits {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

.benefit-card {
  position: relative;
  padding: 1.75rem;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 1.25rem;
  border: 1px solid rgba(82, 138, 237, 0.15);
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  transition: all 400ms var(--ease-out-expo);
  overflow: hidden;
}

.benefit-card::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 1.25rem;
  padding: 1.5px;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-purple));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 400ms ease;
  pointer-events: none;
}

.benefit-card:hover {
  background: rgba(255, 255, 255, 0.85);
  border-color: transparent;
  box-shadow: 0 12px 40px rgba(82, 138, 237, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.15);
  transform: translateY(-4px);
}

.benefit-card:hover::after {
  opacity: 1;
}

.benefit-icon-wrap {
  width: 3rem;
  height: 3rem;
  border-radius: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.12), rgba(166, 123, 244, 0.12));
  border: 1px solid rgba(82, 138, 237, 0.2);
  margin-bottom: 1rem;
  transition: all 400ms var(--ease-out-expo);
}

.benefit-card:hover .benefit-icon-wrap {
  transform: scale(1.08) rotate(-3deg);
  border-color: rgba(82, 138, 237, 0.3);
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.18), rgba(166, 123, 244, 0.18));
}

.benefit-card h4 {
  font-family: var(--font-heading);
  font-size: 1.125rem;
  font-weight: 600;
  color: var(--color-brand-navy);
  margin: 0 0 0.5rem;
}

.benefit-card p {
  font-size: 0.9375rem;
  color: var(--color-slate-light);
  line-height: 1.6;
  margin: 0;
}

  .solution-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

.solution-point {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  position: relative;
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 1.25rem;
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  transition: all 400ms var(--ease-out-expo);
  overflow: hidden;
}

.solution-point::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 1.25rem;
  padding: 1.5px;
  background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-purple));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 400ms ease;
  pointer-events: none;
}

.solution-point:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: transparent;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.12);
  transform: translateX(8px);
}

.solution-point:hover::after {
  opacity: 1;
}

.point-icon {
  width: 3.5rem;
  height: 3.5rem;
  border-radius: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 400ms var(--ease-out-expo);
}

.point-icon.blue {
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.15), rgba(76, 108, 225, 0.15));
  border: 1px solid rgba(82, 138, 237, 0.25);
  color: var(--color-brand-blue);
}

.point-icon.purple {
  background: linear-gradient(135deg, rgba(166, 123, 244, 0.15), rgba(82, 138, 237, 0.1));
  border: 1px solid rgba(166, 123, 244, 0.25);
  color: var(--color-brand-purple);
}

.point-icon.gold {
  background: linear-gradient(135deg, rgba(254, 187, 55, 0.15), rgba(251, 122, 75, 0.1));
  border: 1px solid rgba(254, 187, 55, 0.25);
  color: var(--color-brand-gold);
}

.solution-point:hover .point-icon {
  transform: scale(1.08) rotate(-3deg);
}

.solution-point:hover .point-icon.blue {
  border-color: rgba(82, 138, 237, 0.4);
}

.solution-point:hover .point-icon.purple {
  border-color: rgba(166, 123, 244, 0.4);
}

.solution-point:hover .point-icon.gold {
  border-color: rgba(254, 187, 55, 0.4);
}

  .point-content h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-brand-navy);
    margin: 0 0 0.5rem;
  }

  .point-content p {
    font-size: 1rem;
    color: var(--color-slate-light);
    line-height: 1.7;
    margin: 0;
  }

  .solution-visual {
    position: relative;
    height: 400px;
  }

.visual-card {
