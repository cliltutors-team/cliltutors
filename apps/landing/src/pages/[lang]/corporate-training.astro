---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('corporate.meta.title')} description={t('corporate.meta.desc')} lang={lang}>
  <div class="corporate-training">
  <Navbar />

  <PremiumHero
    eyebrow={t('corporate.hero.eyebrow')}
    title={t('corporate.hero.title')}
    subtitle={t('corporate.hero.subtitle')}
    ctaPrimary={{ text: t('corporate.cta.btn'), href: `/${lang}/consultation` }}
    ctaSecondary={{ text: t('corporate.hero.cta2'), href: `/${lang}/methodology` }}
    visualType="animated"
    visualVariant="growth"
    visualStats={[
      { value: '500+', label: t('corporate.trust.companies') },
      { value: '15K+', label: t('corporate.trust.professionals') },
      { value: '94%', label: t('corporate.trust.satisfaction') }
    ]}
    theme="gradient"
    trustIndicators={[
      { value: '500+', label: t('corporate.trust.companies') },
      { value: '15K+', label: t('corporate.trust.professionals') },
      { value: '94%', label: t('corporate.trust.satisfaction') }
    ]}
  />

  <!-- ============================================================
       SECTION 1: CHALLENGES — Diagnostic dark panel with impact bars
       ============================================================ -->
  <section class="section-padding ct-challenges reveal-section" aria-labelledby="challenges-heading">
    <div class="container-narrow">
      <div class="ct-challenges-inner">
        <div class="ct-challenges-header">
          <span class="ct-eyebrow ct-eyebrow--light">{t('corporate.challenges.eyebrow')}</span>
          <h2 id="challenges-heading" class="ct-section-title ct-section-title--light">
            {t('corporate.challenges.title')}
          </h2>
        </div>

        <div class="ct-challenges-list">
          <!-- Challenge 1 -->
          <div class="ct-challenge-row reveal" style="--stagger:1">
            <div class="ct-challenge-ordinal">01</div>
            <div class="ct-challenge-body">
              <h3 class="ct-challenge-name">{t('corporate.ch1.title')}</h3>
              <p class="ct-challenge-desc">{t('corporate.ch1.desc')}</p>
            </div>
            <div class="ct-challenge-impact">
              <div class="ct-impact-bar-wrap">
                <div class="ct-impact-label">{t('corporate.metric.productivity')} loss</div>
                <div class="ct-impact-track">
                  <div class="ct-impact-fill ct-impact-fill--25"></div>
                </div>
                <div class="ct-impact-value">−25%</div>
              </div>
            </div>
          </div>

          <div class="ct-challenge-divider"></div>

          <!-- Challenge 2 -->
          <div class="ct-challenge-row reveal" style="--stagger:2">
            <div class="ct-challenge-ordinal">02</div>
            <div class="ct-challenge-body">
              <h3 class="ct-challenge-name">{t('corporate.ch2.title')}</h3>
              <p class="ct-challenge-desc">{t('corporate.ch2.desc')}</p>
            </div>
            <div class="ct-challenge-impact">
              <div class="ct-impact-bar-wrap">
                <div class="ct-impact-label">{t('corporate.metric.expansion')} speed</div>
                <div class="ct-impact-track">
                  <div class="ct-impact-fill ct-impact-fill--40"></div>
                </div>
                <div class="ct-impact-value">−40%</div>
              </div>
            </div>
          </div>

          <div class="ct-challenge-divider"></div>

          <!-- Challenge 3 -->
          <div class="ct-challenge-row reveal" style="--stagger:3">
            <div class="ct-challenge-ordinal">03</div>
            <div class="ct-challenge-body">
              <h3 class="ct-challenge-name">{t('corporate.ch3.title')}</h3>
              <p class="ct-challenge-desc">{t('corporate.ch3.desc')}</p>
            </div>
            <div class="ct-challenge-impact">
              <div class="ct-impact-bar-wrap">
                <div class="ct-impact-label">{t('corporate.metric.performance')} drop</div>
                <div class="ct-impact-track">
                  <div class="ct-impact-fill ct-impact-fill--35"></div>
                </div>
                <div class="ct-impact-value">−35%</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2: PROGRAMS — Horizontal track lanes
       ============================================================ -->
  <section class="section-padding ct-programs reveal-section" aria-labelledby="programs-heading">
    <div class="container-narrow">
      <div class="ct-programs-header reveal" style="--stagger:0">
        <span class="ct-eyebrow">{t('corporate.programs.eyebrow')}</span>
        <h2 id="programs-heading" class="ct-section-title">{t('corporate.programs.title')}</h2>
        <p class="ct-section-subtitle">{t('corporate.programs.subtitle')}</p>
      </div>

      <div class="ct-programs-tracks">
        <!-- Track 1: Executive Immersion -->
        <a href={`/${lang}/consultation`} class="ct-track ct-track--blue reveal" style="--stagger:1" aria-label={t('corporate.prog1.title')}>
          <div class="ct-track-accent ct-track-accent--blue"></div>
          <div class="ct-track-content">
            <div class="ct-track-meta">
              <span class="ct-track-index">01</span>
              <div class="ct-track-tags">
                <span class="ct-tag ct-tag--blue">{t('corporate.tag.c-suite')}</span>
                <span class="ct-tag ct-tag--blue">{t('corporate.tag.leadership')}</span>
              </div>
            </div>
            <div class="ct-track-main">
              <h3 class="ct-track-title">{t('corporate.prog1.title')}</h3>
              <p class="ct-track-desc">{t('corporate.prog1.desc')}</p>
            </div>
            <div class="ct-track-cta">
              <span class="ct-track-link">{t('corporate.programs.learn')}</span>
              <svg class="ct-track-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>

        <!-- Track 2: Team Training -->
        <a href={`/${lang}/consultation`} class="ct-track ct-track--purple reveal" style="--stagger:2" aria-label={t('corporate.prog2.title')}>
          <div class="ct-track-accent ct-track-accent--purple"></div>
          <div class="ct-track-content">
            <div class="ct-track-meta">
              <span class="ct-track-index">02</span>
              <div class="ct-track-tags">
                <span class="ct-tag ct-tag--purple">{t('corporate.tag.departments')}</span>
                <span class="ct-tag ct-tag--purple">{t('corporate.tag.teams')}</span>
              </div>
            </div>
            <div class="ct-track-main">
              <h3 class="ct-track-title">{t('corporate.prog2.title')}</h3>
              <p class="ct-track-desc">{t('corporate.prog2.desc')}</p>
            </div>
            <div class="ct-track-cta">
              <span class="ct-track-link">{t('corporate.programs.learn')}</span>
              <svg class="ct-track-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>

        <!-- Track 3: Global Onboarding -->
        <a href={`/${lang}/consultation`} class="ct-track ct-track--gold reveal" style="--stagger:3" aria-label={t('corporate.prog3.title')}>
          <div class="ct-track-accent ct-track-accent--gold"></div>
          <div class="ct-track-content">
            <div class="ct-track-meta">
              <span class="ct-track-index">03</span>
              <div class="ct-track-tags">
                <span class="ct-tag ct-tag--gold">{t('corporate.tag.workshops')}</span>
                <span class="ct-tag ct-tag--gold">{t('corporate.tag.cultural')}</span>
              </div>
            </div>
            <div class="ct-track-main">
              <h3 class="ct-track-title">{t('corporate.prog3.title')}</h3>
              <p class="ct-track-desc">{t('corporate.prog3.desc')}</p>
            </div>
            <div class="ct-track-cta">
              <span class="ct-track-link">{t('corporate.programs.learn')}</span>
              <svg class="ct-track-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3: HOW IT WORKS — Horizontal connected timeline
       ============================================================ -->
  <section class="section-padding ct-journey reveal-section" aria-labelledby="journey-heading">
    <div class="container-narrow">
      <div class="ct-journey-header reveal" style="--stagger:0">
        <span class="ct-eyebrow">{t('corporate.structure.eyebrow')}</span>
        <h2 id="journey-heading" class="ct-section-title">{t('corporate.structure.title')}</h2>
        <p class="ct-section-subtitle">{t('corporate.structure.desc')}</p>
      </div>

      <div class="ct-timeline" role="list">
        <div class="ct-timeline-track" aria-hidden="true"></div>

        <div class="ct-timeline-node reveal" style="--stagger:1" role="listitem">
          <div class="ct-node-dot ct-node-dot--blue">
            <span class="ct-node-num">01</span>
          </div>
          <div class="ct-node-card">
            <h3 class="ct-node-title">{t('corporate.step1.title')}</h3>
            <p class="ct-node-desc">{t('corporate.step1.desc')}</p>
          </div>
        </div>

        <div class="ct-timeline-node reveal" style="--stagger:2" role="listitem">
          <div class="ct-node-dot ct-node-dot--indigo">
            <span class="ct-node-num">02</span>
          </div>
          <div class="ct-node-card">
            <h3 class="ct-node-title">{t('corporate.step2.title')}</h3>
            <p class="ct-node-desc">{t('corporate.step2.desc')}</p>
          </div>
        </div>

        <div class="ct-timeline-node reveal" style="--stagger:3" role="listitem">
          <div class="ct-node-dot ct-node-dot--purple">
            <span class="ct-node-num">03</span>
          </div>
          <div class="ct-node-card">
            <h3 class="ct-node-title">{t('corporate.step3.title')}</h3>
            <p class="ct-node-desc">{t('corporate.step3.desc')}</p>
          </div>
        </div>

        <div class="ct-timeline-node reveal" style="--stagger:4" role="listitem">
          <div class="ct-node-dot ct-node-dot--gold">
            <span class="ct-node-num">04</span>
          </div>
          <div class="ct-node-card">
            <h3 class="ct-node-title">{t('corporate.step4.title')}</h3>
            <p class="ct-node-desc">{t('corporate.step4.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4: WHY CLILTUTORS — Editorial alternating rows
       ============================================================ -->
  <section class="section-padding ct-why reveal-section" aria-labelledby="why-heading">
    <div class="container-narrow">
      <div class="ct-why-header reveal" style="--stagger:0">
        <span class="ct-eyebrow ct-eyebrow--light">{t('corporate.solution.eyebrow')}</span>
        <h2 id="why-heading" class="ct-section-title ct-section-title--light">{t('corporate.solution.title')}</h2>
      </div>

      <div class="ct-why-rows">
        <!-- Row 1 -->
        <div class="ct-why-row reveal" style="--stagger:1">
          <div class="ct-why-stat">
            <span class="ct-why-stat-num">01</span>
            <div class="ct-why-stat-bar ct-why-stat-bar--blue"></div>
          </div>
          <div class="ct-why-divider" aria-hidden="true"></div>
          <div class="ct-why-content">
            <h3 class="ct-why-title">{t('corporate.solution1.title')}</h3>
            <p class="ct-why-desc">{t('corporate.solution1.desc')}</p>
          </div>
          <div class="ct-why-metric">
            <span class="ct-why-metric-value">100%</span>
            <span class="ct-why-metric-label">Native speakers</span>
          </div>
        </div>

        <!-- Row 2 -->
        <div class="ct-why-row reveal" style="--stagger:2">
          <div class="ct-why-stat">
            <span class="ct-why-stat-num">02</span>
            <div class="ct-why-stat-bar ct-why-stat-bar--purple"></div>
          </div>
          <div class="ct-why-divider" aria-hidden="true"></div>
          <div class="ct-why-content">
            <h3 class="ct-why-title">{t('corporate.solution2.title')}</h3>
            <p class="ct-why-desc">{t('corporate.solution2.desc')}</p>
          </div>
          <div class="ct-why-metric">
            <span class="ct-why-metric-value">3×</span>
            <span class="ct-why-metric-label">Faster fluency</span>
          </div>
        </div>

        <!-- Row 3 -->
        <div class="ct-why-row reveal" style="--stagger:3">
          <div class="ct-why-stat">
            <span class="ct-why-stat-num">03</span>
            <div class="ct-why-stat-bar ct-why-stat-bar--gold"></div>
          </div>
          <div class="ct-why-divider" aria-hidden="true"></div>
          <div class="ct-why-content">
            <h3 class="ct-why-title">{t('corporate.solution3.title')}</h3>
            <p class="ct-why-desc">{t('corporate.solution3.desc')}</p>
          </div>
          <div class="ct-why-metric">
            <span class="ct-why-metric-value">+127%</span>
            <span class="ct-why-metric-label">{t('corporate.visual.engagement')}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 5: CASES — Impact spotlight (1 featured + 2 strips)
       ============================================================ -->
  <section class="section-padding ct-cases reveal-section" aria-labelledby="cases-heading">
    <div class="container-narrow">
      <div class="ct-cases-header reveal" style="--stagger:0">
        <span class="ct-eyebrow">{t('corporate.cases.eyebrow')}</span>
        <h2 id="cases-heading" class="ct-section-title">{t('corporate.cases.title')}</h2>
      </div>

      <!-- Featured case: full-width spotlight -->
      <div class="ct-case-featured reveal" style="--stagger:1">
        <div class="ct-case-featured-bg" aria-hidden="true"></div>
        <div class="ct-case-featured-content">
          <div class="ct-case-company-wrap">
            <div class="ct-case-company-logo" aria-hidden="true">TC</div>
            <div>
              <h3 class="ct-case-company-name">{t('corporate.case1.company')}</h3>
              <span class="ct-case-duration">{t('corporate.case1.duration')}</span>
            </div>
          </div>
          <p class="ct-case-featured-desc">{t('corporate.case1.desc')}</p>
          <div class="ct-case-featured-metrics">
            <div class="ct-case-metric-big">
              <span class="ct-case-metric-value">+45%</span>
              <span class="ct-case-metric-label">{t('corporate.metric.productivity')}</span>
            </div>
            <div class="ct-case-metric-big">
              <span class="ct-case-metric-value">−40%</span>
              <span class="ct-case-metric-label">Onboarding time</span>
            </div>
          </div>
        </div>
        <div class="ct-case-featured-visual" aria-hidden="true">
          <div class="ct-case-ring ct-case-ring--1"></div>
          <div class="ct-case-ring ct-case-ring--2"></div>
          <div class="ct-case-ring ct-case-ring--3"></div>
          <div class="ct-case-ring-center">+45%</div>
        </div>
      </div>

      <!-- Two compact horizontal strips -->
      <div class="ct-case-strips">
        <div class="ct-case-strip reveal" style="--stagger:2">
          <div class="ct-strip-accent ct-strip-accent--purple"></div>
          <div class="ct-strip-logo" aria-hidden="true">FG</div>
          <div class="ct-strip-body">
            <h3 class="ct-strip-company">{t('corporate.case2.company')}</h3>
            <p class="ct-strip-desc">{t('corporate.case2.desc')}</p>
          </div>
          <div class="ct-strip-metrics">
            <div class="ct-strip-metric">
              <span class="ct-strip-metric-value">+62%</span>
              <span class="ct-strip-metric-label">{t('corporate.metric.performance')}</span>
            </div>
            <div class="ct-strip-metric">
              <span class="ct-strip-metric-value">{t('corporate.case2.duration')}</span>
              <span class="ct-strip-metric-label">{t('corporate.case.metric1')}</span>
            </div>
          </div>
        </div>

        <div class="ct-case-strip reveal" style="--stagger:3">
          <div class="ct-strip-accent ct-strip-accent--gold"></div>
          <div class="ct-strip-logo ct-strip-logo--gold" aria-hidden="true">IH</div>
          <div class="ct-strip-body">
            <h3 class="ct-strip-company">{t('corporate.case3.company')}</h3>
            <p class="ct-strip-desc">{t('corporate.case3.desc')}</p>
          </div>
          <div class="ct-strip-metrics">
            <div class="ct-strip-metric">
              <span class="ct-strip-metric-value">×3</span>
              <span class="ct-strip-metric-label">Collaboration</span>
            </div>
            <div class="ct-strip-metric">
              <span class="ct-strip-metric-value">{t('corporate.case3.duration')}</span>
              <span class="ct-strip-metric-label">{t('corporate.case.metric1')}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <PremiumCTABanner
    title={t('corporate.cta.title')}
    primaryCTA={{ text: t('corporate.cta.btn'), href: `/${lang}/consultation` }}
    variant="gradient"
    trustBadges={[
      { icon: 'briefcase', iconType: 'lucide' as const, label: t('corporate.trust.companies'), value: '500+' },
      { icon: 'user', iconType: 'lucide' as const, label: t('corporate.trust.professionals'), value: '15K+' },
      { icon: 'star', iconType: 'lucide' as const, label: t('corporate.trust.satisfaction'), value: '94%' }
    ]}
  />

  <Footer />
  </div>
</Layout>

<style>
/* ─── Shared tokens ─────────────────────────────────────── */
.ct-eyebrow {
  display: inline-block;
  padding: 0.375rem 1rem;
  background: var(--color-brand-blue-50);
  color: var(--color-brand-blue-700);
  border-radius: 100px;
  font-size: 0.6875rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  font-family: var(--font-heading);
}

.ct-eyebrow--light {
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
}

.ct-section-title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 700;
  color: var(--color-brand-navy);
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin: 1rem 0 0;
}

.ct-section-title--light {
  color: white;
}

.ct-section-subtitle {
  font-size: 1.125rem;
  color: var(--color-slate-light);
  line-height: 1.7;
  max-width: 560px;
  margin: 1rem 0 0;
}

/* ─── Reveal animation ──────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition:
    opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1),
    transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  transition-delay: calc(var(--stagger, 0) * 90ms);
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}

/* ════════════════════════════════════════════════════════════
   SECTION 1 — CHALLENGES
   Dark scan panel with horizontal impact bars
   ════════════════════════════════════════════════════════════ */
.ct-challenges {
  background: linear-gradient(160deg, var(--color-brand-navy) 0%, #1a1b30 60%, #0d0e1f 100%);
  position: relative;
  overflow: hidden;
}

.ct-challenges::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(82, 138, 237, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(82, 138, 237, 0.04) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
}

.ct-challenges-inner {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4rem;
  align-items: start;
}

@media (max-width: 768px) {
  .ct-challenges-inner {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
}

.ct-challenges-header {
  position: sticky;
  top: 6rem;
  max-width: 280px;
}

@media (max-width: 768px) {
  .ct-challenges-header {
    position: static;
    max-width: none;
  }
}

.ct-challenges-list {
  display: flex;
  flex-direction: column;
}

.ct-challenge-row {
  display: grid;
  grid-template-columns: 4rem 1fr auto;
  gap: 2rem;
  align-items: center;
  padding: 2.5rem 0;
}

@media (max-width: 640px) {
  .ct-challenge-row {
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: 2rem 0;
  }
}

.ct-challenge-divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.07);
}

.ct-challenge-ordinal {
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 800;
  line-height: 1;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255, 255, 255, 0.15);
  letter-spacing: -0.04em;
  flex-shrink: 0;
}

.ct-challenge-name {
  font-family: var(--font-heading);
  font-size: 1.375rem;
  font-weight: 600;
  color: white;
  margin: 0 0 0.625rem;
}

.ct-challenge-desc {
  font-size: 0.9375rem;
  color: rgba(255, 255, 255, 0.65);
  line-height: 1.7;
  margin: 0;
}

.ct-challenge-impact {
  flex-shrink: 0;
  min-width: 200px;
}

@media (max-width: 640px) {
  .ct-challenge-impact {
    min-width: 0;
  }
}

.ct-impact-bar-wrap {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.ct-impact-label {
  font-size: 0.6875rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.45);
}

.ct-impact-track {
  height: 6px;
