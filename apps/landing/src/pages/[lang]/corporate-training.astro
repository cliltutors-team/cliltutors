---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCard from '../../components/PremiumCard.astro';
import StatsBanner from '../../components/StatsBanner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('corporate.meta.title')} description={t('corporate.meta.desc')} lang={lang}>
  <Navbar />
  
  <PremiumHero
    eyebrow={t('corporate.hero.eyebrow')}
    title={t('corporate.hero.title')}
    subtitle={t('corporate.hero.subtitle')}
    ctaPrimary={{ text: t('corporate.cta.btn'), href: `/${lang}/consultation` }}
    ctaSecondary={{ text: t('corporate.hero.cta2'), href: `/${lang}/methodology` }}
    visualType="image"
    visualAsset="/images/web/Corporate_Hero.webp"
    alignment="split"
    theme="gradient"
    trustIndicators={[
      { value: '500+', label: t('corporate.trust.companies') },
      { value: '15K+', label: t('corporate.trust.professionals') },
      { value: '94%', label: t('corporate.trust.satisfaction') }
    ]}
  />

  <StatsBanner
    title={t('corporate.stats.title')}
    subtitle={t('corporate.stats.subtitle')}
    stats={[
      { value: '87%', label: t('corporate.stats.collaboration'), trend: 'up', trendValue: '+23%' },
      { value: '3x', label: t('corporate.stats.speed'), trend: 'up' },
      { value: '25%', label: t('corporate.stats.productivity'), trend: 'up', trendValue: '+18%' },
      { value: '92%', label: t('corporate.stats.retention'), trend: 'up' }
    ]}
    layout="grid"
    theme="gradient"
  />

  <section class="section-padding bg-white">
    <div class="container-narrow">
      <SectionHeader
        eyebrow={t('corporate.challenges.eyebrow')}
        title={t('corporate.challenges.title')}
      />
      
      <div class="grid md:grid-cols-3 gap-8">
        <PremiumCard
          icon="🌍"
          title={t('corporate.ch1.title')}
          description={t('corporate.ch1.desc')}
          variant="navy"
          featured={false}
          metrics={[
            { label: t('corporate.metric.productivity'), value: '25%' }
          ]}
        />
        <PremiumCard
          icon="🤝"
          title={t('corporate.ch2.title')}
          description={t('corporate.ch2.desc')}
          variant="navy"
          featured={false}
          metrics={[
            { label: t('corporate.metric.expansion'), value: '-40%' }
          ]}
        />
        <PremiumCard
          icon="👥"
          title={t('corporate.ch3.title')}
          description={t('corporate.ch3.desc')}
          variant="navy"
          featured={false}
          metrics={[
            { label: t('corporate.metric.performance'), value: '-35%' }
          ]}
        />
      </div>
    </div>
  </section>

  <section class="section-padding gradient-subtle">
    <div class="container-narrow">
      <SectionHeader
        eyebrow={t('corporate.programs.eyebrow')}
        title={t('corporate.programs.title')}
      />
      
      <div class="grid md:grid-cols-3 gap-8">
        <PremiumCard
          icon="👔"
          title={t('corporate.prog1.title')}
          description={t('corporate.prog1.desc')}
          href={`/${lang}/consultation`}
          linkText={t('corporate.programs.learn')}
variant="blue"
  featured={true}
  featuredLabel={t('card.featured')}
  tags={[t('corporate.tag.c-suite'), t('corporate.tag.leadership')]}
        />
        <PremiumCard
          icon="📋"
          title={t('corporate.prog2.title')}
          description={t('corporate.prog2.desc')}
          href={`/${lang}/consultation`}
          linkText={t('corporate.programs.learn')}
          variant="purple"
          featured={false}
          tags={[t('corporate.tag.departments'), t('corporate.tag.teams')]}
        />
        <PremiumCard
          icon="🌐"
          title={t('corporate.prog3.title')}
          description={t('corporate.prog3.desc')}
          href={`/${lang}/consultation`}
          linkText={t('corporate.programs.learn')}
          variant="gold"
          featured={false}
          tags={[t('corporate.tag.workshops'), t('corporate.tag.cultural')]}
        />
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow">
      <SectionHeader
        eyebrow={t('corporate.structure.eyebrow')}
        title={t('corporate.structure.title')}
        description={t('corporate.structure.desc')}
      />
      
      <div class="mt-12 grid md:grid-cols-2 gap-8 items-center">
        <div class="structure-visual">
          <div class="structure-step">
            <div class="step-number">01</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step1.title')}</h3>
              <p class="step-desc">{t('corporate.step1.desc')}</p>
            </div>
          </div>
          
          <div class="structure-step">
            <div class="step-number">02</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step2.title')}</h3>
              <p class="step-desc">{t('corporate.step2.desc')}</p>
            </div>
          </div>
          
          <div class="structure-step">
            <div class="step-number">03</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step3.title')}</h3>
              <p class="step-desc">{t('corporate.step3.desc')}</p>
            </div>
          </div>
          
          <div class="structure-step">
            <div class="step-number">04</div>
            <div class="step-content">
              <h3 class="step-title">{t('corporate.step4.title')}</h3>
              <p class="step-desc">{t('corporate.step4.desc')}</p>
            </div>
          </div>
        </div>
        
        <div class="structure-benefits">
          <div class="benefit-card">
<svg class="benefit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
            <h4>{t('corporate.benefit1.title')}</h4>
            <p>{t('corporate.benefit1.desc')}</p>
          </div>
          
          <div class="benefit-card">
<svg class="benefit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
    </svg>
            <h4>{t('corporate.benefit2.title')}</h4>
            <p>{t('corporate.benefit2.desc')}</p>
          </div>
          
          <div class="benefit-card">
<svg class="benefit-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
    </svg>
            <h4>{t('corporate.benefit3.title')}</h4>
            <p>{t('corporate.benefit3.desc')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding gradient-premium">
    <div class="container-narrow">
      <SectionHeader
        eyebrow={t('corporate.solution.eyebrow')}
        title={t('corporate.solution.title')}
      />
      
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="solution-content">
          <div class="solution-point">
<div class="point-icon blue">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </div>
            <div class="point-content">
              <h3>{t('corporate.solution1.title')}</h3>
              <p>{t('corporate.solution1.desc')}</p>
            </div>
          </div>
          
          <div class="solution-point">
<div class="point-icon purple">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 0v3m0 0v-3m0 0h3m-3 0h-3m12 0a2 2 0 100-4m0 4a2 2 0 110-4m0 0v3m0 0v-3m0 0h3m-3 0h-3" />
      </svg>
            </div>
            <div class="point-content">
              <h3>{t('corporate.solution2.title')}</h3>
              <p>{t('corporate.solution2.desc')}</p>
            </div>
          </div>
          
          <div class="solution-point">
<div class="point-icon gold">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
      </svg>
            </div>
            <div class="point-content">
              <h3>{t('corporate.solution3.title')}</h3>
              <p>{t('corporate.solution3.desc')}</p>
            </div>
          </div>
        </div>
        
        <div class="solution-visual">
          <div class="visual-card card-1">
            <div class="card-header">
              <div class="status-dot"></div>
              <span>{t('corporate.visual.active')}</span>
            </div>
            <div class="card-metric">
              <span class="metric-value">+127%</span>
              <span class="metric-label">{t('corporate.visual.engagement')}</span>
            </div>
          </div>
          
          <div class="visual-card card-2">
            <div class="card-header">
              <div class="status-dot success"></div>
              <span>{t('corporate.visual.completed')}</span>
            </div>
            <div class="card-metric">
              <span class="metric-value">2,847</span>
              <span class="metric-label">{t('corporate.visual.professionals')}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow">
      <SectionHeader
        eyebrow={t('corporate.cases.eyebrow')}
        title={t('corporate.cases.title')}
      />
      
      <div class="grid md:grid-cols-3 gap-8">
        <PremiumCard
          icon="🏢"
          title={t('corporate.case1.company')}
          description={t('corporate.case1.desc')}
          variant="blue"
          metrics={[
            { label: t('corporate.case.metric1'), value: '+45%' },
            { label: t('corporate.case.metric2'), value: t('corporate.case1.duration') }
          ]}
        />
        <PremiumCard
          icon="🏭"
          title={t('corporate.case2.company')}
          description={t('corporate.case2.desc')}
          variant="purple"
          metrics={[
            { label: t('corporate.case.metric1'), value: '+62%' },
            { label: t('corporate.case.metric2'), value: t('corporate.case2.duration') }
          ]}
        />
        <PremiumCard
          icon="🏦"
          title={t('corporate.case3.company')}
          description={t('corporate.case3.desc')}
          variant="gold"
          metrics={[
            { label: t('corporate.case.metric1'), value: '+78%' },
            { label: t('corporate.case.metric2'), value: t('corporate.case3.duration') }
          ]}
        />
      </div>
    </div>
  </section>

  <CTABanner
    title={t('corporate.cta.title')}
    ctaText={t('corporate.cta.btn')}
    ctaHref={`/${lang}/consultation`}
  />
  
  <Footer />
</Layout>

<style>
  .gradient-subtle {
    background: linear-gradient(180deg, rgba(249, 250, 252, 1) 0%, rgba(255, 255, 255, 1) 100%);
  }

  .gradient-premium {
    background: linear-gradient(135deg, rgba(82, 138, 237, 0.03) 0%, rgba(166, 123, 244, 0.03) 100%);
  }

  .structure-visual {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .structure-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 1.5rem;
    background: white;
    border-radius: 1rem;
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 300ms var(--ease-out-expo);
  }

  .structure-step:hover {
    transform: translateX(8px);
    border-color: var(--color-brand-blue);
    box-shadow: 0 8px 24px rgba(82, 138, 237, 0.12);
  }

  .step-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-brand-blue);
    line-height: 1;
    opacity: 0.3;
  }

  .step-content {
    flex: 1;
  }

  .step-title {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-brand-navy);
    margin: 0 0 0.5rem;
  }

  .step-desc {
    font-size: 0.9375rem;
    color: var(--color-slate-light);
    line-height: 1.6;
    margin: 0;
  }

  .structure-benefits {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .benefit-card {
    padding: 1.5rem;
    background: linear-gradient(135deg, rgba(82, 138, 237, 0.04), rgba(166, 123, 244, 0.04));
    border-radius: 1rem;
    border: 1px solid rgba(82, 138, 237, 0.1);
  }

  .benefit-icon {
    width: 2.5rem;
    height: 2.5rem;
    color: var(--color-brand-blue);
    margin-bottom: 1rem;
  }

  .benefit-card h4 {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-brand-navy);
    margin: 0 0 0.5rem;
  }

  .benefit-card p {
    font-size: 0.9375rem;
    color: var(--color-slate-light);
    line-height: 1.6;
    margin: 0;
  }

  .solution-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .solution-point {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .point-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .point-icon svg {
    width: 1.75rem;
    height: 1.75rem;
  }

  .point-icon.blue {
    background: linear-gradient(135deg, var(--color-brand-blue-50), var(--color-brand-blue-100));
    color: var(--color-brand-blue);
  }

  .point-icon.purple {
    background: linear-gradient(135deg, var(--color-brand-purple-50), var(--color-brand-purple-100));
    color: var(--color-brand-purple);
  }

  .point-icon.gold {
    background: linear-gradient(135deg, var(--color-brand-gold-50), var(--color-brand-gold-100));
    color: var(--color-brand-gold);
  }

  .point-content h3 {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-brand-navy);
    margin: 0 0 0.5rem;
  }

  .point-content p {
    font-size: 1rem;
    color: var(--color-slate-light);
    line-height: 1.7;
    margin: 0;
  }

  .solution-visual {
    position: relative;
    height: 400px;
  }

  .visual-card {
    position: absolute;
    background: white;
    border-radius: 1rem;
    padding: 1.5rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.1);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .card-1 {
    top: 0;
    right: 0;
    width: 280px;
  }

  .card-2 {
    bottom: 0;
    left: 20%;
    width: 300px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    color: var(--color-gray-600);
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-brand-blue);
    animation: pulse 2s ease-in-out infinite;
  }

  .status-dot.success {
    background: #10b981;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .card-metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metric-value {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-brand-navy);
    line-height: 1;
  }

  .metric-label {
    font-size: 0.875rem;
    color: var(--color-gray-500);
  }

  @media (max-width: 768px) {
    .structure-step,
    .solution-point {
      flex-direction: column;
      gap: 1rem;
    }

    .solution-visual {
      height: 300px;
      margin-top: 2rem;
    }

    .visual-card {
      position: relative;
      width: 100%;
      margin-bottom: 1rem;
    }

    .card-1,
    .card-2 {
      position: relative;
      top: auto;
      right: auto;
      bottom: auto;
      left: auto;
    }
  }
</style>
