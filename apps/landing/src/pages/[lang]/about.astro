---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCard from '../../components/PremiumCard.astro';
import StatsBanner from '../../components/StatsBanner.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import MotionReveal from '../../components/MotionReveal.tsx';
import StaggerContainer, { StaggerItem } from '../../components/StaggerContainer.tsx';
import MotionCard from '../../components/MotionCard.tsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const values = [
  {
    icon: 'users',
    iconType: 'lucide' as const,
    title: t('about.val1.title'),
    description: t('about.val1.desc'),
    tags: [t('about.val1.title')],
    variant: 'blue' as const,
    size: 'lg' as const,
  },
  {
    icon: 'globe',
    iconType: 'lucide' as const,
    title: t('about.val2.title'),
    description: t('about.val2.desc'),
    tags: [t('about.val2.title')],
    variant: 'purple' as const,
    size: 'lg' as const,
  },
  {
    icon: 'globe-2',
    iconType: 'lucide' as const,
    title: t('about.val3.title'),
    description: t('about.val3.desc'),
    tags: [t('about.val3.title')],
    variant: 'gold' as const,
    size: 'lg' as const,
  },
  {
    icon: 'trending-up',
    iconType: 'lucide' as const,
    title: t('about.val4.title'),
    description: t('about.val4.desc'),
    tags: [t('about.val4.title')],
    variant: 'orange' as const,
    size: 'lg' as const,
  },
];

const numbers = [
  { value: t('about.num1.value'), label: t('about.num1.label'), trend: 'neutral' as const },
  { value: t('about.num2.value'), label: t('about.num2.label'), trend: 'up' as const, trendValue: '+3' },
  { value: t('about.num3.value'), label: t('about.num3.label'), trend: 'up' as const, trendValue: '+40%' },
  { value: t('about.num4.value'), label: t('about.num4.label'), trend: 'up' as const },
];

const team = [
  { name: 'Jimmy Ramires', photo: '/images/web/Jimmy.png', role: t('about.team.role1') },
  { name: 'Alissa Lechleitner', photo: '/images/web/Alissa.png', role: t('about.team.role2') },
  { name: 'Laura Gomes', photo: '/images/web/Laura.png', role: t('about.team.role3') },
  { name: 'Thayline Candatti', photo: '/images/web/Thayline.png', role: t('about.team.role4') },
  { name: 'Xiomara Ramires', photo: '/images/web/Xiomara.png', role: t('about.team.role5') },
  { name: 'Cristian', photo: '/images/web/Cristian.png', role: t('about.team.role6') },
];

const trustIndicators = [
  { value: t('about.num3.value'), label: t('about.num3.label') },
  { value: t('about.num2.value'), label: t('about.num2.label') },
  { value: t('about.num4.value'), label: t('about.num4.label') },
];
---

<Layout title={t('about.meta.title')} description={t('about.meta.desc')} lang={lang}>
  <Navbar />

  <div class="about-page">
  <PremiumHero
    eyebrow={t('about.hero.eyebrow')}
    title={t('about.hero.title')}
    subtitle={t('about.hero.subtitle')}
    ctaPrimary={{ text: t('nav.consultation'), href: `/${lang}/consultation` }}
    ctaSecondary={{ text: t('about.story.label'), href: '#story' }}
    alignment="center"
    theme="gradient"
    trustIndicators={trustIndicators}
  />

  <section id="story" class="section-padding bg-white about-story-section">
    <div class="about-story-dots"></div>
    <div class="about-story-container">
      <SectionHeader
        eyebrow={t('about.story.label')}
        title={t('about.story.title')}
      />
      <div class="story-grid">
        <MotionReveal client:visible direction="left" delay={0.1}>
          <div class="story-visual">
            <div class="story-image-wrapper">
              <div class="story-gradient-orb"></div>
              <div class="story-content-block">
                <div class="story-year">{t('about.num1.value')}</div>
                <div class="story-year-label">{t('about.num1.label')}</div>
              </div>
              <div class="story-decorative-line"></div>
            </div>
          </div>
        </MotionReveal>
        <MotionReveal client:visible direction="right" delay={0.2}>
          <div class="story-text">
            <p class="story-paragraph">{t('about.story.p1')}</p>
            <p class="story-paragraph">{t('about.story.p2')}</p>
            <p class="story-paragraph">{t('about.story.p3')}</p>
          </div>
        </MotionReveal>
      </div>
    </div>
  </section>

  <section class="section-padding gradient-hero about-values-section">
    <div class="about-values-orb about-values-orb-1"></div>
    <div class="about-values-orb about-values-orb-2"></div>
    <div class="container-wide">
      <SectionHeader
        eyebrow={t('about.values.label')}
        title={t('about.values.title')}
        light={true}
      />
      <StaggerContainer className="grid md:grid-cols-2 gap-6" client:visible>
        {values.slice(0, 2).map((v) => (
          <StaggerItem>
            <MotionCard client:visible>
              <PremiumCard
                icon={v.icon}
                iconType={v.iconType}
                title={v.title}
                description={v.description}
                tags={v.tags}
                variant={v.variant}
                size={v.size}
              />
            </MotionCard>
          </StaggerItem>
        ))}
      </StaggerContainer>
      <StaggerContainer className="grid md:grid-cols-2 gap-6 mt-6" client:visible>
        {values.slice(2).map((v) => (
          <StaggerItem>
            <MotionCard client:visible>
              <PremiumCard
                icon={v.icon}
                iconType={v.iconType}
                title={v.title}
                description={v.description}
                tags={v.tags}
                variant={v.variant}
                size={v.size}
              />
            </MotionCard>
          </StaggerItem>
        ))}
      </StaggerContainer>
    </div>
  </section>

  <StatsBanner
    stats={numbers}
    theme="gradient"
    title={t('about.numbers.title')}
  />

  <section class="section-padding bg-white about-team-section">
    <div class="container-wide">
      <SectionHeader
        eyebrow={t('about.team.label')}
        title={t('about.team.title')}
        description={t('about.team.subtitle')}
      />
      <StaggerContainer className="team-grid" client:visible>
        {team.map((member) => (
          <StaggerItem>
            <MotionCard client:visible>
              <div class="team-card">
                <div class="team-photo-wrapper">
                  <div class="team-photo-ring"></div>
                  <img
                    src={member.photo}
                    alt={member.name}
                    class="team-photo"
                    loading="lazy"
                  />
                </div>
                <div class="team-info">
                  <h3 class="team-name">{member.name}</h3>
                  <p class="team-role">{member.role}</p>
                </div>
              </div>
            </MotionCard>
          </StaggerItem>
        ))}
      </StaggerContainer>
    </div>
  </section>

  <section class="about-cta-wrapper">
    <PremiumCTABanner
      title={t('about.cta.title')}
      description={t('about.cta.subtitle')}
      primaryCTA={{ text: t('nav.consultation'), href: `/${lang}/consultation` }}
      variant="gradient"
        trustBadges={[
          { icon: 'check', iconType: 'lucide' as const, label: t('about.num4.label') },
          { icon: 'globe', iconType: 'lucide' as const, label: t('about.num2.label') },
          { icon: 'trending-up', iconType: 'lucide' as const, label: t('about.num3.label') },
        ]}
    />
  </section>

  <Footer />
  </div>
</Layout>

<style>
.about-story-container {
max-width: 1200px;
margin: 0 auto;
padding: 0 1.5rem;
}

.about-cta-wrapper {
padding: 0 1.5rem;
max-width: 1200px;
margin: 0 auto;
}

.about-story-section {
position: relative;
overflow: hidden;
}

.about-story-dots {
position: absolute;
inset: 0;
background-image: radial-gradient(circle, rgba(82, 138, 237, 0.06) 1px, transparent 1px);
background-size: 32px 32px;
pointer-events: none;
}

.about-values-section {
position: relative;
overflow: hidden;
}

.about-values-orb {
position: absolute;
border-radius: 50%;
filter: blur(100px);
pointer-events: none;
}

.about-values-orb-1 {
top: -15%;
right: -10%;
width: 350px;
height: 350px;
background: var(--color-brand-gold);
opacity: 0.12;
}

.about-values-orb-2 {
bottom: -10%;
left: -8%;
width: 300px;
height: 300px;
background: var(--color-brand-purple);
opacity: 0.1;
}

.about-team-section {
position: relative;
}

.story-grid {
display: grid;
grid-template-columns: 1fr 1.5fr;
gap: 4rem;
align-items: center;
}

.story-visual {
display: flex;
justify-content: center;
}

.story-image-wrapper {
  position: relative;
  max-width: 280px;
  width: 100%;
  aspect-ratio: 280 / 340;
border-radius: 1.5rem;
background: linear-gradient(145deg, var(--color-brand-navy), var(--color-brand-indigo));
display: flex;
flex-direction: column;
align-items: center;
justify-content: center;
overflow: hidden;
box-shadow: 0 30px 70px rgba(52, 53, 79, 0.2);
}

.story-gradient-orb {
position: absolute;
top: -30%;
right: -20%;
width: 200px;
height: 200px;
border-radius: 50%;
background: var(--color-brand-gold);
filter: blur(80px);
opacity: 0.25;
pointer-events: none;
}

.story-content-block {
position: relative;
z-index: 2;
text-align: center;
}

.story-year {
font-family: var(--font-heading);
font-size: 5rem;
font-weight: 700;
color: var(--color-brand-gold);
line-height: 1;
text-shadow: 0 0 40px rgba(254, 187, 55, 0.3);
}

.story-year-label {
font-size: 0.875rem;
color: rgba(255, 255, 255, 0.7);
text-transform: uppercase;
letter-spacing: 0.1em;
font-weight: 600;
margin-top: 0.5rem;
}

.story-decorative-line {
position: absolute;
bottom: 2rem;
left: 50%;
transform: translateX(-50%);
width: 40px;
height: 2px;
background: linear-gradient(90deg, transparent, var(--color-brand-gold), transparent);
}

.story-text {
display: flex;
flex-direction: column;
gap: 1.5rem;
}

.story-paragraph {
font-size: 1.125rem;
color: var(--color-slate-light);
line-height: 1.8;
margin: 0;
}

.team-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 2rem;
}

.team-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2.5rem 2rem;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 1.25rem;
  border: 1px solid rgba(82, 138, 237, 0.15);
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.08);
  transition: all 400ms var(--ease-out-expo);
  position: relative;
  overflow: hidden;
}

.team-card::before {
content: '';
position: absolute;
inset: 0;
background: linear-gradient(135deg, rgba(82, 138, 237, 0.02), rgba(166, 123, 244, 0.02));
opacity: 0;
transition: opacity 400ms var(--ease-out-expo);
}

.team-card:hover {
transform: translateY(-6px);
box-shadow: 0 20px 50px rgba(0, 0, 0, 0.08), 0 8px 20px rgba(0, 0, 0, 0.04);
border-color: rgba(82, 138, 237, 0.15);
}

.team-card:hover::before {
opacity: 1;
}

.team-photo-wrapper {
position: relative;
width: 7rem;
height: 7rem;
margin-bottom: 1.5rem;
}

.team-photo-ring {
position: absolute;
inset: -4px;
border-radius: 50%;
background: conic-gradient(
var(--color-brand-blue),
var(--color-brand-purple),
var(--color-brand-gold),
var(--color-brand-blue)
);
opacity: 0;
transition: opacity 400ms var(--ease-out-expo);
}

.team-card:hover .team-photo-ring {
opacity: 1;
animation: spin 6s linear infinite;
}

@keyframes spin {
to { transform: rotate(360deg); }
}

.team-photo {
position: relative;
z-index: 2;
width: 100%;
height: 100%;
border-radius: 50%;
object-fit: cover;
border: 3px solid var(--color-brand-blue-100);
transition: border-color 300ms var(--ease-out-expo);
}

.team-card:hover .team-photo {
border-color: transparent;
}

.team-info {
text-align: center;
position: relative;
z-index: 2;
}

.team-name {
font-family: var(--font-heading);
font-size: 1.125rem;
font-weight: 600;
color: var(--color-brand-navy);
margin: 0;
}

.team-role {
font-size: 0.875rem;
color: var(--color-brand-blue);
font-weight: 500;
margin: 0.375rem 0 0;
}

@media (max-width: 1024px) {
.story-grid {
grid-template-columns: 1fr;
text-align: center;
}
.story-text {
align-items: center;
}
.team-grid {
grid-template-columns: repeat(2, 1fr);
}
}

@media (max-width: 640px) {
.team-grid {
grid-template-columns: 1fr;
max-width: 400px;
margin: 0 auto;
}
.story-image-wrapper {
width: 220px;
height: 270px;
}
.story-year {
font-size: 3.5rem;
}
}

@media (prefers-reduced-motion: reduce) {
  .team-card:hover .team-photo-ring {
    animation: none;
  }
}
</style>
