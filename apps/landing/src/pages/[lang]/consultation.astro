---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import ConsultationForm from '../../components/ConsultationForm';
import MotionReveal from '../../components/MotionReveal';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const trustIndicators = [
  { value: '500+', label: t('consultation.trust.clients') },
  { value: '98%', label: t('consultation.trust.satisfaction') },
  { value: '24h', label: t('consultation.trust.response') },
];

const benefits = [
  { icon: 'target', iconType: 'lucide' as const, title: t('consultation.benefit1.title'), description: t('consultation.benefit1.desc') },
  { icon: 'bar-chart', iconType: 'lucide' as const, title: t('consultation.benefit2.title'), description: t('consultation.benefit2.desc') },
  { icon: 'users', iconType: 'lucide' as const, title: t('consultation.benefit3.title'), description: t('consultation.benefit3.desc') },
];
---

<Layout title={t('consultation.meta.title')} description={t('consultation.meta.desc')} lang={lang}>
  <Navbar />

  <div class="consultation-page">
    <PremiumHero
      eyebrow={t('consultation.hero.eyebrow')}
      title={t('consultation.hero.title')}
      subtitle={t('consultation.hero.subtitle')}
      ctaPrimary={{ text: t('consultation.hero.cta'), href: '#consultation-form' }}
      alignment="center"
      theme="gradient"
      trustIndicators={trustIndicators}
    />

    <section class="section-padding relative overflow-hidden">
      <div class="bg-dots"></div>
      <div class="consultation-orb consultation-orb--blue"></div>
      <div class="consultation-orb consultation-orb--purple"></div>
      <div class="container-narrow max-w-6xl relative">
        <MotionReveal client:visible direction="up" delay={0.1} duration={0.7}>
          <ConsultationForm
            client:visible
            t={t as (key: string) => string}
            lang={lang}
            benefits={benefits}
          />
        </MotionReveal>
      </div>
    </section>

    <PremiumCTABanner
      title={t('consultation.cta.title')}
      description={t('consultation.cta.subtitle')}
      primaryCTA={{ text: t('nav.consultation'), href: `/${lang}/consultation` }}
      secondaryCTA={{ text: t('nav.methodology'), href: `/${lang}/methodology` }}
      variant="gradient"
      trustBadges={[
        { icon: 'target', iconType: 'lucide' as const, label: t('consultation.trust.clients') },
        { icon: 'star', iconType: 'lucide' as const, label: t('consultation.trust.satisfaction') },
      ]}
    />
  </div>

  <Footer />
</Layout>

<style>
  .consultation-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
    pointer-events: none;
  }

  .consultation-orb--blue {
    width: 300px;
    height: 300px;
    background: var(--color-brand-blue);
    top: 10%;
    left: -5%;
  }

  .consultation-orb--purple {
    width: 250px;
    height: 250px;
    background: var(--color-brand-purple);
    bottom: 10%;
    right: -5%;
  }
</style>
