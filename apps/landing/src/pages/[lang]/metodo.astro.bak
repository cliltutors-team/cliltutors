// Page title per language
const pageTitles: Record<string, string> = {
    pt: "Cliltutors — Método simples, humano e eficaz",
    en: "Cliltutors — Simple, human, and effective method",
    es: "Cliltutors — Método simple, humano y eficaz",
};
---

<!doctype html>
<html lang={lang === "pt" ? "pt-BR" : lang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={pageTitles[lang]} />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, maximum-scale=5"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{pageTitles[lang]}</title>

        {cssFiles.map((f) => <link rel="stylesheet" href={f} />)}

        <style is:global>
            html,
            body {
                margin: 0;
                padding: 0;
                overflow-x: hidden;
                overflow-y: auto;
                background: #fbfcff;
                width: 100%;
            }

            .ct-section {
                width: 100%;
                overflow: hidden;
                position: relative;
            }

            .ct-canva-slide {
                position: relative;
                overflow: hidden;
                width: 100%;
            }

            .ct-canva-slide ._14BoqA {
                position: absolute;
                top: 0;
                left: 0;
                width: 1366px;
                transform-origin: top left;
            }

            .ct-canva-slide img {
                max-width: none;
            }
        </style>
    </head>
    <body>
        {
            sections.map((sec, i) => {
                const slideHtml = translatedSlides[i] || "";
                return (
                    <section
                        class="ct-section"
                        id={sec.id}
                        style={`background: ${sec.bg}`}
                    >
                        <div class="ct-canva-slide" data-slide-index={i}>
                            <Fragment set:html={slideHtml} />
                        </div>
                    </section>
                );
            })
        }

        <script is:inline>
            (function () {
                function scaleSlides() {
                    document
                        .querySelectorAll(".ct-canva-slide")
                        .forEach(function (wrapper) {
                            var canvas = wrapper.querySelector("._14BoqA");
                            if (!canvas) return;
                            var canvasW =
                                parseFloat(canvas.style.width) || 1366;
                            var canvasH =
                                parseFloat(canvas.style.height) || 700;
                            var containerW = wrapper.clientWidth;
                            var scale = containerW / canvasW;
                            canvas.style.transform = "scale(" + scale + ")";
                            canvas.style.transformOrigin = "top left";
                            wrapper.style.height = canvasH * scale + "px";
                        });
                }
                if (document.readyState === "loading") {
                    document.addEventListener("DOMContentLoaded", scaleSlides);
                } else {
                    scaleSlides();
                }
                window.addEventListener("resize", scaleSlides);
            })();
        </script>
    </body>
</html>
