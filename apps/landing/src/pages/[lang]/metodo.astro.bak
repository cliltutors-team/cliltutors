    [
        />\s*Plataforma\s+Google\s+Workspace\s+for\s+Education\s*<\/span>/g,
        `>${t("benefits.b2").split("|")[0].trim()}</span>`,
    ],
    [
        />\s*Organização\s+via\s+Google\s+Classroom\s*<\/span>/g,
        `>${t("benefits.b2").split("|")[1]?.trim() || "Google Classroom"}</span>`,
