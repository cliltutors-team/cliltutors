        `>${lang === "en" ? "or bank transfer" : lang === "es" ? "o transferencia" : "ou transferência"}</span>`,
    ],

    // ── FOOTER desc ──
    [
        />\s*Agende\s+uma\s+aula\s+experimental\s*<\/span>/g,
        `>${lang === "en" ? "Schedule a free trial class and" : lang === "es" ? "Agenda una clase experimental" : "Agende uma aula experimental"}</span>`,
    ],
    [
        />\s*gratuita\s+e\s+conheça\s+nosso\s+método,\s*<\/span>/g,
        `>${lang === "en" ? "get to know our simple and" : lang === "es" ? "gratuita y conoce nuestro método," : "gratuita e conheça nosso método,"}</span>`,
    ],
    [
        />\s*simples\s+e\s+eficaz\.\s*<\/span>/g,
        `>${lang === "en" ? "effective method." : lang === "es" ? "simple y eficaz." : "simples e eficaz."}</span>`,
    ],

    // ── CLIL body text ──
    [
        />\s*O\s+método\s+CLIL\s+\(Content\s+and\s*<\/span>/g,
        `>${lang === "en" ? "The CLIL (Content and" : lang === "es" ? "El método CLIL (Content and" : "O método CLIL (Content and"}</span>`,
    ],
    [
        />\s*Language\s+Integrated\s+Learning\)\s*<\/span>/g,
        `>${lang === "en" ? "Language Integrated Learning)" : lang === "es" ? "Language Integrated Learning)" : "Language Integrated Learning)"}</span>`,
    ],
    [
        />\s*Content\s+Language\s+Integrated\s+Learning\s*<\/span>/g,
        `>${t("clil.expansion")}</span>`,
    ],
];

// Apply all translations
function applyTranslations(html: string): string {
    let result = html;

    // Replace lang attribute
    result = result.replace(
        /lang="pt-BR"/g,
        `lang="${lang === "pt" ? "pt-BR" : lang === "es" ? "es" : "en"}"`,
    );

    // Apply exact string replacements first
    for (const [from, to] of spanReplacements) {
        if (from !== to) {
            result = result.replaceAll(from, to);
        }
    }

    // Apply regex replacements
    for (const [pattern, replacement] of regexReplacements) {
        result = result.replace(pattern, replacement);
    }

    return result;
}

const translatedSlides = rawSlides.map((s) => applyTranslations(s));

// Section metadata per slide
const sections = [
    { id: "hero", bg: "#ffffff", label: "Hero" },
    { id: "services", bg: "#F9FAFB", label: "Services" },
    { id: "about", bg: "#ffffff", label: "About" },
    { id: "clil", bg: "#ffffff", label: "CLIL Method" },
    { id: "tutors", bg: "#36DE6B", label: "Tutors" },
    { id: "corporate", bg: "#34354F", label: "Corporate" },
    { id: "testimonials", bg: "#FDD122", label: "Testimonials" },
    { id: "pricing", bg: "#ffffff", label: "Pricing" },
    { id: "footer", bg: "#36DE6B", label: "Footer CTA" },
];

// CSS files from the Canva embed
const cssFiles = [
    "/canva-css/font-_fb-s-9ebe5bfcf37fcce0d8e45969bcd8e089.css",
