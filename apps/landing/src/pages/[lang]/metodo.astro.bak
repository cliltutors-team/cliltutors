        `>${lang === "en" ? "personalized plans for those looking" : lang === "es" ? "personalizados para quienes buscan" : "personalizados para quem busca"}</span>`,
    ],
    [
        />\s*desenvolver\s+fluência\s+prática\s+com\s*<\/span>/g,
