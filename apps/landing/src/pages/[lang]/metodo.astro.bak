        />\s*5%\s+de\s+desconto\s+via\s+Pix\s*<\/span>/g,
        `>${lang === "en" ? "5% discount via Pix" : lang === "es" ? "5% de descuento vía Pix" : "5% de desconto via Pix"}</span>`,
    ],
    [
