---
import type { GetStaticPaths } from "astro";
import { readFileSync } from "node:fs";
import { useTranslations } from "../../i18n/utils";
import { ui } from "../../i18n/ui";

export const getStaticPaths = (() => {
    return [
        { params: { lang: "pt" } },
        { params: { lang: "en" } },
        { params: { lang: "es" } },
    ];
}) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: keyof typeof ui };
const t = useTranslations(lang);

// ── Helpers ──────────────────────────────────────────────────────────────────
function stripTags(s: string): string {
    return s
        .replace(/<br\s*\/?>/gi, "\n")
        .replace(/<[^>]+>/g, "")
        .trim();
}

// ── Read the Canva embed ─────────────────────────────────────────────────────
const embedPath = new URL("../metodo.astro", import.meta.url).pathname;
const embedSource = readFileSync(embedPath, "utf-8");

// ── Extract the <body> content ───────────────────────────────────────────────
const bodyStart = embedSource.indexOf("<body");
const bodyEnd = embedSource.indexOf("</body>");
const bodyHtml =
    bodyStart >= 0 && bodyEnd >= 0
        ? embedSource.substring(
              embedSource.indexOf(">", bodyStart) + 1,
              bodyEnd,
          )
        : "";

// ── Extract slide HTML blocks by splitting on data-page-id ───────────────────
function extractSlides(html: string): string[] {
    const slides: string[] = [];
    const re = /data-page-id="[^"]+"/g;
    let m;
    const positions: number[] = [];
    while ((m = re.exec(html)) !== null) {
        const divStart = html.lastIndexOf("<div", m.index);
        positions.push(divStart);
    }
    for (let i = 0; i < positions.length; i++) {
        const from = positions[i];
        const to = i + 1 < positions.length ? positions[i + 1] : html.length;
        slides.push(html.substring(from, to));
    }
    return slides;
}

const rawSlides = extractSlides(bodyHtml);

// ══════════════════════════════════════════════════════════════════════════════
// i18n TEXT REPLACEMENT
// ══════════════════════════════════════════════════════════════════════════════
// Strategy: The Canva HTML stores text inside <span class="a_GcMg"> elements.
// Text is split at the SPAN level, so we replace the exact text content that
// appears between >…</span>.
//
// We build a map of Portuguese span-level text fragments → translated text.
// Each entry maps the EXACT text as it appears inside a specific span.
// ══════════════════════════════════════════════════════════════════════════════

// Helper: escape special HTML entities as they appear in source
function esc(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

// Build replacement pairs: [Portuguese span text, translated text]
// These match the EXACT text content of individual <span class="a_GcMg"> elements
const spanReplacements: [string, string][] = [
    // ── SLIDE 1: HERO ──
    // Title: split across 2 spans in 2 <p> elements
    [
        ">Método</span>",
        `>${stripTags(t("hero.title")).split("\n")[0] || "Método"}</span>`,
    ],
    [
        ">simples, humano<br>e eficaz.</span>",
        `>${stripTags(t("hero.title")).split("\n").slice(1).join("<br>") || "simples, humano<br>e eficaz."}</span>`,
    ],

    // Subtitle: split across 4 spans
    [
        ">Aprenda o que vai te impulsionar</span>",
        `>${
            stripTags(t("hero.subtitle"))
                .replace(/ método CLIL\./, "")
                .split("\n")[0] || "Aprenda o que vai te impulsionar"
        }</span>`,
    ],
    [
        ">com aulas ao vivo, professores</span>",
        `>${
            stripTags(t("hero.subtitle"))
                .replace(/ método CLIL\./, "")
                .split("\n")[1] || "com aulas ao vivo, professores"
        }</span>`,
    ],
    [
        ">nativos e o </span>",
        `>${
            stripTags(t("hero.subtitle"))
                .replace(/ método CLIL\./, "")
                .split("\n")[2] || "nativos e o "
        }</span>`,
    ],
    [
        ">método CLIL.</span>",
        `>${lang === "pt" ? "método CLIL." : lang === "en" ? "CLIL method." : "método CLIL."}</span>`,
    ],

    // CTA button
    [
        ">Agende sua</span>",
        `>${stripTags(t("hero.cta.book")).split("\n")[0]}</span>`,
    ],
    [
        ">aula gratuíta</span>",
        `>${stripTags(t("hero.cta.book")).split("\n")[1] || stripTags(t("hero.cta.book")).split("\n")[0]}</span>`,
    ],
    [
        ">aula gratuita</span>",
        `>${stripTags(t("hero.cta.book")).split("\n")[1] || stripTags(t("hero.cta.book")).split("\n")[0]}</span>`,
    ],

    // Nav links
    [">Sobre nós</span>", `>${t("nav.about")}</span>`],
    [">Curso pra você</span>", `>${t("nav.course")}</span>`],
    [">Curso prara empresas</span>", `>${t("nav.business")}</span>`],
    [">Curso para empresas</span>", `>${t("nav.business")}</span>`],
    [">Coaching Profissional</span>", `>${t("nav.coaching")}</span>`],

    // ── SLIDE 2: SERVICES (3 pills) ──
    // Section title
    [
        ">Comece pela sua necessidade</span>",
        `>${stripTags(t("about.title"))}</span>`,
    ],

    // Sub-description
    // Features pill #1: "Idiomas com o Método CLIL"
    // This appears across multiple spans with whitespace:

    // Features pill #2: "Mentoria em Ciências e Exatas (STEM)"
    // Features pill #3: "Coaching Profissional" (different from nav)

    // Language pills
    [">PORTUGUÊS</span>", `>${t("start.portuguese")}</span>`],
    [">INGLÊS</span>", `>${t("start.english")}</span>`],
    [">ESPANHOL</span>", `>${t("start.spanish")}</span>`],
    [">NOVO</span>", `>${t("start.badge")}</span>`],

    // "Comece a aprender" CTA
    [">Comece a aprender</span>", `>${stripTags(t("start.title"))}</span>`],

    // ── SLIDE 3: ABOUT ──
    [
        ">Sobre a</span>",
        `>${lang === "pt" ? "Sobre a" : lang === "en" ? "About" : "Sobre"}</span>`,
    ],
    [">MISSÃO</span>", `>${t("about.mission.label")}</span>`],
    [">VISÃO</span>", `>${t("about.vision.label")}</span>`],

    // ── SLIDE 4: CLIL METHOD ──
    [">Isso é método CLIL!</span>", `>${stripTags(t("clil.subtitle"))}</span>`],
    [">espanhol</span>", `>${t("clil.lang1")}</span>`],
    [">inglês</span>", `>${t("clil.lang2")}</span>`],
    [">português</span>", `>${t("clil.lang3")}</span>`],
    [">Lets talk abaut!</span>", `>${stripTags(t("clil.bubble"))}</span>`],
    [">Lets talk about!</span>", `>${stripTags(t("clil.bubble"))}</span>`],

    // Tags
    [">Negócios e Carreira</span>", `>${stripTags(t("clil.tag1"))}</span>`],
    [">Tecnologia e Inovação</span>", `>${stripTags(t("clil.tag2"))}</span>`],
    [">Viagens e Cultura</span>", `>${stripTags(t("clil.tag3"))}</span>`],
    [">Exames e Certificações</span>", `>${stripTags(t("clil.tag4"))}</span>`],

    // ── SLIDE 5: TUTORS ──
    [">OS PROFESSORES DA CLILTUTORS</span>", `>${t("tutors.label")}</span>`],
    [
        ">Conheça nossos tutors!</span>",
        `>${stripTags(t("tutors.title"))}</span>`,
    ],
    [">Estude comigo →</span>", `>${t("tutors.btn")}</span>`],
    [">Estude comigo</span>", `>${t("tutors.btn").replace(" →", "")}</span>`],

    // ── SLIDE 6: CORPORATE ──
    [
        ">CONHEÇA NOSSA SOLUÇÃO DE INGLÊS CORPORATIVO</span>",
        `>${t("corp.label")}</span>`,
    ],

    // ── SLIDE 7: TESTIMONIALS ──
    [
        ">+400 MIL ALUNOS FLUENTES!</span>",
        `>${stripTags(t("test.label"))}</span>`,
    ],
    [">Depoimentos de alunos</span>", `>${stripTags(t("test.title"))}</span>`],

    // ── SLIDE 8: PRICING ──
    [">Plano Básico</span>", `>${t("pricing.p1.name")}</span>`],
    [">Plano Semi-Intensivo</span>", `>${t("pricing.p2.name")}</span>`],
    [">Plano Intensivo</span>", `>${t("pricing.p3.name")}</span>`],
    [">4 aulas/mês</span>", `>${t("pricing.p1.freq")}</span>`],
    [">8 aulas/mês</span>", `>${t("pricing.p2.freq")}</span>`],
    [">16 aulas/mês</span>", `>${t("pricing.p3.freq")}</span>`],
    [
        ">R$ 220,00</span>",
        `>${t("pricing.p1.price_month").replace(" mensal", "").replace(" monthly", "").replace(" mensual", "")}</span>`,
    ],
    [
        ">R$ 440,00</span>",
        `>${t("pricing.p2.price_month").replace(" mensal", "").replace(" monthly", "").replace(" mensual", "")}</span>`,
    ],
    [
        ">R$ 720,00</span>",
        `>${t("pricing.p3.price_month").replace(" mensal", "").replace(" monthly", "").replace(" mensual", "")}</span>`,
    ],
    [
        ">mensal</span>",
        `>${lang === "pt" ? "mensal" : lang === "en" ? "monthly" : "mensual"}</span>`,
    ],
    [
        ">semestral</span>",
        `>${lang === "pt" ? "semestral" : lang === "en" ? "semiannually" : "semestral"}</span>`,
    ],
    [
        ">R$ 1320,00</span>",
        `>${t("pricing.p1.price_sem").replace(" semestral", "").replace(" semiannually", "")}</span>`,
    ],
    [
        ">R$ 2640,00</span>",
        `>${t("pricing.p2.price_sem").replace(" semestral", "").replace(" semiannually", "")}</span>`,
    ],
    [
        ">R$ 4300,00</span>",
        `>${t("pricing.p3.price_sem").replace(" semestral", "").replace(" semiannually", "")}</span>`,
    ],

    // ── SLIDE 9: FOOTER CTA ──
    [">Começar Agora</span>", `>${stripTags(t("footer.cta"))}</span>`],
];

// For longer text fragments that span multiple words with whitespace variations,
// we use regex patterns that allow flexible whitespace matching
const regexReplacements: [RegExp, string][] = [
    // ── NAV LINKS (text split across lines with heavy whitespace) ──
    [/>\s*Sobre\s+nós\s*<\/span>/g, `>${t("nav.about")}</span>`],
    [/>\s*Curso\s+pra\s+você\s*<\/span>/g, `>${t("nav.course")}</span>`],
    [
        />\s*Curso\s+prara\s+empresas\s*<\/span>/g,
        `>${t("nav.business")}</span>`,
    ],
    [/>\s*Curso\s+para\s+empresas\s*<\/span>/g, `>${t("nav.business")}</span>`],

    // Hero subtitle spans with flexible whitespace
    [
        />\s*Aprenda\s+o\s+que\s+vai\s+te\s+impulsionar\s*<\/span>/g,
        `>${lang === "en" ? "Learn what will propel you forward" : lang === "es" ? "Aprende lo que te impulsará" : "Aprenda o que vai te impulsionar"}</span>`,
    ],
    [
        />\s*com\s+aulas\s+ao\s+vivo,\s+professores\s*<\/span>/g,
        `>${lang === "en" ? "with live classes, native teachers," : lang === "es" ? "con clases en vivo, profesores" : "com aulas ao vivo, professores"}</span>`,
    ],
    [
        />\s*nativos\s+e\s+o\s+<\/span>/g,
        `>${lang === "en" ? "and the " : lang === "es" ? "nativos y el " : "nativos e o "}</span>`,
    ],
    [
        />\s*método\s+CLIL\.\s*<\/span>/g,
        `>${lang === "en" ? "CLIL method." : "método CLIL."}</span>`,
    ],

    // Método title
    [
        />\s*Método\s*<\/span>/g,
        `>${lang === "en" ? "Simple, human" : lang === "es" ? "Método" : "Método"}</span>`,
    ],
    [
        />\s*simples,\s+humano\s*<br>\s*e\s+eficaz\.\s*<\/span>/g,
        `>${lang === "en" ? "and effective<br>method." : lang === "es" ? "simple, humano<br>y eficaz." : "simples, humano<br>e eficaz."}</span>`,
    ],

    // Agende sua / aula gratuíta
    [
        />\s*Agende\s+sua\s*<\/span>/g,
        `>${lang === "en" ? "Book your" : lang === "es" ? "Reserva tu" : "Agende sua"}</span>`,
    ],
    [
        />\s*aula\s+gratu[íi]ta\s*<\/span>/g,
        `>${lang === "en" ? "free trial" : lang === "es" ? "clase gratuita" : "aula gratuita"}</span>`,
    ],

    // Features — Idiomas com o / Método CLIL (spans in pill titles)
    [
        />\s*Idiomas\s*\n?\s*com\s+o\s*<br>\s*Método\s+CLIL\s*<\/span>/g,
        `>${stripTags(t("features.f1.title"))}</span>`,
    ],
    [
        />\s*Idiomas\s*\n?\s*com\s+o\s*<\/span>/g,
        `>${lang === "en" ? "Languages with the" : lang === "es" ? "Idiomas con el" : "Idiomas com o"}</span>`,
    ],

    // Mentoria em Ciências e Exatas (STEM) — spans with line breaks
    [
        />\s*Mentoria\s*\n?\s*em\s*<br>\s*Ciências\s+e\s+Exatas\s*<br>\s*\(STEM\)\s*<\/span>/g,
        `>${stripTags(t("features.f2.title"))}</span>`,
    ],
    [
        />\s*Mentoria\s*\n?\s*em\s*<\/span>/g,
        `>${lang === "en" ? "STEM" : lang === "es" ? "Mentoría en" : "Mentoria em"}</span>`,
    ],

    // Coaching Profissional (pill title, not nav)
    [
        />\s*Coaching\s*<br>\s*Profissional\s*<\/span>/g,
        `>${stripTags(t("features.f3.title"))}</span>`,
    ],
    [
        />\s*Coaching\s*\n?\s*Profissional\s*<\/span>/g,
        `>${stripTags(t("features.f3.title"))}</span>`,
    ],

    // Feature descriptions — these are multi-span with bold fragments
    // f1 desc: "Aprenda inglês, espanhol ou...português...enquanto explora temas reais..."
    [
        />\s*Aprenda\s*\n?\s*<\/span>/g,
        `>${lang === "en" ? "Learn " : lang === "es" ? "Aprende " : "Aprenda "}</span>`,
    ],
    [
        />\s*inglês,\s*espanhol\s+ou\s*<\/span>/g,
        `>${lang === "en" ? "English, Spanish or" : lang === "es" ? "inglés, español o" : "inglês, espanhol ou"}</span>`,
    ],
    [
        />\s*português\s*<\/span>(<span[^>]*>)\s*\n?\s*enquanto/g,
        `>${t("clil.lang3")}</span>$1 ${lang === "en" ? "while exploring real-world" : lang === "es" ? "mientras exploras temas" : "enquanto explora temas"}`,
    ],
    [
        />\s*enquanto\s+explora\s+temas\s*<br>\s*reais\s*—\s*\n?\s*tecnologia,\s+viagens,\s*<br>\s*negócios\s+ou\s*\n?\s*cultura\.\s*<\/span>/g,
        `>${lang === "en" ? "while exploring real-world topics — technology, travel, business, or culture." : lang === "es" ? "mientras exploras temas reales: tecnología, viajes, negocios o cultura." : "enquanto explora temas reais — tecnologia, viagens, negócios ou cultura."}</span>`,
    ],

    // f2 desc: "Professores especializados em Matemática, Física, Química e Biologia..."
    [
        />\s*Professores\s*\n?\s*especializados\s+em\s*<br>\s*<\/span>/g,
        `>${lang === "en" ? "Specialized teachers in " : lang === "es" ? "Profesores especializados en " : "Professores especializados em "}</span>`,
    ],
    [
        />\s*Matemática,\s*\n?\s*Física,\s+Química\s+e\s*<\/span>/g,
        `>${lang === "en" ? "Math, Physics, Chemistry and" : lang === "es" ? "Matemáticas, Física, Química y" : "Matemática, Física, Química e"}</span>`,
    ],
    [
        />\s*Biologia\s*\n?\s*<\/span>/g,
        `>${lang === "en" ? "Biology" : lang === "es" ? "Biología" : "Biologia"}</span>`,
    ],
    [
        />\s*que\s*\n?\s*tornam\s+o\s*<br>\s*aprendizado\s+mais\s+leve\s+e\s*<br>\s*eficiente\.\s*<\/span>/g,
        `>${lang === "en" ? "who make learning lighter and more efficient." : lang === "es" ? "que hacen el aprendizaje más ligero y eficiente." : "que tornam o aprendizado mais leve e eficiente."}</span>`,
    ],

    // f3 desc: "Encontros que ajudam você a construir um plano claro e motivador para o futuro."
    [
        />\s*Encontros\s+que\s+ajudam\s+você\s+a\s*<br>\s*<\/span>/g,
        `>${lang === "en" ? "Sessions that help you " : lang === "es" ? "Encuentros que te ayudan a " : "Encontros que ajudam você a "}</span>`,
    ],
    [
        />\s*construir\s+um\s+plano\s+claro\s+e\s*<\/span>/g,
        `>${lang === "en" ? "build a clear and motivating plan" : lang === "es" ? "construir un plan claro y motivador" : "construir um plano claro e"}</span>`,
    ],
    [
        />\s*motivador\s+para\s+o\s+futuro\.\s*<\/span>/g,
        `>${lang === "en" ? "for your future." : lang === "es" ? "para el futuro." : "motivador para o futuro."}</span>`,
    ],

    // About card subtitle
    [
        />\s*Comece\s+pela\s+sua\s+necessidade\s*<\/span>/g,
        `>${stripTags(t("about.title"))}</span>`,
    ],
    // About description (multi-line)
    [
        />\s*Cada\s+pessoa\s+aprende\s+de\s+um\s+jeito/g,
        `>${lang === "en" ? "Everyone learns differently" : lang === "es" ? "Cada persona aprende distinto" : "Cada pessoa aprende de um jeito"}`,
    ],

    // About card title: "Uma experiência global de aprendizado."
    [
        />\s*Uma\s*<br>\s*experiência\s*<br>\s*global\s+de\s*<br>\s*aprendizado\.\s*<\/span>/g,
        `>${stripTags(t("about.card.title")).replace(/\n/g, "<br>")}</span>`,
    ],

    // CLIL method section
    [
        />\s*Aprenda\s+falando\s*<br>\s*sobre\s+o\s+conteúdo\s*<br>\s*que\s+você\s+ama\.\s*<\/span>/g,
        `>${stripTags(t("clil.title")).replace(/\n/g, "<br>")}</span>`,
    ],
    [
        />\s*Aprenda\s+falando\s*\n?\s*<\/span>/g,
        `>${lang === "en" ? "Learn talking" : lang === "es" ? "Aprende hablando" : "Aprenda falando"}</span>`,
    ],
    [
        />\s*sobre\s+o\s+conteúdo\s*<br>\s*que\s+você\s+ama\.\s*<\/span>/g,
        `>${lang === "en" ? "about the content<br>you love." : lang === "es" ? "sobre el contenido<br>que amas." : "sobre o conteúdo<br>que você ama."}</span>`,
    ],
    [
        />\s*Isso\s+é\s+método\s+CLIL!\s*<\/span>/g,
        `>${stripTags(t("clil.subtitle"))}</span>`,
    ],

    // Corporate section
    [
        />\s*CONHEÇA\s+NOSSA\s+SOLUÇÃO\s+DE\s+INGLÊS\s+CORPORATIVO\s*<\/span>/g,
        `>${t("corp.label")}</span>`,
    ],
    [
        />\s*Idiomas\s+estratégicos\s*<br>\s*para\s+equipes\s+de\s*<br>\s*alta\s+performance\s*<\/span>/g,
        `>${stripTags(t("corp.title")).replace(/\n/g, "<br>")}</span>`,
    ],
    [
        />\s*Idiomas\s+estratégicos\s*\n?\s*<\/span>/g,
        `>${lang === "en" ? "Strategic languages" : lang === "es" ? "Idiomas estratégicos" : "Idiomas estratégicos"}</span>`,
    ],
    [
        />\s*para\s+equipes\s+de\s*<\/span>/g,
        `>${lang === "en" ? "for high performance" : lang === "es" ? "para equipos de" : "para equipes de"}</span>`,
    ],
    [
        />\s*alta\s+performance\s*<\/span>/g,
        `>${lang === "en" ? "teams" : lang === "es" ? "alto rendimiento" : "alta performance"}</span>`,
    ],

    // Testimonials
    [
        />\s*\+400\s+MIL\s+ALUNOS\s+FLUENTES!\s*<\/span>/g,
        `>${stripTags(t("test.label"))}</span>`,
    ],
    [
        />\s*Depoimentos\s+de\s+alunos\s*<\/span>/g,
        `>${stripTags(t("test.title"))}</span>`,
    ],

    // Pricing section title
    [
        />\s*Comece\s+hoje\.\s*<br>\s*Conheça\s+nossos\s+planos\.\s*<\/span>/g,
        `>${stripTags(t("pricing.title")).replace(/\n/g, "<br>")}</span>`,
    ],
    [
        />\s*Comece\s+hoje\.\s*<\/span>/g,
        `>${stripTags(t("pricing.title")).split(".")[0]}.</span>`,
    ],

    // Footer CTA
    [
        />\s*Pronto\s+para\s+dar\s*<br>\s*o\s+próximo\s+passo\?\s*<\/span>/g,
        `>${stripTags(t("footer.title")).replace(/\n/g, "<br>")}</span>`,
    ],
    [
        />\s*Pronto\s+para\s+dar\s*\n?\s*<\/span>/g,
        `>${lang === "en" ? "Ready to take" : lang === "es" ? "¿Listo para dar" : "Pronto para dar"}</span>`,
    ],
    [
        />\s*o\s+próximo\s+passo\?\s*<\/span>/g,
        `>${lang === "en" ? "the next step?" : lang === "es" ? "el próximo paso?" : "o próximo passo?"}</span>`,
    ],
    [
        />\s*Começar\s+Agora\s*<\/span>/g,
        `>${stripTags(t("footer.cta"))}</span>`,
    ],

    // Tutor section
    [
        />\s*OS\s+PROFESSORES\s+DA\s+CLILTUTORS\s*<\/span>/g,
        `>${t("tutors.label")}</span>`,
    ],
    [
        />\s*Conheça\s+nossos\s+tutors!\s*<\/span>/g,
        `>${stripTags(t("tutors.title"))}</span>`,
    ],
    [/>\s*Estude\s+comigo\s*→\s*<\/span>/g, `>${t("tutors.btn")}</span>`],
    [
        />\s*Estude\s+comigo\s*<\/span>/g,
        `>${t("tutors.btn").replace(" →", "")}</span>`,
    ],

    // Pricing details
    [/>\s*Plano\s+Básico\s*<\/span>/g, `>${t("pricing.p1.name")}</span>`],
    [
        />\s*Plano\s+Semi-Intensivo\s*<\/span>/g,
        `>${t("pricing.p2.name")}</span>`,
    ],
    [/>\s*Plano\s+Intensivo\s*<\/span>/g, `>${t("pricing.p3.name")}</span>`],
    [/>\s*4\s+aulas\/mês\s*<\/span>/g, `>${t("pricing.p1.freq")}</span>`],
    [/>\s*8\s+aulas\/mês\s*<\/span>/g, `>${t("pricing.p2.freq")}</span>`],
    [/>\s*16\s+aulas\/mês\s*<\/span>/g, `>${t("pricing.p3.freq")}</span>`],

    // ── ABOUT SECTION: Mission text (split across 4 spans) ──
    [
        />\s*Transformar\s+o\s+aprendizado\s+em\s+uma\s*<\/span>/g,
        `>${lang === "en" ? "To turn learning into a" : lang === "es" ? "Transformar el aprendizaje en una" : "Transformar o aprendizado em uma"}</span>`,
    ],
    [
        />\s*experiência\s+humana\s+e\s+global,\s+onde\s+o\s*<\/span>/g,
        `>${lang === "en" ? "human and global experience, where" : lang === "es" ? "experiencia humana y global, donde el" : "experiência humana e global, onde o"}</span>`,
    ],
    [
        />\s*idioma\s+é\s+a\s+ferramenta\s+para\s+viver\s+novas\s*<\/span>/g,
        `>${lang === "en" ? "language is the tool to live new" : lang === "es" ? "idioma es la herramienta para vivir nuevas" : "idioma é a ferramenta para viver novas"}</span>`,
    ],
    [
        />\s*histórias,\s+não\s+apenas\s+estudá-las\.\s*<\/span>/g,
        `>${lang === "en" ? "stories, not just study them." : lang === "es" ? "historias, no solo estudiarlas." : "histórias, não apenas estudá-las."}</span>`,
    ],

    // About vision text (split across spans)
    [
        />\s*Ser\s+uma\s+ponte\s+entre\s+pessoas\s+e\s*<\/span>/g,
