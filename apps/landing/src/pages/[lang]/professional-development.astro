---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCard from '../../components/PremiumCard.astro';
import StatsBanner from '../../components/StatsBanner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import StaggerContainer, { StaggerItem } from '../../components/StaggerContainer.tsx';
import MotionCard from '../../components/MotionCard.tsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const careerPrograms = [
  {
  icon: 'briefcase',
  iconType: 'lucide' as const,
  title: t('professional.programs.interview.title'),
    description: t('professional.programs.interview.desc'),
    metrics: [
      { label: t('professional.programs.interview.metric1.label'), value: t('professional.programs.interview.metric1.value') },
      { label: t('professional.programs.interview.metric2.label'), value: t('professional.programs.interview.metric2.value') }
    ],
    tags: [t('professional.programs.interview.tag1'), t('professional.programs.interview.tag2')],
    variant: 'blue' as const,
    featured: true
  },
  {
  icon: 'target',
  iconType: 'lucide' as const,
  title: t('professional.programs.presentation.title'),
    description: t('professional.programs.presentation.desc'),
    metrics: [
      { label: t('professional.programs.presentation.metric1.label'), value: t('professional.programs.presentation.metric1.value') }
    ],
    tags: [t('professional.programs.presentation.tag1')],
    variant: 'purple' as const
  },
  {
  icon: 'users',
  iconType: 'lucide' as const,
  title: t('professional.programs.negotiation.title'),
    description: t('professional.programs.negotiation.desc'),
    metrics: [
      { label: t('professional.programs.negotiation.metric1.label'), value: t('professional.programs.negotiation.metric1.value') }
    ],
    tags: [t('professional.programs.negotiation.tag1'), t('professional.programs.negotiation.tag2')],
    variant: 'gold' as const
  },
  {
  icon: 'globe-2',
  iconType: 'lucide' as const,
  title: t('professional.programs.collaboration.title'),
    description: t('professional.programs.collaboration.desc'),
    metrics: [
      { label: t('professional.programs.collaboration.metric1.label'), value: t('professional.programs.collaboration.metric1.value') }
    ],
    tags: [t('professional.programs.collaboration.tag1')],
    variant: 'orange' as const
  }
];

const careerStats = [
  { value: '95%', label: t('professional.stats.placement'), trend: 'up' as const, trendValue: '+12%' },
  { value: '3x', label: t('professional.stats.interview'), trend: 'up' as const, trendValue: '+45%' },
  { value: '89%', label: t('professional.stats.promotion'), trend: 'up' as const, trendValue: '+28%' },
  { value: '50+', label: t('professional.stats.industries') }
];

const careerTracks = [
  {
  icon: 'trending-up',
  iconType: 'lucide' as const,
  title: t('professional.tracks.executive.title'),
    description: t('professional.tracks.executive.desc'),
    linkText: t('professional.tracks.link'),
    href: `/${lang}/consultation`,
    variant: 'navy' as const
  },
  {
  icon: 'microscope',
  iconType: 'lucide' as const,
  title: t('professional.tracks.technical.title'),
    description: t('professional.tracks.technical.desc'),
    linkText: t('professional.tracks.link'),
    href: `/${lang}/consultation`,
    variant: 'navy' as const
  },
  {
  icon: 'palette',
  iconType: 'lucide' as const,
  title: t('professional.tracks.creative.title'),
    description: t('professional.tracks.creative.desc'),
    linkText: t('professional.tracks.link'),
    href: `/${lang}/consultation`,
    variant: 'navy' as const
  }
];

const methodologySteps = [
  { number: '01', title: t('professional.method.step1.title'), desc: t('professional.method.step1.desc') },
  { number: '02', title: t('professional.method.step2.title'), desc: t('professional.method.step2.desc') },
  { number: '03', title: t('professional.method.step3.title'), desc: t('professional.method.step3.desc') },
  { number: '04', title: t('professional.method.step4.title'), desc: t('professional.method.step4.desc') }
];
---

<Layout title={t('professional.meta.title')} description={t('professional.meta.desc')} lang={lang}>
  <Navbar />

  <div class="prof-dev-page">
    <PremiumHero
      eyebrow={t('professional.hero.eyebrow')}
      title={t('professional.hero.title')}
      subtitle={t('professional.hero.subtitle')}
      ctaPrimary={{ text: t('professional.hero.cta'), href: `/${lang}/consultation` }}
      ctaSecondary={{ text: t('professional.hero.cta2'), href: `#programs` }}
      alignment="center"
      theme="gradient"
      trustIndicators={[
        { value: '10,000+', label: t('professional.trust.professionals') },
        { value: '95%', label: t('professional.trust.satisfaction') },
        { value: '45+', label: t('professional.trust.countries') }
      ]}
    />

    <StatsBanner
      stats={careerStats}
      theme="dark"
      title={t('professional.stats.title')}
      subtitle={t('professional.stats.subtitle')}
    />

    <section id="programs" class="section-padding gradient-subtle relative overflow-hidden">
      <div class="bg-dots"></div>
      <div class="container-wide relative">
        <SectionHeader
          eyebrow={t('professional.programs.eyebrow')}
          title={t('professional.programs.title')}
          description={t('professional.programs.subtitle')}
        />

      <StaggerContainer client:visible className="grid md:grid-cols-2 gap-6">
        {careerPrograms.map((program) => (
          <StaggerItem>
            <MotionCard client:visible>
              <PremiumCard
                icon={program.icon}
                iconType={program.iconType}
                title={program.title}
                description={program.description}
                metrics={program.metrics}
                tags={program.tags}
                variant={program.variant}
                featured={program.featured}
                featuredLabel={t('card.featured')}
                size="lg"
              />
            </MotionCard>
          </StaggerItem>
        ))}
      </StaggerContainer>
      </div>
    </section>

    <section class="section-padding relative overflow-hidden professional-blue-fade">
      <div class="bg-grid"></div>
      <div class="container-wide relative">
        <SectionHeader
          eyebrow={t('professional.tracks.eyebrow')}
          title={t('professional.tracks.title')}
          description={t('professional.tracks.subtitle')}
        />

      <StaggerContainer client:visible className="grid lg:grid-cols-3 gap-6">
        {careerTracks.map((track) => (
          <StaggerItem>
            <MotionCard client:visible>
              <PremiumCard
                icon={track.icon}
                iconType={track.iconType}
                title={track.title}
                description={track.description}
                href={track.href}
                linkText={track.linkText}
                variant={track.variant}
                size="md"
              />
            </MotionCard>
          </StaggerItem>
        ))}
      </StaggerContainer>
      </div>
    </section>

    <section class="section-padding gradient-hero text-white relative overflow-hidden">
      <div class="method-bg-orb orb-a"></div>
      <div class="method-bg-orb orb-b"></div>
      <div class="container-wide relative">
        <SectionHeader
          eyebrow={t('professional.method.eyebrow')}
          title={t('professional.method.title')}
          light={true}
        />

      <StaggerContainer client:visible className="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {methodologySteps.map((step, i) => (
          <StaggerItem>
            <div class="method-step">
              <div class="step-number">{step.number}</div>
              <h3 class="font-heading font-semibold text-xl mb-3">{step.title}</h3>
              <p class="text-white/70 leading-relaxed">{step.desc}</p>
              {i < methodologySteps.length - 1 && (
                <div class="step-connector hidden lg:block" aria-hidden="true"></div>
              )}
            </div>
          </StaggerItem>
        ))}
      </StaggerContainer>
      </div>
    </section>

    <PremiumCTABanner
      title={t('professional.cta.title')}
      description={t('professional.cta.subtitle')}
      primaryCTA={{ text: t('professional.cta.primary'), href: `/${lang}/consultation` }}
      secondaryCTA={{ text: t('professional.cta.secondary'), href: `/${lang}/methodology` }}
      variant="gradient"
        trustBadges={[
          { icon: 'check', iconType: 'lucide' as const, label: t('professional.trust.professionals'), value: '10,000+' },
          { icon: 'star', iconType: 'lucide' as const, label: t('professional.trust.satisfaction'), value: '95%' }
        ]}
    />
  </div>

  <Footer />
</Layout>

<style>
.prof-dev-page .professional-blue-fade {
  background: linear-gradient(to bottom, var(--color-brand-blue-50), white);
}

.method-bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  pointer-events: none;
}

.orb-a {
  top: -15%;
  right: -10%;
  width: 500px;
  height: 500px;
  background: rgba(82, 138, 237, 0.12);
  animation: float 10s ease-in-out infinite;
}

.orb-b {
  bottom: -15%;
  left: -10%;
  width: 400px;
  height: 400px;
  background: rgba(166, 123, 244, 0.1);
  animation: float 12s ease-in-out infinite;
  animation-delay: 3s;
}

.method-step {
  position: relative;
  padding: 2rem;
  border-radius: 1.25rem;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.08);
  transition: all 400ms var(--ease-out-expo);
  overflow: hidden;
}

.method-step::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 1.25rem;
  padding: 1.5px;
  background: linear-gradient(135deg, var(--color-brand-gold), var(--color-brand-orange));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 400ms ease;
  pointer-events: none;
}

.method-step:hover {
  background: rgba(255, 255, 255, 0.16);
  border-color: transparent;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.12);
  transform: translateY(-4px);
}

.method-step:hover::after {
  opacity: 1;
}

.step-number {
  font-size: 5rem;
  line-height: 1;
  font-family: var(--font-heading);
  font-weight: 800;
  color: rgba(254, 187, 55, 0.15);
  margin-bottom: 1rem;
  transition: color 400ms ease;
}

.method-step:hover .step-number {
  color: rgba(254, 187, 55, 0.35);
}

.step-connector {
  position: absolute;
  top: 50%;
  right: -1rem;
  width: 2rem;
  height: 2px;
  background: linear-gradient(to right, rgba(254, 187, 55, 0.4), transparent);
}
</style>
