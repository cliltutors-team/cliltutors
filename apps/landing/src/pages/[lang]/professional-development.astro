---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCard from '../../components/PremiumCard.astro';
import StatsBanner from '../../components/StatsBanner.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const careerPrograms = [
  {
    icon: '💼',
    title: t('professional.programs.interview.title'),
    description: t('professional.programs.interview.desc'),
    metrics: [
      { label: t('professional.programs.interview.metric1.label'), value: t('professional.programs.interview.metric1.value') },
      { label: t('professional.programs.interview.metric2.label'), value: t('professional.programs.interview.metric2.value') }
    ],
    tags: [t('professional.programs.interview.tag1'), t('professional.programs.interview.tag2')],
    variant: 'blue' as const,
    featured: true
  },
  {
    icon: '🎯',
    title: t('professional.programs.presentation.title'),
    description: t('professional.programs.presentation.desc'),
    metrics: [
      { label: t('professional.programs.presentation.metric1.label'), value: t('professional.programs.presentation.metric1.value') }
    ],
    tags: [t('professional.programs.presentation.tag1')],
    variant: 'purple' as const
  },
  {
    icon: '🤝',
    title: t('professional.programs.negotiation.title'),
    description: t('professional.programs.negotiation.desc'),
    metrics: [
      { label: t('professional.programs.negotiation.metric1.label'), value: t('professional.programs.negotiation.metric1.value') }
    ],
    tags: [t('professional.programs.negotiation.tag1'), t('professional.programs.negotiation.tag2')],
    variant: 'gold' as const
  },
  {
    icon: '🌐',
    title: t('professional.programs.collaboration.title'),
    description: t('professional.programs.collaboration.desc'),
    metrics: [
      { label: t('professional.programs.collaboration.metric1.label'), value: t('professional.programs.collaboration.metric1.value') }
    ],
    tags: [t('professional.programs.collaboration.tag1')],
    variant: 'orange' as const
  }
];

const careerStats = [
  { value: '95%', label: t('professional.stats.placement'), trend: 'up' as const, trendValue: '+12%' },
  { value: '3x', label: t('professional.stats.interview'), trend: 'up' as const, trendValue: '+45%' },
  { value: '89%', label: t('professional.stats.promotion'), trend: 'up' as const, trendValue: '+28%' },
  { value: '50+', label: t('professional.stats.industries') }
];

const careerTracks = [
  {
    icon: '📈',
    title: t('professional.tracks.executive.title'),
    description: t('professional.tracks.executive.desc'),
    linkText: t('professional.tracks.link'),
    href: `/${lang}/consultation`,
    variant: 'navy' as const
  },
  {
    icon: '🔬',
    title: t('professional.tracks.technical.title'),
    description: t('professional.tracks.technical.desc'),
    linkText: t('professional.tracks.link'),
    href: `/${lang}/consultation`,
    variant: 'navy' as const
  },
  {
    icon: '🎨',
    title: t('professional.tracks.creative.title'),
    description: t('professional.tracks.creative.desc'),
    linkText: t('professional.tracks.link'),
    href: `/${lang}/consultation`,
    variant: 'navy' as const
  }
];

const methodologySteps = [
  { number: '01', title: t('professional.method.step1.title'), desc: t('professional.method.step1.desc') },
  { number: '02', title: t('professional.method.step2.title'), desc: t('professional.method.step2.desc') },
  { number: '03', title: t('professional.method.step3.title'), desc: t('professional.method.step3.desc') },
  { number: '04', title: t('professional.method.step4.title'), desc: t('professional.method.step4.desc') }
];
---

<Layout title={t('professional.meta.title')} description={t('professional.meta.desc')} lang={lang}>
  <Navbar />

  <PremiumHero
    eyebrow={t('professional.hero.eyebrow')}
    title={t('professional.hero.title')}
    subtitle={t('professional.hero.subtitle')}
    ctaPrimary={{ text: t('professional.hero.cta'), href: `/${lang}/consultation` }}
    ctaSecondary={{ text: t('professional.hero.cta2'), href: `#programs` }}
    alignment="center"
    theme="gradient"
    trustIndicators={[
      { value: '10,000+', label: t('professional.trust.professionals') },
      { value: '95%', label: t('professional.trust.satisfaction') },
      { value: '45+', label: t('professional.trust.countries') }
    ]}
  />

  <StatsBanner
    stats={careerStats}
    theme="dark"
    title={t('professional.stats.title')}
    subtitle={t('professional.stats.subtitle')}
  />

  <section id="programs" class="section-padding bg-white">
    <div class="container-wide">
      <div class="text-center mb-16">
        <span class="eyebrow">{t('professional.programs.eyebrow')}</span>
        <h2 class="section-title mt-4">{t('professional.programs.title')}</h2>
        <p class="section-subtitle max-w-2xl mx-auto">{t('professional.programs.subtitle')}</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {careerPrograms.map((program) => (
          <PremiumCard
            icon={program.icon}
            title={program.title}
            description={program.description}
            metrics={program.metrics}
            tags={program.tags}
            variant={program.variant}
featured={program.featured}
  featuredLabel={t('card.featured')}
  size="lg"
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding gradient-subtle">
    <div class="container-wide">
      <div class="text-center mb-16">
        <span class="eyebrow">{t('professional.tracks.eyebrow')}</span>
        <h2 class="section-title mt-4">{t('professional.tracks.title')}</h2>
        <p class="section-subtitle max-w-2xl mx-auto">{t('professional.tracks.subtitle')}</p>
      </div>

      <div class="grid lg:grid-cols-3 gap-6">
        {careerTracks.map((track) => (
          <PremiumCard
            icon={track.icon}
            title={track.title}
            description={track.description}
            href={track.href}
            linkText={track.linkText}
            variant={track.variant}
            size="md"
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-brand-navy text-white">
    <div class="container-wide">
      <div class="text-center mb-16">
        <span class="text-brand-gold font-heading font-bold text-xs tracking-widest uppercase">{t('professional.method.eyebrow')}</span>
        <h2 class="text-4xl md:text-5xl font-heading font-bold mt-4">{t('professional.method.title')}</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {methodologySteps.map((step, i) => (
          <div class="relative">
            <div class="step-number text-brand-gold/20 font-heading font-bold text-7xl mb-4">{step.number}</div>
            <h3 class="font-heading font-semibold text-xl mb-3">{step.title}</h3>
            <p class="text-white/70 leading-relaxed">{step.desc}</p>
            {i < methodologySteps.length - 1 && (
              <div class="hidden lg:block absolute top-1/2 -right-4 w-8 h-0.5 bg-brand-gold/30" aria-hidden="true"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow text-center">
      <h2 class="section-title">{t('professional.cta.title')}</h2>
      <p class="section-subtitle mb-8">{t('professional.cta.subtitle')}</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`/${lang}/consultation`} class="btn-primary-premium">
          {t('professional.cta.primary')}
<svg class="w-5 h-5 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
    </svg>
        </a>
        <a href={`/${lang}/methodology`} class="btn-outline-premium">{t('professional.cta.secondary')}</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .eyebrow {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: rgba(82, 138, 237, 0.08);
    color: var(--color-brand-blue);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-family: var(--font-heading);
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    color: var(--color-brand-navy);
    letter-spacing: -0.02em;
    font-family: var(--font-heading);
  }

  .section-subtitle {
    font-size: 1.125rem;
    color: var(--color-slate-light);
    line-height: 1.7;
  }

  .btn-primary-premium {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-indigo));
    color: white;
    font-weight: 600;
    border-radius: 14px;
    text-decoration: none;
    transition: all 300ms var(--ease-out-expo);
    font-family: var(--font-heading);
  }

  .btn-primary-premium:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(82, 138, 237, 0.4);
  }

  .btn-outline-premium {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: transparent;
    color: var(--color-brand-navy);
    font-weight: 600;
    border: 1.5px solid rgba(52, 53, 79, 0.2);
    border-radius: 14px;
    text-decoration: none;
    transition: all 250ms var(--ease-out-expo);
    font-family: var(--font-heading);
  }

  .btn-outline-premium:hover {
    background: rgba(52, 53, 79, 0.04);
    border-color: rgba(52, 53, 79, 0.3);
  }

  .step-number {
    font-size: 5rem;
    line-height: 1;
  }

  .gradient-subtle {
    background: linear-gradient(to bottom, var(--color-off-white), white);
  }
</style>
