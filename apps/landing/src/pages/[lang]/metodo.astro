---
import Layout from "../../layouts/Layout.astro";
import { useTranslations } from "../../i18n/utils";
import { ui } from "../../i18n/ui";
export function getStaticPaths() {
    return [
        { params: { lang: "en" } },
        { params: { lang: "es" } },
        { params: { lang: "pt" } },
    ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as keyof typeof ui);

// Icons as basic SVG strings
const VideoIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-video"><path d="m16 13 5.223 3.482a.5.5 0 0 0 .777-.416V7.87a.5.5 0 0 0-.752-.432L16 10.5"/><rect x="2" y="6" width="14" height="12" rx="2"/></svg>`;
const GlobeIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-globe"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>`;
const TargetIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-target"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`;
const StrategyIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-lightbulb"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.9 1.2 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>`;
---

<Layout title="Método Cliltutors">
    <div class="bg-[#fbfcff] min-h-screen font-poppins text-[#54577c]">
        {/* Navigation */}
        <nav
            class="max-w-7xl mx-auto px-6 py-8 flex flex-wrap items-center justify-center gap-8 md:gap-12 text-[#484a68] font-medium"
        >
            <a href="#sobre" class="hover:text-[#e55b78] transition-colors"
                >{t("nav.about")}</a
            >
            <a href="#curso" class="hover:text-[#e55b78] transition-colors"
                >{t("nav.course")}</a
            >
            <a href="#empresas" class="hover:text-[#e55b78] transition-colors"
                >{t("nav.business")}</a
            >
            <a href="#coaching" class="hover:text-[#e55b78] transition-colors"
                >{t("nav.coaching")}</a
            >
        </nav>

        {/* Hero Section */}
        <header
            class="max-w-7xl mx-auto px-6 py-10 lg:py-16 grid grid-cols-1 xl:grid-cols-2 gap-12 xl:gap-20 items-center min-h-[85vh]"
        >
            <div class="space-y-10 relative z-20">
                <h1
                    class="text-6xl md:text-7xl lg:text-[5.5rem] font-bold text-[#34354f] leading-[1.05] font-montserrat tracking-tight"
                >
                    <Fragment set:html={t("hero.title")} />
                </h1>
                <p
                    class="text-[1.35rem] text-[#54577c] max-w-lg leading-relaxed font-medium"
                >
                    <Fragment set:html={t("hero.subtitle")} />
                </p>

                <div
                    class="flex flex-col sm:flex-row items-start sm:items-center gap-6 pt-4"
                >
                    <a
                        href="https://wa.me/5519974021786?text=Ol%C3%A1.%20Gostaria%20de%20agendar%20minha%20aula%20experimental%20essa%20semana...%20"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="bg-[#36de6b] hover:bg-[#2bc45d] text-white font-bold py-5 px-10 rounded-[50px] shadow-[0_15px_30px_-10px_rgba(54,222,107,0.5)] transition-transform hover:scale-[1.02] flex items-center justify-center gap-4 text-xl w-full sm:w-auto"
                    >
                        <span><Fragment set:html={t("hero.cta.book")} /></span>
                        <span
                            class="bg-white/25 p-2.5 rounded-full flex-shrink-0 backdrop-blur-sm"
                        >
                            <Fragment set:html={VideoIcon} />
                        </span>
                    </a>

                    <div
                        class="flex items-center gap-4 text-[#484a68] font-black text-sm leading-tight uppercase relative ml-2 sm:ml-4"
                    >
                        <div class="relative flex items-center justify-center">
                            <svg
                                class="w-20 h-20 text-[#e55b78] animate-[spin_12s_linear_infinite] absolute"
                                viewBox="0 0 100 100"
                            >
                                <path
                                    id="textPath"
                                    d="M 50, 50 m -35, 0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0"
                                    fill="transparent"></path>
                                <text
                                    class="font-bold text-[14px] tracking-wider"
                                    fill="currentColor"
                                >
                                    <textPath href="#textPath"
                                        >AO VIVO • ENCONTROS 100% •</textPath
                                    >
                                </text>
                            </svg>
                            <div
                                class="w-10 h-10 bg-white rounded-full shadow-md flex items-center justify-center z-10 text-[#34354f]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    stroke="none"
                                    ><path d="M15 10l5-4v12l-5-4V10z"
                                    ></path><rect
                                        x="4"
                                        y="6"
                                        width="11"
                                        height="12"
                                        rx="2"
                                        ry="2"></rect></svg
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div
                class="relative w-full aspect-square xl:aspect-auto xl:h-[750px] flex items-center justify-center mt-10 xl:mt-0 z-10"
            >
                {/* Decorative blob backgrounds */}
                <div
                    class="absolute inset-0 bg-[#fdd122]/15 rounded-full blur-[80px] w-3/4 h-3/4 m-auto"
                >
                </div>
                <div
                    class="absolute top-10 right-10 bg-[#e55b78]/15 rounded-full blur-[80px] w-1/2 h-1/2"
                >
                </div>

                {/* Main Image Frame (Huge rounded corners like Canva) */}
                <div
                    class="relative w-[90%] md:w-[80%] xl:w-[95%] h-[90%] md:h-[85%] xl:h-[95%] rounded-[3rem] md:rounded-[4rem] overflow-hidden shadow-[0_30px_60px_-15px_rgba(0,0,0,0.15)] group rotate-1"
                >
                    <img
                        src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80"
                        alt="Happy student learning"
                        class="object-cover h-full w-full transform transition-transform duration-1000 group-hover:scale-105 group-hover:-rotate-1"
                    />
                </div>

                {/* Abstract colorful shapes overlapping image */}
                <div
                    class="absolute top-1/4 -right-6 w-32 h-16 bg-linear-to-r from-[#e55b78] to-[#ff9a44] rounded-full rotate-45 opacity-80 mix-blend-multiply blur-sm"
                >
                </div>
                <div
                    class="absolute bottom-1/4 -left-6 w-40 h-20 bg-linear-to-r from-[#36de6b] to-[#3bc4f4] rounded-full -rotate-12 opacity-80 mix-blend-multiply blur-sm"
                >
                </div>
            </div>
        </header>

        {/* Start Learning Section */}
        <section id="curso" class="max-w-7xl mx-auto px-6 py-24 pb-32">
            <div class="text-center mb-16 relative">
                <span
                    class="inline-block bg-[#36de6b]/15 text-[#2bc45d] font-black px-5 py-2 rounded-full text-xs tracking-[0.2em] mb-6 uppercase"
                    >{t("start.badge")}</span
                >
                <h2
                    class="text-5xl lg:text-[4rem] font-black text-[#34354f] font-montserrat tracking-tight leading-none"
                >
                    {t("start.title")}
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-10">
                <!-- STEM (Yellow) -> Canva has Yellow as STEM/Exatas -->
                <div
                    class="bg-[#fdd122] rounded-[3rem] p-10 text-white relative overflow-hidden group h-[550px] flex flex-col justify-end shadow-[0_20px_40px_-15px_rgba(253,209,34,0.5)] transform md:-translate-y-4 hover:-translate-y-6 transition-all duration-300"
                >
                    <img
                        src="https://images.unsplash.com/photo-1509062522246-3755977927d7?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80"
                        alt="Ciências"
                        class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-50 group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-[#fdd122] via-[#fdd122]/80 to-transparent"
                    >
                    </div>
                    <div class="relative z-10">
                        <span
                            class="inline-block bg-white text-[#d4af37] text-xs font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-4 shadow-sm"
                            >EXATAS & STEM</span
                        >
                        <h3
                            class="text-[2.5rem] font-black font-montserrat tracking-tight mb-4 leading-none drop-shadow-md text-white"
                        >
                            <Fragment set:html={t("features.f2.title")} />
                        </h3>
                    </div>
                </div>

                <!-- Languages (Green) -->
                <div
                    class="bg-[#36de6b] rounded-[3rem] p-10 text-white relative overflow-hidden group h-[550px] flex flex-col justify-end shadow-[0_20px_40px_-15px_rgba(54,222,107,0.5)] transform hover:-translate-y-2 transition-all duration-300 z-10"
                >
                    <img
                        src="https://images.unsplash.com/photo-1543269865-cbf427effbad?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80"
                        alt="Idiomas"
                        class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-60 group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-[#36de6b] via-[#36de6b]/80 to-transparent"
                    >
                    </div>

                    {/* Floating Language Tags */}
                    <div
                        class="absolute top-10 right-8 flex flex-col items-end gap-3 z-20"
                    >
                        <span
                            class="bg-white text-[#2bc45d] text-xs font-black uppercase tracking-widest px-4 py-2 rounded-full shadow-lg transform -rotate-3"
                            >{t("start.spanish")}</span
                        >
                        <span
                            class="bg-white text-[#2bc45d] text-xs font-black uppercase tracking-widest px-4 py-2 rounded-full shadow-lg transform rotate-2"
                            >{t("start.english")}</span
                        >
                        <span
                            class="bg-white text-[#2bc45d] text-xs font-black uppercase tracking-widest px-4 py-2 rounded-full shadow-lg transform -rotate-1"
                            >{t("start.portuguese")}</span
                        >
                    </div>

                    <div class="relative z-10">
                        <span
                            class="inline-block bg-white text-[#2bc45d] text-xs font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-4 shadow-sm"
                            >MÉTODO CLIL</span
                        >
                        <h3
                            class="text-[2.5rem] font-black font-montserrat tracking-tight leading-none drop-shadow-md text-white"
                        >
                            <Fragment set:html={t("features.f1.title")} />
                        </h3>
                    </div>
                </div>

                <!-- Coaching (Pink) -->
                <div
                    class="bg-[#e55b78] rounded-[3rem] p-10 text-white relative overflow-hidden group h-[550px] flex flex-col justify-end shadow-[0_20px_40px_-15px_rgba(229,91,120,0.5)] transform md:translate-y-4 hover:translate-y-2 transition-all duration-300"
                >
                    <img
                        src="https://images.unsplash.com/photo-1552581234-26160f608093?ixlib=rb-4.0.3&auto=format&fit=crop&w=600&q=80"
                        alt="Coaching"
                        class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-70 group-hover:scale-105 transition-transform duration-700 ease-out"
                    />
                    <div
                        class="absolute inset-0 bg-linear-to-t from-[#e55b78] via-[#e55b78]/70 to-transparent"
                    >
                    </div>
                    <div class="relative z-10">
                        <span
                            class="inline-block bg-[#fdd122] text-[#34354f] text-xs font-black uppercase tracking-widest px-4 py-1.5 rounded-full mb-4 shadow-sm"
                            >CAREER</span
                        >
                        <h3
                            class="text-[2.5rem] font-black font-montserrat tracking-tight mb-4 leading-none text-white drop-shadow-md"
                        >
                            <Fragment set:html={t("features.f3.title")} />
                        </h3>
                    </div>
                </div>
            </div>
        </section>

        {/* Method CLIL features */}
        <section class="bg-white py-24">
            <div
                class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-20"
            >
                <!-- Feature 1 -->
                <div class="space-y-6 group">
                    <div
                        class="w-20 h-20 bg-[#e55b78]/10 rounded-3xl flex items-center justify-center text-[#e55b78] group-hover:bg-[#e55b78] group-hover:text-white transition-colors duration-300 shadow-sm"
                    >
                        <Fragment set:html={GlobeIcon} />
                    </div>
                    <h3
                        class="text-2xl font-bold text-[#34354f] font-montserrat leading-tight"
                    >
                        <Fragment set:html={t("features.f1.title")} />
                    </h3>
                    <p class="text-[17px] text-[#54577c] leading-relaxed">
                        <Fragment set:html={t("features.f1.desc")} />
                    </p>
                </div>

                <!-- Feature 2 -->
                <div class="space-y-6 group">
                    <div
                        class="w-20 h-20 bg-[#fdd122]/20 rounded-3xl flex items-center justify-center text-[#d4af37] group-hover:bg-[#fdd122] group-hover:text-white transition-colors duration-300 shadow-sm"
                    >
                        <Fragment set:html={TargetIcon} />
                    </div>
                    <h3
                        class="text-2xl font-bold text-[#34354f] font-montserrat leading-tight"
                    >
                        <Fragment set:html={t("features.f2.title")} />
                    </h3>
                    <p class="text-[17px] text-[#54577c] leading-relaxed">
                        <Fragment set:html={t("features.f2.desc")} />
                    </p>
                </div>

                <!-- Feature 3 -->
                <div class="space-y-6 group" id="coaching">
                    <div
                        class="w-20 h-20 bg-[#36de6b]/10 rounded-3xl flex items-center justify-center text-[#36de6b] group-hover:bg-[#36de6b] group-hover:text-white transition-colors duration-300 shadow-sm"
                    >
                        <Fragment set:html={StrategyIcon} />
                    </div>
                    <h3
                        class="text-2xl font-bold text-[#34354f] font-montserrat leading-tight"
                    >
                        <Fragment set:html={t("features.f3.title")} />
                    </h3>
                    <p class="text-[17px] text-[#54577c] leading-relaxed">
                        <Fragment set:html={t("features.f3.desc")} />
                    </p>
                </div>
            </div>
        </section>

        {/* About Section */}
        <section id="sobre" class="bg-[#fbfcff] py-32 overflow-hidden">
            <div class="max-w-7xl mx-auto px-6">
                <div class="text-center max-w-4xl mx-auto space-y-6 mb-24">
                    <h2
                        class="text-4xl lg:text-5xl font-bold text-[#34354f] font-montserrat tracking-tight leading-tight"
                    >
                        {t("about.title")}
                    </h2>
                    <p class="text-xl text-[#54577c] leading-relaxed">
                        {t("about.desc")}
                    </p>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24 items-center"
                >
                    <div
                        class="bg-linear-to-br from-[#40dd89] to-[#e55b78] p-12 lg:p-16 rounded-[3rem] text-white shadow-[0_20px_50px_-12px_rgba(229,91,120,0.5)] relative overflow-hidden h-full flex flex-col justify-center"
                    >
                        <!-- Decorative elements -->
                        <div
                            class="absolute top-0 right-0 w-64 h-64 bg-white opacity-10 rounded-full blur-3xl transform translate-x-1/3 -translate-y-1/3"
                        >
                        </div>
                        <div
                            class="absolute bottom-0 left-0 w-64 h-64 bg-white opacity-10 rounded-full blur-3xl transform -translate-x-1/3 translate-y-1/3"
                        >
                        </div>

                        <h3
                            class="text-4xl lg:text-5xl font-black font-montserrat mb-8 leading-[1.1] tracking-tight relative z-10"
                        >
                            <Fragment set:html={t("about.card.title")} />
                        </h3>
                        <p
                            class="text-xl text-white/95 leading-relaxed font-medium relative z-10"
                        >
                            {t("about.card.desc")}
                        </p>
                    </div>

                    <div class="space-y-16 py-8">
                        <div class="relative pb-16 border-b border-gray-200">
                            <div
                                class="absolute -left-8 top-2 w-1.5 h-12 bg-[#36de6b] rounded-r-full"
                            >
                            </div>
                            <h4
                                class="text-[#84877c] font-bold tracking-[0.2em] text-sm mb-4"
                            >
                                {t("about.mission.label")}
                            </h4>
                            <p
                                class="text-2xl lg:text-3xl text-[#484a68] font-medium leading-relaxed font-montserrat"
                            >
                                {t("about.mission.text")}
                            </p>
                        </div>

                        <div class="relative">
                            <div
                                class="absolute -left-8 top-2 w-1.5 h-12 bg-[#e55b78] rounded-r-full"
                            >
                            </div>
                            <h4
                                class="text-[#84877c] font-bold tracking-[0.2em] text-sm mb-4"
                            >
                                {t("about.vision.label")}
                            </h4>
                            <p
                                class="text-2xl lg:text-3xl text-[#484a68] font-medium leading-relaxed font-montserrat"
                            >
                                {t("about.vision.text")}
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {/* Method CLIL Deep Dive */}
        <section class="bg-white py-32 overflow-hidden relative">
            <div
                class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center"
            >
                <div class="space-y-8 relative z-10">
                    <h2
                        class="text-5xl lg:text-6xl font-black text-[#1f4e3d] font-montserrat leading-[1.1] tracking-tight"
                    >
                        {t("clil.title")}
                    </h2>
                    <div class="flex items-center gap-3">
                        <h3 class="text-2xl font-bold text-[#34354f]">
                            {t("clil.subtitle")}
                        </h3>
                        <div
                            class="w-8 h-8 rounded-full bg-[#36de6b] text-white flex items-center justify-center"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                class="lucide lucide-check"
                                stroke="currentColor"
                                stroke-width="3"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M20 6 9 17l-5-5"></path></svg
                            >
                        </div>
                    </div>
                    <p class="text-xl text-[#84877c] font-medium tracking-wide">
                        {t("clil.expansion")}
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <span
                            class="bg-[#fdd122]/20 text-[#d4af37] px-4 py-2 rounded-full font-bold text-sm uppercase"
                            >{t("clil.lang1")}</span
                        >
                        <span
                            class="bg-[#e55b78]/10 text-[#e55b78] px-4 py-2 rounded-full font-bold text-sm uppercase"
                            >{t("clil.lang2")}</span
                        >
                        <span
                            class="bg-[#36de6b]/20 text-[#2bc45d] px-4 py-2 rounded-full font-bold text-sm uppercase"
                            >{t("clil.lang3")}</span
                        >
                    </div>
                    <p
                        class="text-lg text-[#54577c] leading-relaxed max-w-lg font-medium"
                    >
                        {t("clil.body")}
                    </p>
                </div>

                <div
                    class="relative h-[600px] flex items-center justify-center"
                >
                    {/* Decorative nodes */}
                    <div
                        class="absolute inset-0 bg-red-50 rounded-full blur-3xl opacity-50"
                    >
                    </div>
                    <div
                        class="relative w-[350px] h-[350px] bg-gray-100 rounded-full border-[10px] border-white shadow-2xl z-10 overflow-hidden"
                    >
                        <img
                            src="/images/canva/clil_person.png"
                            onerror="this.src='https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&q=80&w=600'"
                            alt="CLIL student"
                            class="object-cover w-full h-full"
                        />
                    </div>

                    {/* Floating elements simulating Canva's infographic */}
                    <div
                        class="absolute top-[10%] left-[5%] bg-white px-6 py-3 rounded-2xl shadow-xl z-20 font-bold text-[#484a68] border-b-4 border-[#fdd122] transform -rotate-3 hover:scale-105 transition-transform text-center max-w-[150px]"
                    >
                        {t("clil.tag1")}
                    </div>
                    <div
                        class="absolute top-[20%] right-[0%] bg-white px-6 py-3 rounded-2xl shadow-xl z-20 font-bold text-[#484a68] border-b-4 border-[#36de6b] transform rotate-3 hover:scale-105 transition-transform text-center max-w-[150px]"
                    >
                        {t("clil.tag2")}
                    </div>
                    <div
                        class="absolute bottom-[20%] left-[0%] bg-white px-6 py-3 rounded-2xl shadow-xl z-20 font-bold text-[#484a68] border-b-4 border-[#e55b78] transform -rotate-2 hover:scale-105 transition-transform text-center max-w-[150px]"
                    >
                        {t("clil.tag3")}
                    </div>
                    <div
                        class="absolute bottom-[10%] right-[5%] bg-white px-6 py-3 rounded-2xl shadow-xl z-20 font-bold text-[#484a68] border-b-4 border-[#3bc4f4] transform rotate-2 hover:scale-105 transition-transform text-center max-w-[150px]"
                    >
                        {t("clil.tag4")}
                    </div>

                    {/* Bubble */}
                    <div
                        class="absolute top-[5%] right-[20%] bg-[#fdd122] text-[#34354f] font-black italic px-4 py-2 rounded-t-2xl rounded-bl-2xl shadow-lg transform rotate-[10deg] border-2 border-white z-30"
                    >
                        {t("clil.bubble")}
                    </div>
                </div>
            </div>
        </section>

        {/* Tutors Section */}
        <section class="bg-[#36de6b] py-32 overflow-hidden relative">
            <div
                class="max-w-7xl mx-auto px-6 mb-16 text-center space-y-6 relative z-10"
            >
                <span
                    class="inline-block bg-white/20 text-white font-bold px-4 py-1.5 rounded-full text-xs tracking-[0.2em]"
                >
