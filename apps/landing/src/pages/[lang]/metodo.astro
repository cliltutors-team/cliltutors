---
import { getLangFromUrl } from "../../i18n/utils";
import { languages } from "../../i18n/ui";

export function getStaticPaths() {
    return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
// Legacy metodo page — redirect to methodology
---

<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0;url=/${lang}/methodology`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting to <a href={`/${lang}/methodology`}>methodology</a>...</p>
  </body>
</html>
