---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import TutorsPage from '../../components/TutorsPage';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('tutors.meta.title')} description={t('tutors.meta.desc')} lang={lang}>
<Navbar />

<PremiumHero
eyebrow={t('tutors.hero.eyebrow')}
title={t('tutors.hero.title')}
subtitle={t('tutors.hero.subtitle')}
ctaPrimary={{ text: t('nav.consultation'), href: `/${lang}/consultation` }}
alignment="center"
theme="gradient"
/>

<section class="tutors-page section-padding gradient-subtle">
<div class="container-wide">
<TutorsPage client:idle lang={lang} t={t} />
</div>
</section>

<PremiumCTABanner
title={t('tutors.cta.title')}
description={t('tutors.cta.subtitle')}
primaryCTA={{ text: t('nav.consultation'), href: `/${lang}/consultation` }}
variant="gradient"
/>

<Footer />
</Layout>

