---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import HeroSection from '../../components/HeroSection.astro';
import TutorsPage from '../../components/TutorsPage';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t('tutors.meta.title')} description={t('tutors.meta.desc')} lang={lang}>
  <Navbar />
  <HeroSection
    eyebrow={t('tutors.hero.eyebrow')}
    title={t('tutors.hero.title')}
    subtitle={t('tutors.hero.subtitle')}
    cta1Text={t('nav.consultation')}
    cta1Href={`/${lang}/consultation`}
  />
  <TutorsPage client:idle lang={lang} t={t} />
  <Footer />
</Layout>
