---

<Layout title={t('home.meta.title')} description={t('home.meta.desc')} lang={lang}>
<Navbar />
<div class="home-page">

  <!-- Premium Hero -->
  <PremiumHero
    eyebrow={t('home.challenge.eyebrow')}
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    ctaPrimary={{ text: t('home.hero.cta1'), href: `/${lang}/solutions` }}
    ctaSecondary={{ text: t('home.hero.cta2'), href: `/${lang}/consultation` }}
  visualType="animated"
  visualVariant="dashboard"
  visualStats={heroTrustIndicators}
  theme="gradient"
  trustIndicators={heroTrustIndicators}
  />

<!-- NEW: Trust Signals Section -->
<TrustSignalsSection
  trustIndicators={trustIndicators}
  studentCount="50,000+"
  courseCount="200+"
  countryCount="120+"
  ratingValue="4.9"
  studentLabel={t('trust.students')}
  courseLabel={t('trust.courses')}
  countryLabel={t('trust.countries')}
  ratingLabel={t('trust.rating')}
  verifiedLabel={t('trust.verified')}
  lifetimeLabel={t('trust.lifetime')}
  expertsLabel={t('trust.experts')}
  partnersLabel={t('trust.partners')}
/>

  <!-- Challenge Section -->
  <section class="challenge-section section-padding relative overflow-hidden">
    <div class="challenge-bg" aria-hidden="true">
      <div class="challenge-orb challenge-orb-1"></div>
      <div class="challenge-orb challenge-orb-2"></div>
      <div class="challenge-dots"></div>
    </div>
    <div class="container-narrow relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <MotionReveal client:visible direction="up" delay={0} duration={0.7}>
            <SectionHeader eyebrow={t('home.challenge.eyebrow')} title={t('home.challenge.title')} center={false} />
          </MotionReveal>
          <MotionReveal client:visible direction="up" delay={0.1} duration={0.7}>
            <p class="text-slate-light leading-relaxed text-lg -mt-8">{t('home.challenge.desc')}</p>
          </MotionReveal>
        </div>
        <MotionReveal client:visible direction="up" delay={0.2} duration={0.7}>
          <MotionCard client:visible hoverScale={1.02} hoverY={-4}>
            <div class="challenge-image-wrap">
              <img src="/images/web/first_sec.webp" alt="Global challenge" class="w-full rounded-xl" loading="lazy" />
            </div>
          </MotionCard>
        </MotionReveal>
      </div>
    </div>
  </section>

  <!-- Capabilities with Premium Cards -->
  <section class="capabilities-section section-padding gradient-section-alt relative overflow-hidden">
    <div class="capabilities-bg" aria-hidden="true">
      <div class="capabilities-orb capabilities-orb-1"></div>
    </div>
    <div class="container-narrow relative z-10">
      <MotionReveal client:visible direction="up" delay={0} duration={0.7}>
        <SectionHeader eyebrow={t('home.capabilities.eyebrow')} title={t('home.capabilities.title')} />
      </MotionReveal>
      <StaggerContainer client:visible staggerDelay={0.1} className="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.03} hoverY={-6}>
            <PremiumCard
              icon="globe-2"
              iconType="lucide"
              title={t('home.cap1.title')}
              description={t('home.cap1.desc')}
              variant="blue"
              size="md"
            />
          </MotionCard>
        </StaggerItem>
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.03} hoverY={-6}>
            <PremiumCard
              icon="users"
              iconType="lucide"
              title={t('home.cap2.title')}
              description={t('home.cap2.desc')}
              variant="purple"
              size="md"
            />
          </MotionCard>
        </StaggerItem>
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.03} hoverY={-6}>
            <PremiumCard
              icon="brain"
              iconType="lucide"
              title={t('home.cap3.title')}
              description={t('home.cap3.desc')}
              variant="gold"
              size="md"
            />
          </MotionCard>
        </StaggerItem>
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.03} hoverY={-6}>
            <PremiumCard
              icon="target"
              iconType="lucide"
              title={t('home.cap4.title')}
              description={t('home.cap4.desc')}
              variant="orange"
              size="md"
            />
          </MotionCard>
        </StaggerItem>
      </StaggerContainer>
    </div>
  </section>

  <!-- Solutions Grid with Premium Cards -->
  <section class="solutions-section section-padding relative overflow-hidden">
    <div class="solutions-bg" aria-hidden="true">
      <div class="solutions-orb solutions-orb-1"></div>
      <div class="solutions-orb solutions-orb-2"></div>
    </div>
    <div class="container-narrow relative z-10">
      <MotionReveal client:visible direction="up" delay={0} duration={0.7}>
        <SectionHeader eyebrow={t('home.solutions.eyebrow')} title={t('home.solutions.title')} />
      </MotionReveal>
      <StaggerContainer client:visible staggerDelay={0.12} className="grid sm:grid-cols-2 gap-6">
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.02} hoverY={-5}>
            <PremiumCard
              icon="briefcase"
              iconType="lucide"
              title={t('home.sol1.title')}
              description={t('home.sol1.desc')}
              href={`/${lang}/corporate-training`}
              linkText={t('solutions.learn')}
              variant="blue"
              size="lg"
              featured={true}
              featuredLabel={t('card.featured')}
            />
          </MotionCard>
        </StaggerItem>
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.02} hoverY={-5}>
            <PremiumCard
              icon="briefcase"
              iconType="lucide"
              title={t('home.sol2.title')}
              description={t('home.sol2.desc')}
              href={`/${lang}/professional-development`}
              linkText={t('solutions.learn')}
              variant="purple"
              size="lg"
            />
          </MotionCard>
        </StaggerItem>
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.02} hoverY={-5}>
            <PremiumCard
              icon="graduation-cap"
              iconType="lucide"
              title={t('home.sol3.title')}
              description={t('home.sol3.desc')}
              href={`/${lang}/academic-support`}
              linkText={t('solutions.learn')}
              variant="gold"
              size="lg"
            />
          </MotionCard>
        </StaggerItem>
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.02} hoverY={-5}>
            <PremiumCard
              icon="book-open"
              iconType="lucide"
              title={t('home.sol4.title')}
              description={t('home.sol4.desc')}
              href={`/${lang}/k12-global-preparation`}
              linkText={t('solutions.learn')}
              variant="orange"
              size="lg"
            />
          </MotionCard>
        </StaggerItem>
      </StaggerContainer>
    </div>
  </section>

  <!-- Methodology -->
  <section class="methodology-section section-padding gradient-section-alt relative overflow-hidden">
    <div class="methodology-bg" aria-hidden="true">
      <div class="methodology-orb methodology-orb-1"></div>
      <div class="methodology-dots"></div>
    </div>
    <div class="container-narrow relative z-10">
      <MotionReveal client:visible direction="up" delay={0} duration={0.7}>
        <SectionHeader eyebrow={t('home.methodology.eyebrow')} title={t('home.methodology.title')} />
      </MotionReveal>
      <div class="max-w-2xl mx-auto">
        <MotionReveal client:visible direction="up" delay={0.1} duration={0.7}>
          <MethodStep step={1} eyebrow={t('home.method1.title')} title={t('home.method1.title')} description={t('home.method1.desc')} stagger={0} />
        </MotionReveal>
        <MotionReveal client:visible direction="up" delay={0.15} duration={0.7}>
          <MethodStep step={2} eyebrow={t('home.method2.title')} title={t('home.method2.title')} description={t('home.method2.desc')} stagger={1} />
        </MotionReveal>
        <MotionReveal client:visible direction="up" delay={0.2} duration={0.7}>
          <MethodStep step={3} eyebrow={t('home.method3.title')} title={t('home.method3.title')} description={t('home.method3.desc')} stagger={2} />
        </MotionReveal>
        <MotionReveal client:visible direction="up" delay={0.25} duration={0.7}>
          <MethodStep step={4} eyebrow={t('home.method4.title')} title={t('home.method4.title')} description={t('home.method4.desc')} stagger={3} />
        </MotionReveal>
        <MotionReveal client:visible direction="up" delay={0.3} duration={0.7}>
          <MethodStep step={5} eyebrow={t('home.method5.title')} title={t('home.method5.title')} description={t('home.method5.desc')} isLast stagger={4} />
        </MotionReveal>
      </div>
    </div>
  </section>

  <!-- Outcomes with StatsBanner -->
  <StatsBanner
    stats={outcomeStats}
    layout="grid"
    theme="gradient"
    title={t('home.outcomes.title')}
    subtitle={t('home.outcomes.subtitle')}
  />

  <!-- Testimonials -->
  <section class="testimonials-section section-padding bg-white relative overflow-hidden">
    <div class="testimonials-bg" aria-hidden="true">
      <div class="testimonials-orb testimonials-orb-1"></div>
      <div class="testimonials-orb testimonials-orb-2"></div>
    </div>
    <div class="container-narrow relative z-10">
      <MotionReveal client:visible direction="up" delay={0} duration={0.7}>
        <SectionHeader eyebrow={t('home.testimonials.eyebrow')} title={t('home.testimonials.title')} />
      </MotionReveal>
      <StaggerContainer client:visible staggerDelay={0.12} className="grid md:grid-cols-3 gap-6">
        <StaggerItem client:visible>
          <MotionCard client:visible hoverScale={1.02} hoverY={-4}>
          <TestimonialCard quote={t('home.test1.quote')} name={t('home.test1.name')} role={t('home.test1.role')} stars={5} avatar="/images/web/Laura.png" />
        </MotionCard>
      </StaggerItem>
      <StaggerItem client:visible>
        <MotionCard client:visible hoverScale={1.02} hoverY={-4}>
          <TestimonialCard quote={t('home.test2.quote')} name={t('home.test2.name')} role={t('home.test2.role')} stars={5} avatar="/images/web/Cristian.png" />
        </MotionCard>
      </StaggerItem>
      <StaggerItem client:visible>
        <MotionCard client:visible hoverScale={1.02} hoverY={-4}>
          <TestimonialCard quote={t('home.test3.quote')} name={t('home.test3.name')} role={t('home.test3.role')} stars={5} avatar="/images/web/Alissa.png" />
          </MotionCard>
        </StaggerItem>
      </StaggerContainer>
    </div>
  </section>

  <!-- NEW: Course Catalog Section -->
  <CourseCatalogSection 
    courses={courses}
    title={t('catalog.title')}
    subtitle={t('catalog.subtitle')}
    eyebrow={t('catalog.eyebrow')}
    filterAllText={t('catalog.filter.all')}
    bestsellerText={t('course.bestseller')}
    featuredText={t('course.featured')}
    studentsText={t('course.students')}
    enrollText={t('course.enroll')}
    viewAllText={t('catalog.viewall')}
    viewAllHref={`/${lang}/solutions`}
  />

  <!-- NEW: Learning Outcomes Section -->
  <LearningOutcomesSection
    outcomes={outcomes}
    title={t('outcomes.title')}
    subtitle={t('outcomes.subtitle')}
    eyebrow={t('outcomes.eyebrow')}
    successTitle={t('outcomes.success')}
    successDesc={t('outcomes.success.desc')}
    successRate={t('outcomes.successRate')}
    completeText={t('outcomes.complete')}
    completeValue={t('outcomes.completeValue')}
    timeText={t('outcomes.time')}
    timeValue={t('outcomes.timeValue')}
    salaryText={t('outcomes.salary')}
    salaryValue={t('outcomes.salaryValue')}
  />

  <!-- NEW: Instructor Spotlight Section -->
  <CourseInstructorSpotlight
    instructors={instructors}
    title={t('instructors.title')}
    subtitle={t('instructors.subtitle')}
    eyebrow={t('instructors.eyebrow')}
    viewAllText={t('instructors.viewall')}
    coursesText={t('instructors.courses')}
    studentsText={t('instructors.students')}
    ratingText={t('instructors.rating')}
  />

  <!-- NEW: Premium Pricing Section -->
  <PremiumPricingSection
    tiers={pricingTiers}
    title={t('pricing.section.title')}
    subtitle={t('pricing.section.subtitle')}
    eyebrow={t('pricing.eyebrow')}
    enterpriseText={t('pricing.enterprise')}
    secureText={t('pricing.secure')}
    secureDesc={t('pricing.secure.desc')}
    billingText={t('pricing.billing')}
    billingDesc={t('pricing.billing.desc')}
    refundText={t('pricing.refund')}
    refundDesc={t('pricing.refund.desc')}
    customSolutionText={t('pricing.customSolution')}
  />

  <!-- NEW: Success Stories Section -->
  <SuccessStoriesSection
    stories={successStories}
    title={t('stories.title')}
    subtitle={t('stories.subtitle')}
    eyebrow={t('stories.eyebrow')}
    viewAllText={t('stories.readmore')}
  />

<!-- NEW: Final CTA Section -->
<FinalCTASection
  title={t('finalcta.title')}
  description={t('finalcta.description')}
  badge={t('finalcta.badge')}
  primaryCta={{ text: t('finalcta.primary'), href: `/${lang}/consultation` }}
  secondaryCta={{ text: t('finalcta.secondary'), href: `/${lang}/solutions` }}
  features={[t('finalcta.trial'), t('finalcta.nocard'), t('finalcta.cancel')]}
  accessTitle={t('finalcta.access')}
  accessDesc={t('finalcta.access.desc')}
  certificateTitle={t('finalcta.certificate')}
  certificateDesc={t('finalcta.certificate.desc')}
  communityTitle={t('finalcta.community')}
  communityDesc={t('finalcta.community.desc')}
 />

  </div>
<Footer />
</Layout>

<style>
  .challenge-image-wrap {
    background: linear-gradient(135deg, rgba(82, 138, 237, 0.08), rgba(166, 123, 244, 0.08));
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 1.25rem;
    padding: 1.5rem;
    border: 1px solid rgba(82, 138, 237, 0.15);
    position: relative;
    box-shadow: 0 8px 32px rgba(82, 138, 237, 0.06);
  }
  .challenge-image-wrap::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: 1.35rem;
    background: var(--gradient-card-border);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.5s var(--ease-out-expo);
