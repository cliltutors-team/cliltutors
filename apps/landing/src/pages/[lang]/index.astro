---
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
    return [
        { params: { lang: "en" } },
        { params: { lang: "es" } },
        { params: { lang: "pt" } },
    ];
}
---

<Layout title="Cliltutors">
    <main
        class="flex min-h-screen flex-col items-center justify-center p-24 bg-gray-50 text-center"
    >
        <h1 class="text-4xl font-bold font-montserrat text-[#34354f]">
            Cliltutors Landing
        </h1>
        <p class="mt-4 text-xl font-poppins text-[#54577c]">Select a page:</p>
        <a
            href="./metodo"
            class="mt-8 px-8 py-4 bg-[#36de6b] text-white rounded-full font-bold shadow-lg transition-transform hover:scale-105"
        >
            Ver Método Cliltutors
        </a>
    </main>
</Layout>
