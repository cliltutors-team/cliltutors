---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PremiumHero from '../../components/PremiumHero.astro';
import PremiumCard from '../../components/PremiumCard.astro';
import StatsBanner from '../../components/StatsBanner.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import PremiumCTABanner from '../../components/PremiumCTABanner.astro';
import LucideIcon from '../../components/LucideIcon.tsx';
import MotionReveal from '../../components/MotionReveal.tsx';
import StaggerContainer, { StaggerItem } from '../../components/StaggerContainer.tsx';
import MotionCard from '../../components/MotionCard.tsx';
import StatsCounter from '../../components/StatsCounter.tsx';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/ui';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const k12Stats = [
  { value: '95%', label: t('k12.stats.bilingual'), trend: 'up' as const, trendValue: '+22%' },
  { value: '87%', label: t('k12.stats.readiness'), trend: 'up' as const, trendValue: '+15%' },
  { value: '94%', label: t('k12.stats.acceptance'), trend: 'up' as const, trendValue: '+30%' },
  { value: '98%', label: t('k12.stats.engagement'), trend: 'up' as const, trendValue: '+12%' }
];

const k12Programs = [
  {
    icon: 'palette',
    iconType: 'lucide' as const,
    title: t('k12.programs.elementary.title'),
    description: t('k12.programs.elementary.desc'),
    metrics: [
      { label: t('k12.programs.elementary.metric1.label'), value: t('k12.programs.elementary.metric1.value') }
    ],
    tags: [t('k12.programs.elementary.tag1'), t('k12.programs.elementary.tag2')],
    variant: 'purple' as const,
    featured: true
  },
  {
    icon: 'book-open',
    iconType: 'lucide' as const,
    title: t('k12.programs.middle.title'),
    description: t('k12.programs.middle.desc'),
    metrics: [
      { label: t('k12.programs.middle.metric1.label'), value: t('k12.programs.middle.metric1.value') }
    ],
    tags: [t('k12.programs.middle.tag1'), t('k12.programs.middle.tag2')],
    variant: 'blue' as const
  },
  {
    icon: 'target',
    iconType: 'lucide' as const,
    title: t('k12.programs.high.title'),
    description: t('k12.programs.high.desc'),
    metrics: [
      { label: t('k12.programs.high.metric1.label'), value: t('k12.programs.high.metric1.value') }
    ],
    tags: [t('k12.programs.high.tag1'), t('k12.programs.high.tag2')],
    variant: 'gold' as const
  },
  {
    icon: 'globe',
    iconType: 'lucide' as const,
    title: t('k12.programs.exchange.title'),
    description: t('k12.programs.exchange.desc'),
    metrics: [
      { label: t('k12.programs.exchange.metric1.label'), value: t('k12.programs.exchange.metric1.value') }
    ],
    tags: [t('k12.programs.exchange.tag1'), t('k12.programs.exchange.tag2')],
    variant: 'orange' as const
  }
];

const methodologySteps = [
  { phase: '01', title: t('k12.method.phase1.title'), items: [t('k12.method.phase1.item1'), t('k12.method.phase1.item2')] },
  { phase: '02', title: t('k12.method.phase2.title'), items: [t('k12.method.phase2.item1'), t('k12.method.phase2.item2')] },
  { phase: '03', title: t('k12.method.phase3.title'), items: [t('k12.method.phase3.item1'), t('k12.method.phase3.item2')] },
  { phase: '04', title: t('k12.method.phase4.title'), items: [t('k12.method.phase4.item1'), t('k12.method.phase4.item2')] }
];

const k12Benefits = [
  {
    icon: 'brain',
    iconType: 'lucide' as const,
    title: t('k12.benefits.cognitive.title'),
    description: t('k12.benefits.cognitive.desc'),
    linkText: t('k12.benefits.link'),
    href: `/${lang}/consultation`,
    variant: 'purple' as const
  },
  {
    icon: 'bar-chart',
    iconType: 'lucide' as const,
    title: t('k12.benefits.academic.title'),
    description: t('k12.benefits.academic.desc'),
    linkText: t('k12.benefits.link'),
    href: `/${lang}/consultation`,
    variant: 'blue' as const
  },
  {
    icon: 'globe',
    iconType: 'lucide' as const,
    title: t('k12.benefits.cultural.title'),
    description: t('k12.benefits.cultural.desc'),
    linkText: t('k12.benefits.link'),
    href: `/${lang}/consultation`,
    variant: 'gold' as const
  },
  {
    icon: 'rocket',
    iconType: 'lucide' as const,
    title: t('k12.benefits.future.title'),
    description: t('k12.benefits.future.desc'),
    linkText: t('k12.benefits.link'),
    href: `/${lang}/consultation`,
    variant: 'orange' as const
  }
];
---

<Layout title={t('k12.meta.title')} description={t('k12.meta.desc')} lang={lang}>
<Navbar />

<div class="k12-page">
<PremiumHero
    eyebrow={t('k12.hero.eyebrow')}
    title={t('k12.hero.title')}
    subtitle={t('k12.hero.subtitle')}
    ctaPrimary={{ text: t('k12.hero.cta'), href: `/${lang}/consultation` }}
    ctaSecondary={{ text: t('k12.hero.cta2'), href: `#programs` }}
    alignment="center"
    theme="gradient"
    trustIndicators={[
      { value: '3,000+', label: t('k12.trust.students') },
      { value: '50+', label: t('k12.trust.schools') },
      { value: '98%', label: t('k12.trust.satisfaction') }
    ]}
  />

  <StatsBanner
    stats={k12Stats}
    theme="gradient"
    title={t('k12.stats.title')}
    subtitle={t('k12.stats.subtitle')}
  />

<section id="programs" class="section-padding gradient-subtle relative overflow-hidden">
<div class="k12-dots" aria-hidden="true"></div>
<div class="container-wide relative">
<SectionHeader
  eyebrow={t('k12.programs.eyebrow')}
  title={t('k12.programs.title')}
  description={t('k12.programs.subtitle')}
/>

		<StaggerContainer className="grid md:grid-cols-2 gap-6" client:visible>
			{k12Programs.map((program, i) => (
				<StaggerItem>
					<MotionCard client:visible>
						<PremiumCard
							icon={program.icon}
							iconType={program.iconType}
							title={program.title}
							description={program.description}
							metrics={program.metrics}
							tags={program.tags}
							variant={program.variant}
							featured={program.featured}
							featuredLabel={t('card.featured')}
							size="lg"
						/>
					</MotionCard>
				</StaggerItem>
			))}
		</StaggerContainer>
    </div>
  </section>

<section class="section-padding gradient-hero relative overflow-hidden">
<div class="k12-orb k12-orb-1" aria-hidden="true"></div>
<div class="k12-orb k12-orb-2" aria-hidden="true"></div>
<div class="container-wide relative">
<SectionHeader
  eyebrow={t('k12.method.eyebrow')}
  title={t('k12.method.title')}
  light={true}
/>

		<StaggerContainer className="grid md:grid-cols-2 lg:grid-cols-4 gap-6" client:visible>
			{methodologySteps.map((phase, i) => (
				<StaggerItem>
					<div class="process-card">
						<div class="phase-number">{phase.phase}</div>
						<h3 class="phase-title">{phase.title}</h3>
						<ul class="phase-items">
							{phase.items.map((item) => (
								<li class="phase-item">
									<LucideIcon client:idle name="check" size={18} color="currentColor" className="text-brand-gold" />
									{item}
								</li>
							))}
						</ul>
						{i < methodologySteps.length - 1 && (
							<div class="process-connector hidden lg:block" aria-hidden="true"></div>
						)}
					</div>
				</StaggerItem>
			))}
		</StaggerContainer>
    </div>
  </section>

<section class="section-padding gradient-section-alt relative overflow-hidden">
  <div class="container-wide">
    <SectionHeader
      eyebrow={t('k12.benefits.eyebrow')}
  title={t('k12.benefits.title')}
  description={t('k12.benefits.subtitle')}
/>

		<StaggerContainer className="grid lg:grid-cols-4 gap-6" client:visible>
			{k12Benefits.map((benefit, i) => (
				<StaggerItem>
					<MotionCard client:visible>
						<PremiumCard
							icon={benefit.icon}
							iconType={benefit.iconType}
							title={benefit.title}
							description={benefit.description}
							href={benefit.href}
							linkText={benefit.linkText}
							variant={benefit.variant}
							size="md"
						/>
					</MotionCard>
				</StaggerItem>
			))}
		</StaggerContainer>
    </div>
  </section>

<section class="section-padding gradient-hero text-white relative overflow-hidden">
<div class="k12-navy-orb" aria-hidden="true"></div>
<div class="container-wide relative">
<div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
			<MotionReveal client:visible>
				<SectionHeader eyebrow={t('k12.featured.eyebrow')} title={t('k12.featured.title')} description={t('k12.featured.desc')} light />
			</MotionReveal>

			<StaggerContainer className="grid grid-cols-2 gap-6" client:visible>
<StaggerItem>
          <div class="featured-stat">
            <div class="featured-value"><StatsCounter client:visible value={t('k12.featured.stat1.value')} /></div>
            <div class="featured-label">{t('k12.featured.stat1.label')}</div>
          </div>
        </StaggerItem>
        <StaggerItem>
          <div class="featured-stat">
            <div class="featured-value"><StatsCounter client:visible value={t('k12.featured.stat2.value')} /></div>
            <div class="featured-label">{t('k12.featured.stat2.label')}</div>
          </div>
        </StaggerItem>
			</StaggerContainer>
        </div>

		<StaggerContainer className="featured-cards" client:visible>
			<StaggerItem>
				<MotionCard client:visible>
					<div class="featured-card-item">
						<div class="card-icon-wrap">
							<LucideIcon client:idle name="bar-chart" size={24} color="white" />
						</div>
						<div>
							<h4 class="font-heading font-semibold text-lg">{t('k12.featured.card1.title')}</h4>
							<p class="text-white/70 text-sm">{t('k12.featured.card1.desc')}</p>
						</div>
					</div>
				</MotionCard>
			</StaggerItem>
			<StaggerItem>
				<MotionCard client:visible>
					<div class="featured-card-item">
						<div class="card-icon-wrap">
							<LucideIcon client:idle name="pencil" size={24} color="white" />
						</div>
						<div>
							<h4 class="font-heading font-semibold text-lg">{t('k12.featured.card2.title')}</h4>
							<p class="text-white/70 text-sm">{t('k12.featured.card2.desc')}</p>
						</div>
					</div>
				</MotionCard>
			</StaggerItem>
			<StaggerItem>
				<MotionCard client:visible>
					<div class="featured-card-item">
						<div class="card-icon-wrap">
							<LucideIcon client:idle name="message-circle" size={24} color="white" />
						</div>
						<div>
							<h4 class="font-heading font-semibold text-lg">{t('k12.featured.card3.title')}</h4>
							<p class="text-white/70 text-sm">{t('k12.featured.card3.desc')}</p>
						</div>
					</div>
				</MotionCard>
			</StaggerItem>
		</StaggerContainer>
      </div>
    </div>
  </section>

<section class="section-padding relative overflow-hidden">
<div class="container-wide relative">
<PremiumCTABanner
  title={t('k12.cta.title')}
  description={t('k12.cta.subtitle')}
  primaryCTA={{ text: t('k12.cta.btn'), href: `/${lang}/consultation` }}
  secondaryCTA={{ text: t('k12.cta.secondary'), href: `/${lang}/methodology` }}
  variant="gradient"
      trustBadges={[
        { icon: 'graduation-cap', iconType: 'lucide' as const, label: t('k12.trust.students'), value: '3,000+' },
        { icon: 'school', iconType: 'lucide' as const, label: t('k12.trust.schools'), value: '50+' },
        { icon: 'star', iconType: 'lucide' as const, label: t('k12.trust.satisfaction'), value: '98%' }
      ]}
/>
</div>
</section>

<Footer />
</div>
</Layout>

<style>
.k12-dots {
  position: absolute;
  inset: 0;
  opacity: 0.3;
  background-image: radial-gradient(circle, var(--color-brand-blue-200) 1px, transparent 1px);
  background-size: 32px 32px;
  pointer-events: none;
}

.k12-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
}

.k12-orb-1 {
  top: -15%;
  right: -10%;
  width: 400px;
  height: 400px;
  background: rgba(255, 255, 255, 0.15);
}

.k12-orb-2 {
  bottom: -15%;
  left: -10%;
  width: 350px;
  height: 350px;
  background: rgba(166, 123, 244, 0.15);
}

.k12-navy-orb {
  position: absolute;
  top: -20%;
  right: -15%;
  width: 500px;
  height: 500px;
  border-radius: 50%;
  background: rgba(82, 138, 237, 0.08);
  filter: blur(100px);
  pointer-events: none;
}

.process-card {
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid rgba(82, 138, 237, 0.18);
  border-radius: 1.25rem;
  padding: 2rem;
  position: relative;
  transition: all 400ms var(--ease-out-expo);
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  overflow: hidden;
}

.process-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 1.25rem;
  padding: 1px;
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.5), rgba(166, 123, 244, 0.5));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 400ms var(--ease-out-expo);
  pointer-events: none;
}

.process-card:hover {
  background: rgba(255, 255, 255, 0.16);
  border-color: transparent;
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(82, 138, 237, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.15);
}

.process-card:hover::after {
  opacity: 0.6;
}

.phase-number {
  font-family: var(--font-heading);
  font-size: 3rem;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.2);
  line-height: 1;
  margin-bottom: 1rem;
  transition: color 400ms var(--ease-out-expo);
}

.process-card:hover .phase-number {
  color: rgba(254, 187, 55, 0.5);
}

  .phase-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1rem;
  }

  .phase-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .phase-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9375rem;
    margin-bottom: 0.5rem;
  }

.process-connector {
    position: absolute;
    top: 50%;
    right: -1.5rem;
    width: 3rem;
    height: 2px;
    background: linear-gradient(90deg, rgba(255,255,255,0.3), rgba(255,255,255,0.1));
  }

.featured-stat {
  padding: 1.5rem;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: 1rem;
  border: 1px solid rgba(82, 138, 237, 0.15);
  box-shadow: 0 8px 32px rgba(82, 138, 237, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.08);
}

  .featured-value {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-brand-gold);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .featured-value .stat-value {
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    color: inherit;
    display: inline;
  }

  .featured-label {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .featured-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

.featured-card-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(82, 138, 237, 0.15);
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(82, 138, 237, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.06);
    transition: all 400ms var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }

  .featured-card-item::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 1rem;
    padding: 1.5px;
    background: linear-gradient(135deg, var(--color-brand-blue), var(--color-brand-purple));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
  }

  .featured-card-item:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: transparent;
    transform: translateX(8px);
    box-shadow: 0 8px 28px rgba(82, 138, 237, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  .featured-card-item:hover::after {
    opacity: 1;
  }

.card-icon-wrap {
  width: 3.5rem;
  height: 3.5rem;
  background: linear-gradient(135deg, rgba(82, 138, 237, 0.2), rgba(166, 123, 244, 0.2));
  border: 1px solid rgba(82, 138, 237, 0.2);
  border-radius: 0.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 400ms var(--ease-out-expo);
}

.featured-card-item:hover .card-icon-wrap {
  transform: scale(1.08) rotate(3deg);
  border-color: rgba(82, 138, 237, 0.35);
}

@media (max-width: 1024px) {
.process-connector {
display: none;
}
}
